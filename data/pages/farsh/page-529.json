{"page":529,"data":{"54:7:1":[{"f":"خُشَّعًا","r":"أكدناَ","n":"بفتح الخاء وكسر وتخفيف الشين وألف بينهما"},{"f":"خَٰشِعًا","r":"ففَر ح حَ","n":"بفتح الخاء وكسر وتخفيف الشين وألف بينهما"}],"54:11:1":[{"f":"فَفَتَحۡنَآ","r":"احظ","n":"بتشديد التاء"},{"f":"فَفَتَّحۡنَآ","r":"كاَحَ","n":"بتشديد التاء"}],"54:12:3":[{"f":"عُيُونٗا","r":"احلعاَحَفَ","n":"كسر العين"},{"f":"عِيُونٗا","r":"دمصفر","n":"كسر العين"}],"54:26:1":[{"f":"سَيَعۡلَمُونَ","r":"حرفَ أحَدناَ","n":"بتاء الخطاب"},{"f":"سَتَعۡلَمُونَ","r":"كف","n":"بتاء الخطاب"}]}}