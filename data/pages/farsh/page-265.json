{"page":265,"data":{"15:53:5":[{"f":"نُبَشِّرُكَ","r":"ادحكنراَحَفَ","n":"بفتح النون وسكون الباء وضم وتخفيف الشين"},{"f":"نَبۡشُرُكَ","r":"ف","n":"بفتح النون وسكون الباء وضم وتخفيف الشين"}],"15:54:8":[{"f":"تُبَشِّرُونَ","r":"دحكنفراَحَفَ","n":"بكسر النون مخففة"},{"f":"تُبَشِّرُونِ","r":"ا","n":"بكسر النون مخففة"},{"f":"تُبَشِّرُوٓنِّ","r":"د","n":"بكسر النون مشددة مع المد المشبع"}],"15:56:3":[{"f":"يَقۡنَطُ","r":"فاكدناَ","n":"بكسر النون"},{"f":"يَقۡنِطُ","r":"فر ح حَ","n":"بكسر النون"}],"15:59:5":[{"f":"لَمُنَجُّوهُمۡ","r":"احن اَكد","n":"بسكون النون وتخفيف الجيم"},{"f":"لَمُنجُوهُمۡ","r":"ففَرحَ","n":"بسكون النون وتخفيف الجيم"}],"15:60:3":[{"f":"قَدَّرۡنَآ","r":"ادحكعفراَحَفَ","n":"بتخفيف الدال"},{"f":"قَدَرۡنَآ","r":"ص","n":"بتخفيف الدال"}],"15:65:1":[{"f":"فَأَسۡرِ","r":"حكنفرحَفَ","n":"بوصل الهمزة"},{"f":"فَٱسۡرِ","r":"اداَ","n":"بوصل الهمزة"}]}}