{"page":463,"data":{"39:42:13":[{"f":"قَضَىٰ عَلَيۡهَا ٱلۡمَوۡتَ","r":"ادحكناَحَ","n":"بضم القاف وكسر الضاد وياء مفتوحة ورفع التاء"},{"f":"قُضِيَ عَلَيۡهَا ٱلۡمَوۡتُ","r":"فرفَ","n":"بضم القاف وكسر الضاد وياء مفتوحة ورفع التاء"}],"39:44:11":[{"f":"تُرۡجَعُونَ","r":"ادحكنفراَفَ","n":"بفتح التاء وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بفتح التاء وكسر الجيم"}]}}