{"page":20,"data":{"2:127:3":[{"f":"إِبۡرَٰهِ‍ۧمَ","r":"ادحنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"لم²","n":"بفتح الهاء وألف بعدها"}],"2:128:10":[{"f":"وَأَرِنَا","r":"ادىكنفراَحَفَ","n":"باختلاس كسر الراء"},{"f":"وَأَرۡنَا","r":"يد حَ","n":"إسكان الراء مفخمة"},{"f":"وَأَرٜنَا","r":"ط","n":"باختلاس كسر الراء"}],"2:132:1":[{"f":"وَوَصَّىٰ","r":"غد","n":"تخفيف الصاد وسكون الواو قبلها \nوهمزة مفتوحة بين الواوين"},{"f":"وَأَوۡصَيٰ","r":"اكاَ","n":"تخفيف الصاد وسكون الواو قبلها \nوهمزة مفتوحة بين الواوين"}]}}