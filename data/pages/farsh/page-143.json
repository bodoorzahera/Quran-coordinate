{"page":143,"data":{"6:119:11":[{"f":"فَصَّلَ - حَرَّمَ","r":"عاحَا","n":"بفتح الفاء والصاد وضم الحاء وكسر الراء"},{"f":"فَصَّلَ -حُرِّمَ","r":"فصرفَ","n":"بفتح الفاء والصاد وضم الحاء وكسر الراء"},{"f":"فُصِّلَ -حُرِّمَ","r":"حدك","n":"بضم الفاء والحاء وكسر الصاد والراء"}],"6:119:22":[{"f":"لَّيُضِلُّونَ","r":"ث","n":"بفتح الياء"},{"f":"لَّيَضِلُّونَ","r":"اكداَ ح حَ","n":"بفتح الياء"}],"6:122:3":[{"f":"مَيۡتٗا","r":"حظك","n":"بكسر وتشديد الياء"},{"f":"مَيِّتٗا","r":"ااَحَن","n":"بكسر وتشديد الياء"}],"6:124:18":[{"f":"رِسَالَتَهُ","r":"دع","n":"اجمع واكسر التاء والهاء"},{"f":"رِسَالَٰتِهِ","r":"صحف افَراَحَك","n":"اجمع واكسر التاء والهاء"}]}}