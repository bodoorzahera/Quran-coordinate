{"page":425,"data":{"33:51:1":[{"f":"تُرۡجِي","r":"افعاَرفَ","n":"بهمزة مرفوعة بعد الجيم"},{"f":"تُرۡجِئُ","r":"حدك صحَ","n":"بهمزة مرفوعة بعد الجيم"}],"33:52:2":[{"f":"يَحِلُّ","r":"ادكنفراَفَ","n":"بالتاء"},{"f":"تَحِلُّ","r":"ححَ","n":"بالتاء"}],"33:52:9":[{"f":"أَن تَبَدَّلَ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء وصلاً"},{"f":"أَن تَّبَدَّلَ","r":"ه","n":"بتشديد التاء وصلاً"}],"33:53:6":[{"f":"بُيُوتَ","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"بِيُوتَ","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}],"33:53:7":[{"f":"ٱلنَّبِيِّ إِلَّآ ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓءِ الَّآ ","r":"ا","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيَّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓءَ","r":"ا","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيِّ إِلَّآ","r":"دحكنفراَحَفَ"},{"f":"ٱلنَّبِيٓءِ الَّآ","r":"ا"}],"33:53:42":[{"f":"فَسۡـَٔلُوهُنَّ","r":"احكناَحَ","n":"بالنقل"},{"f":"فَسَلُوهُنَّ","r":"دفرفَ","n":"بالنقل"}]}}