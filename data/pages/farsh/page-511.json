{"page":511,"data":{"48:2:14":[{"f":"صِرَٰطٗا","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطٗا","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٗا","r":"ض","n":"بإشمام الصاد زاياً"}],"48:6:9":[{"f":"ٱلسَّوۡءِ","r":"اكنفراَحَفَ","n":"بضم السين فتمد الواو على المتصل"},{"f":"ٱلسُّوٓءِ","r":"دح","n":"بضم السين فتمد الواو على المتصل"}],"48:9:1":[{"f":"لِّتُؤۡمِنُواْ -وَتُعَزِّرُوهُ وَتُوَقِّرُوهُۚ وَتُسَبِّحُوهُ","r":"اكنفراَحَفَ","n":"بالياء"},{"f":"لِّيُؤۡمِنُواْ - وَيُعَزِّرُوهُ \nوَيُوَقِّرُوهُۚ \nوَيُسَبِّحُوهُ","r":"دح","n":"بالياء"}]}}