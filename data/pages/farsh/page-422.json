{"page":422,"data":{"33:31:6":[{"f":"وَتَعۡمَلۡ -نُّؤۡتِهَآ","r":"ادحكناَحَ","n":"بالياء"}],"33:31:8":[{"f":"وَيَعۡمَلۡ -يُّؤۡتِهَآ","r":"فرفَ","n":"بالياء"}],"33:32:2":[{"f":"ٱلنَّبِيِّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓءِ","r":"ا","n":"بالهمز فيمد على المتصل"}],"33:33:1":[{"f":"وَقَرۡنَ","r":"اناَ","n":"بكسر القاف"},{"f":"وَقِرۡنَ","r":"فح فَحَ كدر","n":"بكسر القاف"}],"33:33:4":[{"f":"وَلَا تَبَرَّجۡنَ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء وصلا فتمد الألف مشبعاً"},{"f":"وَلَآ تَّبَرَّجۡنَ","r":"ه","n":"بتشديد التاء وصلا فتمد الألف مشبعاً"}]}}