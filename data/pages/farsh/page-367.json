{"page":367,"data":{"26:1:1":[{"f":"طسٓمٓ ","r":"ادحكنرحَفَ","n":"س بالسكت على حروفه -نۡ أظهر نون السين"},{"f":"طسٓمٓ","r":"ادحكنرحَفَ"}],"26:4:3":[{"f":"نُنَزِّلۡ","r":"اكنفراَفَ","n":"بسكون النون وتخفيف الزاي"},{"f":"نُنزِلۡ","r":"دححَ","n":"بسكون النون وتخفيف الزاي"}],"26:9:3":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"26:13:1":[{"f":"وَيَضِيقُ -يَنطَلِقُ","r":"ادحكنفراَفَ","n":"بالنصب"},{"f":"وَيَضِيقَ -يَنطَلِقَ","r":"حَ","n":"بالنصب"}]}}