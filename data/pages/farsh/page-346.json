{"page":346,"data":{"23:67:4":[{"f":"تَهۡجُرُونَ","r":"دحكنفراَحَفَ","n":"بضم التاء وكسر الجيم"},{"f":"تُهۡجِرُونَ","r":"ا","n":"بضم التاء وكسر الجيم"}],"23:72:3":[{"f":"خَرۡجٗا","r":"ادحكناَحَ","n":"بفتح الراء وألف بعدها"},{"f":"خَرَٰجٗا","r":"فرفَ","n":"بفتح الراء وألف بعدها"}],"23:72:4":[{"f":"فَخَرَاجُ","r":"ادحنفراَحَفَ","n":"بسكون الراء دون ألف"},{"f":"فَخَرۡاْجُ","r":"ك","n":"بسكون الراء دون ألف"}],"23:72:7":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"23:73:4":[{"f":"صِرَٰطٖ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"}],"23:74:7":[{"f":"ٱلصِّرَٰطِ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"ٱلصِّۜرَٰطِ","r":"زطَ","n":"بالسين"},{"f":"ٱلصـِّؗـرَٰطِ","r":"ض","n":"بإشمام الصاد زاياً"}]}}