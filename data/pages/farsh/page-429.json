{"page":429,"data":{"34:9:13":[{"f":"نَّشَأۡ نَخۡسِفۡ -نُسۡقِطۡ","r":"ادحكناَحَ","n":"بالياء"},{"f":"يَّشَأۡ يَخۡسِفۡ -يُسۡقِطۡ","r":"فرفَ","n":"بالياء"}],"34:9:20":[{"f":"كِسَفٗا","r":"ع","n":"بسكون السين"},{"f":"كِسۡفٗا","r":"ادحكصفراَحَفَ","n":"بسكون السين"}],"34:12:2":[{"f":"ٱلرِّيحَ","r":"اعفك در فَححَ","n":"بضم الحاء"},{"f":"ٱلرِّيحُ","r":"ص","n":"بضم الحاء"},{"f":"ٱلرِّيَٰحَ","r":"اَ","n":"بفتح الياء وألف بعدها مع فتح الحاء"}],"34:14:13":[{"f":"مِنسَأَتَهُ","r":"لحَظ","n":"بإبدال الهمزة ألفا (ويقف حمزة بين بين)"},{"f":"مِنسَاتَهُ","r":"احاَ","n":"بإبدال الهمزة ألفا (ويقف حمزة بين بين)"},{"f":"مِنسَأۡتَهُ","r":"م","n":"بسكون الهمزة"}],"34:14:16":[{"f":"تَبَيَّنَتِ","r":"ادحكنفراَىَفَ","n":"بضم التاء والباء وكسر الياء"},{"f":"تُبُيِّنَتِ","r":"طَ","n":"بضم التاء والباء وكسر الياء"}]}}