{"page":434,"data":{"34:52:6":[{"f":"ٱلتَّنَاوُشُ","r":"ادعاَك حَ","n":"بهمز الواو مع مد الألف على المتصل"},{"f":"ٱلتَّنَآؤُشُ","r":"ح فصرفَ","n":"بهمز الواو مع مد الألف على المتصل"}],"34:54:1":[{"f":"وَحِيلَ","r":"ادحنفاَىَفَ","n":"بإشمام كسر الحاء ضماً"},{"f":"وَح۬يلَ","r":"كرطَ","n":"بإشمام كسر الحاء ضماً"}],"35:2:17":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"35:3:10":[{"f":"غَيۡرُ ٱللَّهِ","r":"كاَحد حَن","n":"بكسر الراء"},{"f":"غَيۡرِ ٱللَّهِ","r":"فراَفَ","n":"بكسر الراء"}]}}