{"page":299,"data":{"18:47:2":[{"f":"نُسَيِّرُ ٱلۡجِبَالَ","r":"ااَحث","n":"بالتاء وفتح الياء ورفع اللام"},{"f":"تُسَيَّرُ ٱلۡجِبَالُ","r":"ح دك","n":"بالتاء وفتح الياء ورفع اللام"}],"18:50:3":[{"f":"لِلۡمَلَٰٓئِكَةِ ٱسۡجُدُواْ ","r":"ادحكنفرحَفَ","n":"بضم التاء"},{"f":"لِلۡمَلَٰٓئِكَةُ ٱسۡجُدُواْ","r":"اَ","n":"بضم التاء"},{"f":"لِلۡمَلَٰٓئِكَةِ ٱسۡجُدُواْ","r":"ادحكنفرحَفَ"}],"18:51:2":[{"f":"أَشۡهَدتُّهُمۡ","r":"ادحكنفرحَفَ","n":"بنون مفتوحة وألف"},{"f":"أَشۡهَدۡنَٰهُمۡ","r":"اَ","n":"بنون مفتوحة وألف"}],"18:51:10":[{"f":"وَمَا كُنتُ","r":"ادحكنفرحَفَ","n":"بفتح التاء"},{"f":"وَمَا كُنتَ","r":"اَ","n":"بفتح التاء"}],"18:52:2":[{"f":"يَقُولُ","r":"ادحكنراَحَفَ","n":"بالنون"},{"f":"نَقُولُ","r":"ف","n":"بالنون"}]}}