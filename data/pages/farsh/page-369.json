{"page":369,"data":{"26:42:2":[{"f":"نَعَمۡ","r":"ادحكنفاَحَفَ","n":"بكسر العين"},{"f":"نَعِمۡ","r":"ر","n":"بكسر العين"}],"26:45:6":[{"f":"تَلۡقَفُ","r":"ع","n":"بفتح اللام وتشديد القاف"},{"f":"تَلَقَّفُ","r":"زاح كفر فَصاَحَ","n":"بفتح اللام وتشديد القاف"},{"f":"تَّلَقَّفُ","r":"ه","n":"تشديد التاء وصلا وفتح اللام وتشديد القاف"}],"26:52:5":[{"f":"أَنۡ أَسۡرِ","r":"كغ","n":"بهمزة وصل وكسر أولى الساكنين"},{"f":"أنِ ٱسۡرِ","r":"اداَ","n":"بهمزة وصل وكسر أولى الساكنين"}],"26:56:3":[{"f":"حَٰذِرُونَ","r":"ثم","n":"بدون الألف (بالقصر)"},{"f":"حَذِرُونَ","r":"احد حَاَل","n":"بدون الألف (بالقصر)"}],"26:57:4":[{"f":"وَعُيُونٖ","r":"ح حَ الاَعفَ","n":"كسر العين"},{"f":"وَعِيُونٖ","r":"صف رمد","n":"كسر العين"}]}}