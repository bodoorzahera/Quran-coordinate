{"page":157,"data":{"7:54:15":[{"f":"يُغۡشِي","r":"ح ادعاَك","n":"بفتخ الغين وتشديد الشين"},{"f":"يُغَشِّي","r":"صف فَرحَ","n":"بفتخ الغين وتشديد الشين"}],"7:54:20":[{"f":"وَٱلشَّمۡسَ وَٱلۡقَمَرَ وَٱلنُّجُومَ مُسَخَّرَٰتِۭ","r":"ادحنفراَحَفَ","n":"برفعهم"}],"7:54:22":[{"f":"وَٱلشَّمۡسُ \nوَٱلۡقَمَرُ \nوَٱلنُّجُومُ \nمُسَخَّرَٰتُۢ","r":"ك","n":"برفعهم"}],"7:55:4":[{"f":"وَخُفۡيَةً","r":"ادحكعفراَحَفَ","n":"بكسر الخاء"},{"f":"وَخِفۡيَةً","r":"ص","n":"بكسر الخاء"}],"7:57:1":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}],"7:57:4":[{"f":"ٱلرِّيَٰحَ","r":"اكاَن ح حَ","n":"سكون الياء دون الألف"},{"f":"ٱلرِّيحَ","r":"ففَرد","n":"سكون الياء دون الألف"}],"7:57:5":[{"f":"بُشۡرَۢا","r":"ن","n":"بنون مضمومة وسكون الشين"}],"7:57:16":[{"f":"مَّيِّتٖ","r":"افعاَرفَ","n":"بسكون الياء"},{"f":"مَّيۡتٖ","r":"حصدك حَ","n":"بسكون الياء"}],"7:57:29":[{"f":"تَذَكَّرُونَ","r":"فعرفَ","n":"تشديد الذال"},{"f":"تَذَّكَّرُونَ","r":"اكداَ صححَ","n":"تشديد الذال"}]}}