{"page":575,"data":{"73:20:8":[{"f":"ثُلُثَيِ","r":"ادحمنفراَحَفَ","n":"بسكون اللام"},{"f":"ثُلۡثَيِ","r":"ل","n":"بسكون اللام"}],"73:20:10":[{"f":"وَنِصۡفَهُۥ وَثُلُثَهُۥ","r":"دنفرفَ","n":"بكسر الفاء والثاء والهاء  على الخفض"},{"f":"وَنِصۡفِهِۦ وَثُلُثِهِۦ","r":"احكاَحَ","n":"بكسر الفاء والثاء والهاء  على الخفض"}],"73:20:30":[{"f":"ٱلۡقُرۡءَانِ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانِ","r":"دف","n":"بالنقل"}],"74:5:1":[{"f":"وَٱلرُّجۡزَ","r":"عاَحَ","n":"بكسر الراء"}]}}