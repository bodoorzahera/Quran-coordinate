{"page":85,"data":{"4:40:9":[{"f":"حَسَنَةً -يُضَٰعِفۡهَا","r":"دحكنفراَحَفَ","n":"بالرفع - بالألف والتخفيف"},{"f":"حَسَنَةٌ -يُضَٰعِفۡهَا ","r":"ا","n":"بالرفع - بالألف والتخفيف"},{"f":"حَسَنَةٌ -يُضَعِّفۡهَا","r":"داَ","n":"بالرفع - بالتشديد دون ألف"},{"f":"حَسَنَةً -يُضَعِّفۡهَا","r":"كحَ","n":"بالنصب - بالتشديد دون ألف"},{"f":"حَسَنَةً","r":"كغ"},{"f":"حَسَنَةٌ","r":"اداَ"},{"f":"حَسَنَةٌ -يُضَٰعِفۡهَا","r":"ا"}],"4:40:10":[{"f":"يُضَٰعِفۡهَا","r":"احث"},{"f":"يُضَعِّفۡهَا","r":"كدحَاَ"}],"4:42:8":[{"f":"تُسَوَّىٰ","r":"ند ح حَ","n":"بفتح التاء وتشديد السين"},{"f":"تَسَّوَّىٰ","r":"اكاَ","n":"بفتح التاء وتشديد السين"},{"f":"تَسَوَّىٰ","r":"ففَر","n":"بفتح التاء والتخفيف"}],"4:43:33":[{"f":"لَٰمَسۡتُمُ","r":"احد نكاَحَ","n":"بحذف الألف"},{"f":"لَمَسۡتُمُ","r":"ففَر","n":"بحذف الألف"}]}}