{"page":335,"data":{"22:24:8":[{"f":"صِرَٰطِ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطِ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطِ","r":"ض","n":"بإشمام الصاد زاياً"}],"22:25:13":[{"f":"سَوَآءً","r":"ع","n":"بالرفع"},{"f":"سَوَآءٌ","r":"ادحكصفراَحَفَ","n":"بالرفع"}],"22:29:2":[{"f":"لْيقضوا","r":"بث يَها"},{"f":"لِيقضو","r":"جز حطَك"}],"22:29:4":[{"f":"وَلۡيُوفُواْ","r":"احد عرف اَفَلحَ","n":"بكسر اللام"},{"f":"وَلِيُوفُواْ","r":"م","n":"بكسر اللام"},{"f":"وَلۡيُوَفُّواْ","r":"ص","n":"بسكون اللام وفتح الواو وتشديد الفاء"}],"22:29:6":[{"f":"وَلۡيَطَّوَّفُواْ","r":"ادحلنفراَحَفَ","n":"بكسر اللام"},{"f":"وَلِيَطَّوَّفُواْ","r":"م","n":"بكسر اللام"}],"22:30:6":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}