{"page":408,"data":{"30:35:5":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"30:36:15":[{"f":"يَقۡنَطُونَ","r":"فاكدناَ","n":"بكسر النون"},{"f":"يَقۡنِطُونَ","r":"حرفَ حَ","n":"بكسر النون"}],"30:39:2":[{"f":"ءَاتَيۡتُم مِّن رِّبٗا ","r":"احكنفراَحَفَ","n":"بالقصر بحذف الألف"},{"f":"أَتَيۡتُم مِّن رِّبٗا ","r":"د","n":"بالقصر بحذف الألف"},{"f":"ءَاتَيۡتُم مِّن رِّبٗا","r":"احكنفراَحَفَ"},{"f":"أَتَيۡتُم مِّن رِّبٗا","r":"د"}],"30:39:5":[{"f":"لِّيَرۡبُوَاْ ","r":"دحكنفرفَ","n":"بتاء الخطاب مضمومة وسكون الواو"},{"f":"لِّتُرۡبُواْ ","r":"ااَحَ","n":"بتاء الخطاب مضمومة وسكون الواو"},{"f":"لِّيَرۡبُوَاْ","r":"حظك"},{"f":"لِّتُرۡبُواْ","r":"ااَحَ"}],"30:40:22":[{"f":"يُشۡرِكُونَ","r":"ادحكناَحَ","n":"بتاء الخطاب"},{"f":"تُشۡرِكُونَ","r":"فرفَ","n":"بتاء الخطاب"}],"30:41:10":[{"f":"لِيُذِيقَهُم","r":"احاَطَه ذ","n":"بالنون"},{"f":"لِنُذِيقَهُم","r":"زيَ","n":"بالنون"}]}}