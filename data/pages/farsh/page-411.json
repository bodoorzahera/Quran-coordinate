{"page":411,"data":{"31:1:1":[{"f":"الٓمٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"31:3:2":[{"f":"وَرَحۡمَةٗ","r":"ادحكنراَحَفَ","n":"بضم التاء"},{"f":"وَرَحۡمَةٞ","r":"ف","n":"بضم التاء"}],"31:6:7":[{"f":"لِيُضِلَّ","r":"اكنفراَحَفَ","n":"بفتح الياء"},{"f":"لِيَضِلَّ","r":"دح","n":"بفتح الياء"}],"31:6:13":[{"f":"وَيَتَّخِذَهَا","r":"عف فَرحَ","n":"برفع الذال"},{"f":"وَيَتَّخِذُهَا","r":"احصاَدك","n":"برفع الذال"}],"31:6:14":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"31:7:12":[{"f":"أُذُنَيۡهِ","r":"دحكنفراَحَفَ","n":"بسكون الذال"},{"f":"أُذۡنَيۡهِ","r":"ا","n":"بسكون الذال"}],"31:9:6":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}