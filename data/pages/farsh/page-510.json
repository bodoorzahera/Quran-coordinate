{"page":510,"data":{"47:31:1":[{"f":"وَلَنَبۡلُوَنَّكُمۡ -نَعۡلَمَ -وَنَبۡلُوَاْ","r":"ادحكعفراَحَفَ","n":"بالياء"},{"f":"وَلَيَبۡلُوَنَّكُمۡ -يَعۡلَمَ -وَيَبۡلُوَاْ","r":"ص","n":"بالياء"}],"47:31:7":[{"f":"وَنَبۡلُوَاْ","r":"ادحكنفراَىَفَ","n":"بسكون الواو"},{"f":"وَنَبۡلُواْ","r":"طَ","n":"بسكون الواو"}],"47:35:5":[{"f":"ٱلسَّلۡمِ","r":"ادعاَك ح حَ","n":"بكسر السين"},{"f":"ٱلسِّلۡمِ","r":"فصفَ","n":"بكسر السين"}],"47:38:1":[{"f":"هَٰٓأَنتُمۡ","r":"اهحكنفراَحَفَ","n":"حذف الألف وتحقيق الهمز"},{"f":"هَأَنتُمۡ","r":"ز","n":"حذف الألف وتحقيق الهمز"},{"f":"هَا۬نتُمۡ","r":"ج","n":"حذف الألف وتسهيل الهمزة"},{"f":"هَآنتُمۡ","r":"ج","n":"بحذف الهمزة وتمد الألف مشبعاً"},{"f":"هَٰا۬نتُمۡ","r":"بحاَ","n":"بتسهيل الهمزة مع قصر "},{"f":"هَٰٓا۬نتُمۡ","r":"بط","n":"بتسهيل الهمزة مع مد"}]}}