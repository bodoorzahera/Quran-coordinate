{"page":502,"data":{"45:34:1":[{"f":"وَقِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"وَقـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"45:35:6":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"45:35:12":[{"f":"يُخۡرَجُونَ","r":"ادحكناَحَ","n":"بفتح الياء وضم الراء"},{"f":"يَخۡرُجُونَ","r":"فرفَ","n":"بفتح الياء وضم الراء"}],"45:37:6":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"46:1:1":[{"f":"حمٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حرفيه"}]}}