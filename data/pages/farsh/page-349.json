{"page":349,"data":{"23:106:5":[{"f":"شِقۡوَتُنَا","r":"ادحكناَحَ","n":"بفتح الشين والقاف وألف بعدها"},{"f":"شَقَٰوَتُنَا","r":"فرفَ","n":"بفتح الشين والقاف وألف بعدها"}],"23:110:2":[{"f":"سِخۡرِيًّا","r":"دحكنحَ","n":"بضم السين"},{"f":"سُخۡرِيًّا","r":"افراَفَ","n":"بضم السين"}],"23:111:6":[{"f":"أَنَّهُمۡ","r":"ادحكناَحَفَ","n":"بكسر الهمزة"},{"f":"إِنَّهُمۡ","r":"فر","n":"بكسر الهمزة"}],"23:112:1":[{"f":"قَٰلَ كَمۡ","r":"احكناَحَفَ","n":"بالأمر"},{"f":"قُلۡ كَمۡ","r":"دفر","n":"بالأمر"}],"23:113:7":[{"f":"فَسۡـَٔلِ","r":"احكناَحَ","n":"بالنقل"},{"f":"فَسَلِ","r":"دفرفَ","n":"بالنقل"}],"23:114:1":[{"f":"قَٰلَ إِن","r":"ادحكناَحَفَ","n":"بالأمر"},{"f":"قُلۡ إِن","r":"فر","n":"بالأمر"}],"23:115:8":[{"f":"تُرۡجَعُونَ","r":"ادحكناَ","n":"بفتح التاء وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"فرحَفَ","n":"بفتح التاء وكسر الجيم"}]}}