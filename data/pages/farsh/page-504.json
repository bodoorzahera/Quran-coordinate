{"page":504,"data":{"46:15:4":[{"f":"إِحۡسَٰنًا","r":"نفرفَ","n":"بضم الحاء وسكون السين بلا همز ولا ألف"},{"f":"حُسۡنًا","r":"ادحكاَحَ","n":"بضم الحاء وسكون السين بلا همز ولا ألف"}],"46:15:7":[{"f":"كُرۡهٗا (معا)","r":"ثم حَ","n":"بفتح الكاف"},{"f":"كَرۡهٗا","r":"احاَد ل","n":"بفتح الكاف"}],"46:15:11":[{"f":"وَفِصَٰلُهُ","r":"ادحكنفراَفَ","n":"بفتح الفاء وسكون الصاد"},{"f":"وَفَصۡلُهُ","r":"حَ","n":"بفتح الفاء وسكون الصاد"}],"46:16:3":[{"f":"نَتَقَبَّلُ -أَحۡسَنَ -وَنَتَجَاوَزُ ","r":"عفرفَ","n":"بياء مضمومة ثم رفع أحسن"},{"f":"يُتَقَبَّلُ -أَحۡسَنُ -وَيُتَجَاوَزُ ","r":"ادحكصاَحَ","n":"بياء مضمومة ثم رفع أحسن"},{"f":"نَتَقَبَّلُ -أَحۡسَنَ -وَنَتَجَاوَزُ","r":"عفرفَ"},{"f":"يُتَقَبَّلُ -أَحۡسَنُ -وَيُتَجَاوَزُ","r":"ادحكصاَحَ"}],"46:17:4":[{"f":"أُفّٖ","r":"احنفراَفَ","n":"بفتح الفاء دون تنوين"},{"f":"أُفَّ","r":"دكحَ","n":"بفتح الفاء دون تنوين"},{"f":"أُفِّ","r":"حصفرفَ","n":"بكسر الفاء دون تنوين"}],"46:17:6":[{"f":"أَتَعِدَانِنِيٓ","r":"ادحمنفراَحَفَ","n":"بنون واحدة مشددة على الإدغام فتمد الألف مشبعاً"},{"f":"أَتَعِدَآننِّيٓ","r":"ل","n":"بنون واحدة مشددة على الإدغام فتمد الألف مشبعاً"},{"f":"أَتَعِدَانِنِيَ","r":"اداَ","n":"فتح الياء ونونين"}],"46:19:5":[{"f":"وَلِيُوَفِّيَهُمۡ","r":"ندل ح حَ","n":"بالنون"},{"f":"وَلِنُوَفِّيَهُمۡ","r":"فما راَفَك","n":"بالنون"}]}}