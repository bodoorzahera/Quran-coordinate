{"page":440,"data":{"36:1:1":[{"f":"يسٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"36:2:1":[{"f":"وَٱلۡقُرۡءَانِ ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"وَٱلۡقُرَانِ","r":"دف","n":"بالنقل"},{"f":"وَٱلۡقُرۡءَانِ","r":"احكنراَحَفَ"}],"36:4:2":[{"f":"صِرَٰطٖ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"}],"36:5:1":[{"f":"تَنزِيلَ","r":"فعرفَك","n":"بالرفع"},{"f":"تَنزِيلُ","r":"اداَ صححَ","n":"بالرفع"}],"36:8:6":[{"f":"فَهِيَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡيَ","r":"بحراَ","n":"بسكون الهاء"}],"36:9:5":[{"f":"سَدّٗا","r":"عفرفَ","n":"بضم السين"},{"f":"سُدّٗا","r":"ادحكصاَحَ","n":"بضم السين"}]}}