{"page":55,"data":{"3:38:2":[{"f":"دَعَا زَكَرِيَّا","r":"فعرفَ"},{"f":"دَعَا زَكَرِيَّآءُ","r":"اكداَ صححَ"}],"3:38:3":[{"f":"زَكَرِيَّا","r":"عفرفَ","n":"بهمزة مضمومة بعد الألف"},{"f":"زَكَرِيَّآءُ","r":"ادحكصاَحَ","n":"بهمزة مضمومة بعد الألف"}],"3:39:1":[{"f":"فَنَادَتۡهُ","r":"أكدناَ ح حَ","n":"بألف ممالة بين الدال والهاء"},{"f":"فَنَادَىٰٜهُ","r":"ففَر","n":"بألف ممالة بين الدال والهاء"}],"3:39:3":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}],"3:39:9":[{"f":"أَنَّ ٱللَّهَ","r":"اردفَنا ح حَ","n":"بكسر الهمزة"},{"f":"إِنَّ ٱللَّهَ","r":"فك","n":"بكسر الهمزة"}],"3:39:10":[{"f":"يُبَشِّرك","r":"ادا ح حَ فَكن"},{"f":"يَبْشُرك","r":"فر"}],"3:45:7":[{"f":"يُبَشِّرك","r":"ادا ح حَ فَكن"},{"f":"يَبْشُرك","r":"فر"}]}}