{"page":581,"data":{"77:23:1":[{"f":"فَقَدَرۡنَا","r":"حد فحَنفَك","n":"بتشديد الدال"},{"f":"فَقَدَّرۡنَا","r":"أراَ","n":"بتشديد الدال"}],"77:29:1":[{"f":"ٱنطَلِقُوٓاْ","r":"حد فحَنفَك","n":"بفتح اللام (الكلمة الثانية فقط)"},{"f":"ٱنطَلَقُوٓاْ","r":"طَ","n":"بفتح اللام (الكلمة الثانية فقط)"}],"77:33:2":[{"f":"جِمَٰلَتٞ","r":"فعرفَ","n":"بالجمع"},{"f":"جِمَٰلَٰتٞ","r":"حصايَ دكاَ","n":"بالجمع"},{"f":"جُمَٰلَٰتٞ","r":"طَ","n":"بالجمع مع ضم الجيم"}],"77:41:5":[{"f":"وَعُيُونٖ","r":"احلعاَحَفَ","n":"كسر العين"},{"f":"وَعِيُونٖ","r":"دمصفر","n":"كسر العين"}],"77:48:2":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}]}}