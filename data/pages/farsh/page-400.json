{"page":400,"data":{"29:31:4":[{"f":"إِبۡرَٰهِ‍ۧمَ","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}],"29:32:10":[{"f":"لَنُنَجِّيَنَّهُ","r":"ادحكناَ","n":"بتخفيف الجيم وسكون النون قبلها"},{"f":"لَنُنجِيَنَّهُ","r":"فرحَفَ","n":"بتخفيف الجيم وسكون النون قبلها"}],"29:33:6":[{"f":"سِيٓءَ","r":"دحنفىَفَ","n":"بإشمام كسر السين ضماً"},{"f":"سـ۬يٓءَ","r":"اكراَطَ","n":"بإشمام كسر السين ضماً"}],"29:33:17":[{"f":"مُنَجُّوكَ","r":"احكعاَ","n":"بسكون النون وتخفيف الجيم"},{"f":"مُنجُوكَ","r":"دصفرحَفَ","n":"بسكون النون وتخفيف الجيم"}],"29:34:2":[{"f":"مُنزِلُونَ","r":"ادحنفراَحَفَ","n":"بفتح النون وتشديد الزاي"},{"f":"مُنَزِّلُونَ","r":"ك","n":"بفتح النون وتشديد الزاي"}],"29:38:2":[{"f":"وَثَمُودَاْ","r":"عفحَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"وَثَمُودٗا","r":"ادحكصراَفَ","n":"بالتنوين ويبدل ألف وقفا"}]}}