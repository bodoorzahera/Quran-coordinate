{"page":389,"data":{"28:29:13":[{"f":"لِأَهۡلِهِ ٱمۡكُثُوٓاْ","r":"ادحكنراَحَفَ","n":"بضم الهاء"},{"f":"لِأَهۡلِهُ ٱمۡكُثُوٓاْ","r":"ف","n":"بضم الهاء"}],"28:29:23":[{"f":"جَذۡوَةٖ","r":"ادحكنراَحَ","n":"بضم الجيم"},{"f":"جُذۡوَةٖ","r":"ففَ","n":"بضم الجيم"},{"f":"جِذۡوَةٖ","r":"ادحكراَحَ","n":"بكسر الجيم"}],"28:32:14":[{"f":"ٱلرَّهۡبِ","r":"ادحعاَحَ","n":"بضم الراء وسكون الهاء"},{"f":"ٱلرُّهۡبِ","r":"كصفرفَ","n":"بضم الراء وسكون الهاء"},{"f":"ٱلرَّهَبِ","r":"ادحاَحَ","n":"بفتح الراء والهاء"}],"28:32:15":[{"f":"فَذَٰنِكَ","r":"اكنفراَىَفَ","n":"بتشديد النون فتمد الألف مشبعاً"},{"f":"فَذَٰٓنِّكَ","r":"دحطَ","n":"بتشديد النون فتمد الألف مشبعاً"}],"28:34:9":[{"f":"رِدۡءٗا","r":"دحكنفراَحَفَ","n":"بالنقل والتنوين وصلا"},{"f":"رِدٗا","r":"ا","n":"بالنقل والتنوين وصلا"},{"f":"رِدَا","r":"فاَ","n":"بالنقل بألف دون تنوين"}],"28:34:10":[{"f":"يُصَدِّقُنِيٓ","r":"نف","n":"بسكون القاف"},{"f":"يُصَدِّقۡنِيٓ","r":"ادحكراَحَفَ","n":"بسكون القاف"}]}}