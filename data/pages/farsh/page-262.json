{"page":262,"data":{"15:1:1":[{"f":"الٓر","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"15:1:5":[{"f":"وَقُرۡءَانٖ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"وَقُرَانٖ","r":"د","n":"بالنقل"}],"15:2:1":[{"f":"رُّبَمَا","r":"اناَ","n":"بتشديد الباء"},{"f":"رُّبَّمَا","r":"فح فَحَ كدر","n":"بتشديد الباء"}],"15:8:2":[{"f":"مَا نُنَزِّلُ ٱلۡمَلَٰٓئِكَةَ","r":"فعرفَ","n":"بتاء مضمومة وفتح الزاي ثم الرفع"},{"f":"مَا تُنَزَّلُ ٱلۡمَلَٰٓئِكَةُ","r":"ص","n":"بتاء مضمومة وفتح الزاي ثم الرفع"},{"f":"مَا تَنَزَّلُ ٱلۡمَلَٰٓئِكَةُ","r":"حازاَك حَ","n":"بتاء مفتوحة وفتح الزاي ثم الرفع"},{"f":"مَآ تَّنَزَّلُ ٱلۡمَلَٰٓئِكَةُ","r":"ه","n":"تشديد التاء المفتوحة مع المد المشبع وفتح الزاي والرفع"}],"15:15:3":[{"f":"سُكِّرَتۡ","r":"احكنفراَحَفَ","n":"بتخفيف الكاف"},{"f":"سُكِرَتۡ","r":"د","n":"بتخفيف الكاف"}]}}