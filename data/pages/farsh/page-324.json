{"page":324,"data":{"21:25:8":[{"f":"نُوحِيٓ إِلَيۡهِ","r":"عفرفَ","n":"بياء وفتح الحاء وألف بعدها"},{"f":"يُّوحَيٰ إِلَيۡهِ","r":"ادحكصاَحَ","n":"بياء وفتح الحاء وألف بعدها"}],"21:30:1":[{"f":"أَوَلَمۡ يَرَ","r":"احكنفراَحَفَ","n":"بحذف الواو"},{"f":"أَلَمۡ يَرَ","r":"د","n":"بحذف الواو"}],"21:33:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"21:34:8":[{"f":"مِّتَّ","r":"افعرفَ","n":"بضم الميم"},{"f":"مُّتَّ","r":"كداَ صححَ","n":"بضم الميم"}],"21:35:10":[{"f":"تُرۡجَعُونَ","r":"ادحكنفراَفَ","n":"بفتح التاء وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بفتح التاء وكسر الجيم"}]}}