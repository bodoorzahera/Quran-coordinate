{"page":164,"data":{"7:105:1":[{"f":"حَقِيقٌ عَلَىٰٓ","r":"دحكنفراَحَفَ","n":"بياء مفتوحة مشددة"},{"f":"حَقِيقٌ عَلَيَّ","r":"ا","n":"بياء مفتوحة مشددة"}],"7:112:3":[{"f":"سَٰحِرٍ","r":"أكدناَ ح حَ","n":"بفتح وتشديد الحاء وبعدها الألف"},{"f":"سَحَّٰرٍ","r":"ففَر","n":"بفتح وتشديد الحاء وبعدها الألف"}],"7:113:6":[{"f":"إِنَّ لَنَا","r":"اعاَدل","n":"بالاستفهام (ء همزة قطع - •تسهيل \n- | إدخال - |• إدخال مع تسهيل)"},{"f":"أَءِنَّ لَنَا","r":"فصححَ كفَر","n":"بالاستفهام (ء همزة قطع - •تسهيل \n- | إدخال - |• إدخال مع تسهيل)"}],"7:114:2":[{"f":"نَعَمۡ","r":"ادحكنفاَحَفَ","n":"بكسر العين"},{"f":"نَعِمۡ","r":"ر","n":"بكسر العين"}],"7:117:9":[{"f":"تَلۡقَفُ","r":"ع","n":"بفتح اللام وتشديد القاف"},{"f":"تَلَقَّفُ","r":"زاح كفر فصاَحَ","n":"بفتح اللام وتشديد القاف"},{"f":"تَّلَقَّفُ","r":"ه","n":"بتشديد التاء وصلا بما قبلها مع الفتح والتشديد"}]}}