{"page":403,"data":{"29:55:9":[{"f":"وَيَقُولُ","r":"انفرفَ","n":"بالنون"},{"f":"وَنَقُولُ","r":"دحكاَحَ","n":"بالنون"}],"29:57:7":[{"f":"تُرۡجَعُونَ","r":"ادحكعفراَحَفَ","n":"بالياء"},{"f":"يُرۡجَعُونَ","r":"ص","n":"بالياء"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بفتح التاء وكسر الجيم"}],"29:58:5":[{"f":"لَنُبَوِّئَنَّهُم","r":"ادحكنفرحَفَ","n":"إبدال الهمزة ياء"},{"f":"لَنُبَوِّيَنَّهُم","r":"اَ","n":"إبدال الهمزة ياء"},{"f":"لَنُثۡوِيَنَّهُم","r":"فرفَ","n":"بثاء ساكنة وتخفيف الواو وإبدال الهمزة ياء"}],"29:60:1":[{"f":"وَكَأَيِّن","r":"احكنفراَحَفَ","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآئِن","r":"د","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآىٜن","r":"اَ","n":"بتسهيل الهمزة المكسورة مع مد وقصر"},{"f":"وَكَأَيّنْ","r":"ححَ","n":"الوقوف على الياء"},{"f":"وَكَا۬يِّن","r":"ف","n":"الوقوف بتسهيل الهمزة المفتوحة وبعدها ياء"}],"29:60:10":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}