{"page":381,"data":{"27:45:8":[{"f":"أَنِ ٱعۡبُدُواْ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱعۡبُدُواْ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}],"27:49:4":[{"f":"لَنُبَيِّتَنَّهُ","r":"ادحكناَحَ","n":"بتاء مضارعة وضم الأخرى"},{"f":"لَتُبَيِّتُنَّهُ","r":"فرفَ","n":"بتاء مضارعة وضم الأخرى"}],"27:49:7":[{"f":"لَنَقُولَنَّ","r":"ادحكناَحَ","n":"بتاء مضارعة وضم اللام الثانية"},{"f":"لَتَقُولُنَّ","r":"فرفَ","n":"بتاء مضارعة وضم اللام الثانية"}],"27:49:11":[{"f":"مَهۡلِكَ","r":"ن","n":"بضم الميم وفتح اللام"},{"f":"مَهۡلَكَ","r":"ص","n":"بفتح الميم واللام"},{"f":"مُهۡلَكَ","r":"ادحكفراَحَفَ","n":"بضم الميم وفتح اللام"}],"27:51:6":[{"f":"أَنَّا","r":"ثحَ","n":"بكسر الهمزة"},{"f":"إِنَّا","r":"ادحكاَ","n":"بكسر الهمزة"}],"27:52:2":[{"f":"بُيُوتُهُمۡ","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"بِيُوتُهُمۡ","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}]}}