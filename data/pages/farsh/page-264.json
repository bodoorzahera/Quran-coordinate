{"page":264,"data":{"15:40:4":[{"f":"ٱلۡمُخۡلَصِينَ","r":"اثاَ","n":"بكسر اللام"},{"f":"ٱلۡمُخۡلِصِينَ","r":"كد ح حَ","n":"بكسر اللام"}],"15:41:3":[{"f":"صِرَٰطٌ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطٌ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٌ","r":"ض","n":"بإشمام الصاد زاياً"}],"15:41:4":[{"f":"عَلَيَّ","r":"ادحكنفراَفَ","n":"بكسر اللام ورفع وتنوين الياء"},{"f":"عَلِيّٞ","r":"حَ","n":"بكسر اللام ورفع وتنوين الياء"}],"15:44:7":[{"f":"جُزۡءٞ","r":"ادحكعفراَحَفَ","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزُءٞ","r":"ص","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزّٞ","r":"اَ","n":"تشديد الزاي دون همز"},{"f":"جُزُ","r":"لف","n":"الوقف بنقل مع سكون وإشمام وروم"}],"15:45:5":[{"f":"وَعُيُونٍ","r":"ح حَ الاَعفَ","n":"كسر العين"},{"f":"وَعِيُونٍ","r":"صف رمد","n":"كسر العين"}]}}