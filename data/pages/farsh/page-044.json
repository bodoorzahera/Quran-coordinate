{"page":44,"data":{"2:260:3":[{"f":"إِبۡرَٰهِ‍ۧمَ","r":"ادحنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"لمً","n":"بفتح الهاء وألف بعدها"}],"2:260:5":[{"f":"أَرِنِي","r":"ادىكنفراَحَفَ","n":"بسكون الراء"},{"f":"أَرۡنِي","r":"يد حَ","n":"بسكون الراء"},{"f":"أَرٜنِي","r":"ط","n":"اختلاس كسر الراء"}],"2:260:22":[{"f":"فَصُرۡهُنَّ","r":"احيَكن رد","n":"بكسر الصاد"},{"f":"فَصِرۡهُنَّ","r":"فطَاَفَ","n":"بكسر الصاد"}],"2:260:30":[{"f":"جُزۡءٗا","r":"أحدك ففَرحَ ع","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزُءٗا","r":"ص","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزّٗا","r":"اَ","n":"تشديد الزاي دون همز"},{"f":"جُزَا","r":"ف","n":"الإبدال"}],"2:261:19":[{"f":"يُضَٰعِفُ","r":"احث","n":"تشديد العين وحذف الألف"},{"f":"يُضَعِّفُ","r":"كدحَاَ","n":"تشديد العين وحذف الألف"}],"2:262:20":[{"f":"خَوۡفٌ ","r":"ادحكنفراَفَ","n":"بفتح الفاء دون تنوين"},{"f":"خَوۡفَ","r":"حَ","n":"بفتح الفاء دون تنوين"},{"f":"خَوۡفٌ","r":"ادحكنفراَفَ"}]}}