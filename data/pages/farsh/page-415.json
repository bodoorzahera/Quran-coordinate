{"page":415,"data":{"32:1:1":[{"f":"الٓمٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"32:2:3":[{"f":"أَلِفۡۜ لَآمۡۜ مِيٓمۡۜ","r":"اَ","n":"بالسكت على حروف التهجي"}],"32:7:5":[{"f":"خَلَقَهُ","r":"اثر","n":"بسكون اللام"},{"f":"خَلۡقَهُ","r":"كدا ح حَ","n":"بسكون اللام"}],"32:10:2":[{"f":"أَءِذَا","r":"ادحنفرحَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِذَا","r":"كاَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"32:10:6":[{"f":"أَءِنَّا","r":"دحكنفاَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِنَّا","r":"ارحَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"32:11:11":[{"f":"تُرۡجَعُونَ","r":"ادحكنفراَفَ","n":"بفتح التاء وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بفتح التاء وكسر الجيم"}]}}