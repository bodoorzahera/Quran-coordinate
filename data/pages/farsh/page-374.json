{"page":374,"data":{"26:175:3":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"26:176:3":[{"f":"لۡـَٔيۡكَةِ","r":"حنفرحَفَ","n":"بفتح اللام والتاء دون همز قبل اللام وبعدها"},{"f":"لَيۡكَةَ","r":"ادكاَ","n":"بفتح اللام والتاء دون همز قبل اللام وبعدها"}],"26:182:2":[{"f":"بِٱلۡقِسۡطَاسِ","r":"عفرفَ","n":"بضم القاف"},{"f":"بِٱلۡقُسۡطَاسِ","r":"ادحكصاَحَ","n":"بضم القاف"}]}}