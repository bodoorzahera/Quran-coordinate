{"page":236,"data":{"12:5:2":[{"f":"يَٰبُنَيَّ","r":"ع","n":"بكسر الياء"},{"f":"يَٰبُنَيِّ","r":"ادحكصفراَحَفَ","n":"بكسر الياء"}],"12:7:6":[{"f":"ءَايَٰتٞ","r":"احكنفراَحَفَ","n":"بالتوحيد"},{"f":"ءَايَتٞ","r":"د","n":"بالتوحيد"}],"12:10:9":[{"f":"غَيَٰبَتِ","r":"دحكنفرحَفَ","n":"بألف الجمع قبل التاء"},{"f":"غَيَٰبَٰتِ","r":"ااَ","n":"بألف الجمع قبل التاء"}],"12:11:6":[{"f":"تَأۡمَ۬نَّا","r":"ادحكنفرحَفَ","n":"بإدغام النون في النون محضاً دون إشمام أو اختلاس"},{"f":"تَأۡمَنَّا","r":"اَ","n":"بإدغام النون في النون محضاً دون إشمام أو اختلاس"}],"12:12:4":[{"f":"يَرۡتَعۡ وَيَلۡعَبۡ","r":"ثحَ","n":"بالياء مع كسر العين الأولى"},{"f":"يَرۡتَعِ وَيَلۡعَبۡ","r":"ااَ","n":"بالياء مع كسر العين الأولى"},{"f":"نَرۡتَعِ وَنَلۡعَبۡ","r":"د","n":"بالنون مع كسر العين الأولى"},{"f":"نَرۡتَعۡ وَنَلۡعَبۡ","r":"حك","n":"بالنون مع سكون العين الأولى"}],"12:13:3":[{"f":"لَيَحۡزُنُنِيٓ","r":"دحكنفراَحَفَ","n":"بضم الياء وكسر الزاي وفتح ياء الإضافة"},{"f":"لَيُحۡزِنُنِيَ","r":"ا","n":"بضم الياء وكسر الزاي وفتح ياء الإضافة"},{"f":"لَيَحۡزُنُنِيَ","r":"داَ","n":"بفتح الياء وضم الزاي وفتح ياء الإضافة"}]}}