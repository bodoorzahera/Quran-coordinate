{"page":295,"data":{"18:16:19":[{"f":"مِّرۡفَقٗا","r":"دحنفرحَفَ","n":"بفتح الميم وكسر الفاء"},{"f":"مَّرۡفِقٗا","r":"اكاَ","n":"بفتح الميم وكسر الفاء"}],"18:17:5":[{"f":"تَّزَٰوَرُ","r":"ادحنفراَفَ","n":"بسكون الزاي وتشديد الراء دون ألف"},{"f":"تَّزۡوَرُّ","r":"كحَ","n":"بسكون الزاي وتشديد الراء دون ألف"},{"f":"تَّزَّٰوَرُ","r":"ادحاَ","n":"بفتح وتشديد الزاي وألف بعدها"}],"18:17:26":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"18:18:1":[{"f":"وَتَحۡسَبُهُمۡ","r":"كنفاَ","n":"كسر السين"},{"f":"وَتَحۡسِبُهُمۡ","r":"ادحرحَفَ","n":"كسر السين"}],"18:18:20":[{"f":"وَلَمُلِئۡتَ","r":"كغ","n":"بتشديد اللام"},{"f":"وَلَمُلِّئۡتَ","r":"اد","n":"بتشديد اللام"},{"f":"وَلَمُلِّيتَ","r":"اَ","n":"بتشديد اللام وإبدال الهمزة ياء"},{"f":"وَلَمُلِيتَ","r":"ىف","n":"إبدال الهمزة ياء"}],"18:18:22":[{"f":"رُعۡبٗا","r":"ادحنففَ","n":"بضم العين"},{"f":"رُعُبٗا","r":"كراَحَ","n":"بضم العين"}],"18:19:23":[{"f":"بِوَرِقِكُمۡ","r":"اعطَاَك در","n":"بسكون الراء"},{"f":"بِوَرۡقِكُمۡ","r":"حىَ فصفَ","n":"بسكون الراء"}]}}