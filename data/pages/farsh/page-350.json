{"page":350,"data":{"24:1:3":[{"f":"وَفَرَضۡنَٰهَا","r":"اكنفراَحَفَ","n":"بتشديد الراء"},{"f":"وَفَرَّضۡنَٰهَا","r":"دح","n":"بتشديد الراء"}],"24:1:9":[{"f":"تَذَكَّرُونَ","r":"عفرفَ","n":"تشديد الذال"},{"f":"تَذَّكَّرُونَ","r":"ادحكصاَحَ","n":"تشديد الذال"}],"24:2:12":[{"f":"رَأۡفَةٞ","r":"احكنفراَحَفَ","n":"بفتح الهمزة"},{"f":"رَأَفَةٞ","r":"د","n":"بفتح الهمزة"},{"f":"رَافَةٞ","r":"ىفاَ","n":"بالإبدال"}],"24:4:3":[{"f":"ٱلۡمُحۡصَنَٰتِ","r":"ادحكنفاَحَفَ","n":"بكسر الصاد"},{"f":"ٱلۡمُحۡصِنَٰتِ","r":"ر","n":"بكسر الصاد"}],"24:6:12":[{"f":"أَرۡبَعُ","r":"عفرفَ","n":"بالنصب"},{"f":"أَرۡبَعَ","r":"ادحكصاَحَ","n":"بالنصب"}],"24:7:3":[{"f":"أَنَّ لَعۡنَتَ","r":"دحكنفراَفَ","n":"بسكون النون ثم الرفع"},{"f":"أَن لَّعۡنَتُ","r":"احَ","n":"بسكون النون ثم الرفع"}],"24:9:1":[{"f":"وَٱلۡخَٰمِسَةَ","r":"ع","n":"بالرفع"},{"f":"وَٱلۡخَٰمِسَةُ","r":"ادحكصفراَحَفَ","n":"بالرفع"}],"24:9:3":[{"f":"أَنَّ غَضَبَ ٱللَّهِ","r":"دحكنفراَحَفَ","n":"بسكون النون وكسرالضاد وفتح الباء وضم الهاء"},{"f":"أَنۡ غَضِبَ ٱللَّهُ","r":"ا","n":"بسكون النون وكسرالضاد وفتح الباء وضم الهاء"},{"f":"أنۡ غَضَبُ اللهِ","r":"حَ","n":"بسكون النون وفتح الضاد وضم الباء وكسر الهاء"}]}}