{"page":255,"data":{"14:1:1":[{"f":"الٓر","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"14:1:14":[{"f":"صِرَٰطِ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطِ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطِ","r":"ض","n":"بإشمام الصاد زاياً"}],"14:2:1":[{"f":"ٱللَّهِ","r":"حديَث","n":"بالرفع"},{"f":"ٱللَّهُ","r":"اكاَطَ","n":"بالرفع"}],"14:4:17":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}