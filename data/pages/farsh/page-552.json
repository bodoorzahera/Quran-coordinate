{"page":552,"data":{"61:6:30":[{"f":"سِحۡرٞ","r":"ادحكناَحَ","n":"بفتح السين وكسر الحاء وألف بينهما"},{"f":"سَٰحِرٞ","r":"فرفَ","n":"بفتح السين وكسر الحاء وألف بينهما"}],"61:7:8":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"61:8:7":[{"f":"مُتِمُّ نُورِهِ","r":"در فعفَ","n":"بتنوين الميم وفتح الراء"},{"f":"مُتِمّٞ نُورَهِ","r":"اصحاَحَك","n":"بتنوين الميم وفتح الراء"}],"61:10:8":[{"f":"تُنجِيكُم","r":"ادحنفراَحَفَ","n":"بتشديد الجيم وفتح النون"},{"f":"تُنَجِّيكُم","r":"ك","n":"بتشديد الجيم وفتح النون"}],"61:13:5":[{"f":"أَنصَارَ ٱللَّهِ","r":"ذحَ","n":"بتنوين الراء ولام الجر للفظ الجلالة"}],"61:14:5":[{"f":"أَنصَارٗا لِلَّهِ","r":"احداَ","n":"بتنوين الراء ولام الجر للفظ الجلالة"}]}}