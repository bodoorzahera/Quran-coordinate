{"page":337,"data":{"22:39:1":[{"f":"أُذِنَ","r":"حان حَاَ","n":"بفتح الهمزة"},{"f":"أَذِنَ","r":"دك ففَر","n":"بفتح الهمزة"}],"22:39:3":[{"f":"يُقَٰتَلُونَ","r":"اعكاَ","n":"بكسر التاء"},{"f":"يُقَٰتِلُونَ","r":"حصد ففَرحَ","n":"بكسر التاء"}],"22:40:13":[{"f":"دَفۡعُ","r":"حظك","n":"بكسر الدال وفتح الفاء وألف بعدها"},{"f":"دِفَـٰعُ","r":"ااَحَ","n":"بكسر الدال وفتح الفاء وألف بعدها"}],"22:40:18":[{"f":"لَّهُدِّمَتۡ","r":"كغ","n":"بتخفيف الدال"},{"f":"لَّهُدِمَتۡ","r":"اداَ","n":"بتخفيف الدال"}],"22:45:1":[{"f":"فَكَأَيِّن","r":"احكنفراَحَفَ","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"فَكَآئِن","r":"د","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"فَكَآىٜن","r":"اَ","n":"بتسهيل الهمزة المكسورة مع مد وقصر"},{"f":"فَكَأَيّنْ","r":"ححَ","n":"الوقوف على الياء"},{"f":"فَكَا۬يِّن","r":"ف","n":"الوقوف بتسهيل الهمزة المفتوحة وبعدها ياء"}],"22:45:4":[{"f":"أَهۡلَكۡنَٰهَا ","r":"ادكنفراَفَ","n":"بتاء فاعل مضمومة"},{"f":"أَهۡلَكۡتُهَا ","r":"ححَ","n":"بتاء فاعل مضمومة"},{"f":"أَهۡلَكۡنَٰهَا","r":"اذاَد"},{"f":"أَهۡلَكۡتُهَا","r":"ح حَ"}],"22:45:5":[{"f":"وَهِيَ -فَهِيَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡيَ -فَهۡيَ","r":"بحراَ","n":"بسكون الهاء"}],"22:45:11":[{"f":"بئْر","r":""},{"f":"بير","r":"جياَ"}]}}