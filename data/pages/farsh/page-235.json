{"page":235,"data":{"11:121:7":[{"f":"مَكَانَتِكُمۡ","r":"ادحكعفراَحَفَ","n":"بمد النون بألف الجمع قبل التاء"},{"f":"مَكَانَـٰتِكُمۡ","r":"ص","n":"بمد النون بألف الجمع قبل التاء"}],"11:123:6":[{"f":"يُرۡجَعُ","r":"اع","n":"بفتح الياء وكسر الجيم"},{"f":"يَرۡجِعُ","r":"حصاَدك ففَرحَ","n":"بفتح الياء وكسر الجيم"}],"11:123:16":[{"f":"تَعۡمَلُونَ","r":"اع حكاَ","n":"بالغيب"},{"f":"يَعۡمَلُونَ","r":"حصد ففَر","n":"بالغيب"}],"12:1:1":[{"f":"الٓر","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"12:4:5":[{"f":"يَٰٓأَبَتَ","r":"كاَ"},{"f":"يَٰٓأَبَتِ","r":"احكنفراَفَ","n":"كسر التاء والوقوف بالهاء"}],"12:4:8":[{"f":"أَحَدَ عَشَرَ","r":"ادحكنفرحَفَ","n":"بإسكان العين"},{"f":"أَحَدَ عۡشَرَ","r":"اَ","n":"بإسكان العين"}]}}