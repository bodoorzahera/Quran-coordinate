{"page":134,"data":{"6:54:14":[{"f":"أَنَّهُ -فَأَنَّهُ","r":"اكناَحَ","n":"بفتح الألف الأولى وكسر الثانية"},{"f":"أَنَّهُ -فَإِنَّهُ","r":"ااَ","n":"بفتح الألف الأولى وكسر الثانية"},{"f":"إِنَّهُ -فَإِنَّهُ","r":"حد ففَر","n":"بكسرالألف فيهما"}],"6:55:4":[{"f":"وَلِتَسۡتَبِينَ سَبِيلُ","r":"اعاَك ح حَ","n":"بالتاء مع نصب"},{"f":"وَلِتَسۡتَبِينَ سَبِيلَ","r":"ااَ","n":"بالتاء مع نصب"}],"6:55:5":[{"f":"وَلِيَسۡتَبِينَ سَبِيلُ","r":"فصرفَ","n":"بالياء مع رفع"},{"f":"سبيلُ","r":"غدك"},{"f":"سبيلَ","r":"ااَ"}],"6:57:18":[{"f":"يَقُصُّ","r":"اداَن","n":"بسكون القاف وضاد مكسورة مخففة"}],"6:57:20":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}]}}