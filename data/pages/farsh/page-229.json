{"page":229,"data":{"11:66:13":[{"f":"يَوۡمِئِذٍ","r":"فنفَحك حَد","n":"بفتح الميم"},{"f":"يَوۡمَئِذٍ","r":"أراَد","n":"بفتح الميم"}],"11:68:7":[{"f":"ثَمُودَاْ","r":"عفَ حَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"ثَمُودٗا","r":"احاَدك صرفَ","n":"بالتنوين ويبدل ألف وقفا"}],"11:68:12":[{"f":"لِّثَمُودَ","r":"ادحكنفاَحَفَ","n":"بكسر وتنوين الدال"},{"f":"لِّثَمُودٖ","r":"ر","n":"بكسر وتنوين الدال"}],"11:69:3":[{"f":"رُسُلُنَا","r":"ادكنفراَحَفَ","n":"بإسكان السين"},{"f":"رُسۡلُنَا","r":"ح","n":"بإسكان السين"}],"11:69:8":[{"f":"قَالَ سَلَٰمٞ","r":"ادحكناَحَفَ","n":"بكسر السين وسكون اللام"},{"f":"قَالَ سِلۡمٞ","r":"فر","n":"بكسر السين وسكون اللام"}],"11:71:9":[{"f":"يَعۡقُوبَ","r":"عفك","n":"بالرفع"},{"f":"يَعۡقُوبُ","r":"ارد حَ صفحَا","n":"بالرفع"}]}}