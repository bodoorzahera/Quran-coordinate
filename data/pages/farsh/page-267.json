{"page":267,"data":{"15:91:3":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"د","n":"بالنقل"}],"15:94:1":[{"f":"فَٱصۡدَعۡ","r":"ادحكناَىَ","n":"بإشمام الصاد زياً"},{"f":"فَٱصۡـؗدَعۡ","r":"فرطَفَ","n":"بإشمام الصاد زياً"}],"16:2:1":[{"f":"يُنَزِّلُ ٱلۡمَلَٰٓئِكَةَ","r":"اذاَ","n":"بتاء مفتوحة وفتح النون والزاي مشددة ثم رفع"},{"f":"تَنَزَّلُ ٱلۡمَلَٰٓئِكَةُ","r":"يَ","n":"بتاء مفتوحة وفتح النون والزاي مشددة ثم رفع"},{"f":"يُنزِلُ ٱلۡمَلَٰٓئِكَةَ","r":"حد طَ","n":"بياء مضمومة ونون ساكنة وكسر وتخفيف الزاي ونصب"}]}}