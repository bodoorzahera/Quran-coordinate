{"page":585,"data":{"80:4:3":[{"f":"فَتَنفَعَهُ","r":"ن","n":"بضم العين"},{"f":"فَتَنفَعُهُ","r":"ادحكفراَحَفَ","n":"بضم العين"}],"80:6:3":[{"f":"تَصَدَّىٰ","r":"كغ","n":"بتشديد الصاد"},{"f":"تَصَّدَّىٰ","r":"اداَ","n":"بتشديد الصاد"}],"80:9:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"80:10:2":[{"f":"عَنۡهُ تَلَهَّىٰ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء فتمد صلة الهاء مشبعاً وصلاً"},{"f":"عَنۡهُۥٓ تَّلَهَّىٰ","r":"ه","n":"بتشديد التاء فتمد صلة الهاء مشبعاً وصلاً"}],"80:25:1":[{"f":"أَنَّا صَبَبۡنَا","r":"نفرفَ","n":"بكسر الهمزة (ورويس ابتداءاً فقط)"},{"f":"إِنَّا صَبَبۡنَا","r":"ادحكاَحَ","n":"بكسر الهمزة (ورويس ابتداءاً فقط)"}]}}