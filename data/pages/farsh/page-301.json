{"page":301,"data":{"18:63:2":[{"f":"أَرَءَيۡتَ","r":"ادحكنفاَحَفَ","n":"بحذف الهمزة الثانية"},{"f":"أَرَيۡتَ","r":"ر","n":"بحذف الهمزة الثانية"},{"f":"أَرَٰ۬يۡتَ","r":"افاَ","n":"بالتسهيل"}],"18:63:11":[{"f":"أَنسَىٰنِيهُ","r":"ع","n":"بكسر الهاء (والصلة لابن كثير)"},{"f":"أَنسَىٰنِيهِ","r":"ادحكصفراَحَفَ","n":"بكسر الهاء (والصلة لابن كثير)"}],"18:66:11":[{"f":"رُشۡدٗا","r":"ادكنفراَفَ","n":"بفتح الراء والشين"},{"f":"رَشَدٗا","r":"ححَ","n":"بفتح الراء والشين"}],"18:70:5":[{"f":"تَسۡـَٔلۡنِي","r":"غد","n":"بفتح اللام وتشديد النون"},{"f":"تَسۡـَٔلَنِّي","r":"اكاَد م⁴","n":"بفتح اللام وتشديد النون"},{"f":"تَسۡـَٔلَنِّيْ","r":"م","n":"له حذف الياء"},{"f":"تَسۡـَٔلَنِّْ( اثبات الياء/ وحذفها) (وصلا ووقفا)","r":"م⁴"}],"18:71:10":[{"f":"لِتُغۡرِقَ أَهۡلَهَا ","r":"ادحكناَحَ","n":"بياء مفتوحة وفتح الراء ورفع اللام"},{"f":"لِتُغۡرِقَ أَهۡلَهَا","r":"ادحكناَحَ"}],"18:71:11":[{"f":"لِيَغۡرَقَ أَهۡلُهَا","r":"فرفَ","n":"بياء مفتوحة وفتح الراء ورفع اللام"}],"18:73:10":[{"f":"عُسۡرٗا","r":"ادحكنفرحَفَ","n":"بضم السين"},{"f":"عُسُرٗا","r":"اَ","n":"بضم السين"}],"18:74:10":[{"f":"زَكِيَّةَۢ","r":"ذيَ","n":"بألف قبل الكاف مع تخفيف الياء"},{"f":"زَٰكِيَةَۢ","r":"احاَطَ د","n":"بألف قبل الكاف مع تخفيف الياء"}],"18:74:16":[{"f":"نُّكۡرٗا","r":"حرف فَعدل","n":"بضم الكاف"},{"f":"نُّكُرٗا","r":"ما صاَحَ","n":"بضم الكاف"}]}}