{"page":203,"data":{"9:100:5":[{"f":"وَٱلۡأَنصَارِ","r":"ادحكنفراَفَ","n":"بالرفع"},{"f":"وَٱلۡأَنصَارُ","r":"حَ","n":"بالرفع"}],"9:100:17":[{"f":"تَجۡرِي تَحۡتَهَا","r":"احكنفراَحَفَ","n":"بزيادة (من) والجر"},{"f":"تَجۡرِي مِن تَحۡتِهَا","r":"د","n":"بزيادة (من) والجر"}],"9:103:11":[{"f":"صَلَوٰتَكَ","r":"عفرفَ","n":"بواو مفتوحة قبل الألف مع كسر التاء"},{"f":"صَلَوَٰتِكَ","r":"ادحكصاَحَ","n":"بواو مفتوحة قبل الألف مع كسر التاء"}],"9:106:2":[{"f":"مُرۡجَوۡنَ","r":"اعفراَفَ","n":"بهمزة مضمومة قبل الواو"},{"f":"مُرۡجَـُٔونَ","r":"دحكصحَ","n":"بهمزة مضمومة قبل الواو"}]}}