{"page":315,"data":{"20:53:5":[{"f":"مَهۡدٗا","r":"نفرفَ","n":"بكسر الميم وفتح الهاء وألف بعدها"},{"f":"مِهَٰدٗا","r":"ادحكاَحَ","n":"بكسر الميم وفتح الهاء وألف بعدها"}],"20:58:9":[{"f":"نُخۡلِفُهُ","r":"ادحكنفرحَفَ","n":"بسكون الفاء"},{"f":"نُخۡلِفۡهُ","r":"اَ","n":"بسكون الفاء"}],"20:58:14":[{"f":"سُوٗى","r":"كنفحَفَ","n":"بكسر السين"},{"f":"سِوٗى","r":"حد أراَ","n":"بكسر السين"}],"20:61:10":[{"f":"فَيُسۡحِتَكُم","r":"فطَر فَع","n":"بفتح الياء والحاء"},{"f":"فَيَسۡحَتَكُم","r":"حصد اياَك","n":"بفتح الياء والحاء"}],"20:63:2":[{"f":"إِنۡ","r":"دع","n":"بفتح وتشديد النون"},{"f":"إِنَّ","r":"صحف افَراحَك","n":"بفتح وتشديد النون"}],"20:63:3":[{"f":"هَٰذَٰنِ","r":"اذاَحَ","n":"بتشديد النون مع مد الألف مشبعا"},{"f":"هَٰذَٰٓنِّ","r":"د","n":"بتشديد النون مع مد الألف مشبعا"},{"f":"هَٰذَۦۡنِ","r":"ح","n":"بالياء"}],"20:64:1":[{"f":"فَأَجۡمِعُواْ","r":"ادكنفراَحَفَ","n":"بهمزة وصل وفتح الميم"},{"f":"فَٱجۡمَعُواْ","r":"ح","n":"بهمزة وصل وفتح الميم"}]}}