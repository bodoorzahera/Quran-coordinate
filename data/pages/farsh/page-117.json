{"page":117,"data":{"5:53:1":[{"f":"وَيَقُولُ","r":"ث","n":"بإثبات الواو والنصب"},{"f":"وَيَقُولَ","r":"ح حَ","n":"بإثبات الواو والنصب"},{"f":"يَقُولُ","r":"اكاَد","n":"بحذف الواو والرفع"}],"5:54:5":[{"f":"يَرۡتَدَّ","r":"غد","n":"بدالين الأولى مكسورة والثانية ساكنة"},{"f":"يَرۡتَدِدۡ","r":"اكاَ","n":"بدالين الأولى مكسورة والثانية ساكنة"}],"5:57:9":[{"f":"هُزُوٗا","r":"ادحكنراَحَفَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"5:57:17":[{"f":"وَٱلۡكُفَّارَ","r":"أداَن فكفَ","n":"بالخفض"},{"f":"وَٱلۡكُفَّارِ","r":"رححَ","n":"بالخفض"}]}}