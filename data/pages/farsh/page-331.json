{"page":331,"data":{"21:103:2":[{"f":"يَحۡزُنُهُمُ","r":"ادحكنفرحَفَ","n":"بضم الياء وكسر الزاي"},{"f":"يُحۡزِنُهُمُ","r":"اَ","n":"بضم الياء وكسر الزاي"}],"21:104:2":[{"f":"نَطۡوِي ٱلسَّمَآءَ","r":"ادحكنفرحَفَ","n":"بتاء مضمومة وفتح الواو وألف بعدها ورفع الهمزة"},{"f":"تُطۡوَيٰ ٱلسَّمَآءُ","r":"اَ","n":"بتاء مضمومة وفتح الواو وألف بعدها ورفع الهمزة"}],"21:104:6":[{"f":"لِلۡكُتُبِ","r":"عفرفَ","n":"بالإفراد"},{"f":"لِلۡكِتَـٰبِ","r":"ادحكصاَحَ","n":"بالإفراد"}],"21:105:4":[{"f":"ٱلزَّبُورِ","r":"ادحكنراَحَ","n":"بضم الزاي"},{"f":"ٱلزُّبُورِ","r":"ففَ","n":"بضم الزاي"}],"21:112:1":[{"f":"قَٰلَ رَبِّ","r":"ع","n":"بضم القاف وسكون اللام و الإدغام مع الراء (كامل وناقص)"},{"f":"قُل رَّبّ","r":"ادحكصفراَحَفَ","n":"بضم القاف وسكون اللام و الإدغام مع الراء (كامل وناقص)"}],"21:112:2":[{"f":"رَبِّ","r":"ادحكنفرحَفَ","n":"بضم الباء"},{"f":"رَّبُّ","r":"اَ","n":"بضم الباء"}]}}