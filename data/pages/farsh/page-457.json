{"page":457,"data":{"38:63:1":[{"f":"أَتَّخَذۡنَٰهُمۡ","r":"ادكناَ","n":"بوصل الهمزة وكسرها ابتداءًا"},{"f":"ٱتَّخَذۡنَٰهُمۡ","r":"حفرحَفَ","n":"بوصل الهمزة وكسرها ابتداءًا"}],"38:63:2":[{"f":"سِخۡرِيًّا","r":"نكد ح حَ","n":"بضم السين"},{"f":"سُخۡرِيًّا","r":"افراَفَ","n":"بضم السين"}],"38:70:5":[{"f":"أَنَّمَآ","r":"ادحكنفرحَفَ","n":"بكسر الهمزة"},{"f":"إِنَّمَآ","r":"اَ","n":"بكسر الهمزة"}],"38:83:4":[{"f":"ٱلۡمُخۡلَصِينَ","r":"انفراَفَ","n":"بكسر اللام"},{"f":"ٱلۡمُخۡلِصِينَ","r":"دحكحَ","n":"بكسر اللام"}]}}