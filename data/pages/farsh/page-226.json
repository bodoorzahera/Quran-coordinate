{"page":226,"data":{"11:40:10":[{"f":"مِن كُلّٖ","r":"ع","n":"بغير تنوين"},{"f":"مِن كُلِّ","r":"ادحكصفراَحَفَ","n":"بغير تنوين"}],"11:41:6":[{"f":"مَجۡرٜىٰهَا","r":"فعرفَ","n":"بضم الميم (مع التقليل والإمالة)"},{"f":"مُجۡرٜىٰهَا","r":"ج ح","n":"بضم الميم (مع التقليل والإمالة)"},{"f":"مُجۡرَىٰهَا","r":"بك اَحصد","n":"بضم الميم وألف بعد الراء"}],"11:42:1":[{"f":"وَهِيَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡيَ","r":"بحراَ","n":"بسكون الهاء"}],"11:42:13":[{"f":"يَٰبُنَيَّ","r":"ن","n":"بكسر ياء الإضافة"},{"f":"يَٰبُنَيِّ","r":"ادحكفراَحَفَ","n":"بكسر ياء الإضافة"}],"11:44:1":[{"f":"وَقِيلَ(معا) -وَغِيضَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف والغين ضماً"},{"f":"وَقـ۬يلَ -وَغـ۬يضَ","r":"لرطَ","n":"بإشمام كسر القاف والغين ضماً"}]}}