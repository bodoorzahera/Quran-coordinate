{"page":528,"data":{"53:47:3":[{"f":"ٱلنَّشۡأَةَ","r":"اكنفراَحَفَ","n":"بفتح الشين ومد على المتصل"},{"f":"ٱلنَّشَآءَةَ","r":"دح","n":"بفتح الشين ومد على المتصل"}],"53:50:3":[{"f":"عَادًا ٱلۡأُولَىٰ","r":"دذ","n":"بنقل حركة الهمزة مع إدغام التنوين"},{"f":"عَادٗا ٱلُّاوليٰ","r":"جحاَحَ","n":"بنقل حركة الهمزة مع إدغام التنوين"},{"f":"عَادٗا ٱلُّاؤۡليٰ","r":"ب","n":"بنقل حركة الهمزة مع إدغام التنوين وهمز الواو"}],"53:51:1":[{"f":"وَثَمُودَاْ","r":"نفحَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"وَثَمُودٗا","r":"احد راَفَك","n":"بالتنوين ويبدل ألف وقفا"}],"53:55:4":[{"f":"تَتَمَارَىٰ","r":"ادحكنفراَفَ","n":"بإدغام التاء في التاء وصلا فقط"},{"f":"تتَّمَارَىٰ","r":"حَ","n":"بإدغام التاء في التاء وصلا فقط"}],"54:3:6":[{"f":"مُّسۡتَقِرّٞ","r":"ادحكنفرحَفَ","n":"بالخفض"},{"f":"مُّسۡتَقِرّٖ","r":"اَ","n":"بالخفض"}],"54:6:8":[{"f":"نُّكُرٍ","r":"احكنفراَحَفَ","n":"بسكون الكاف"},{"f":"نُّكۡرٍ","r":"د","n":"بسكون الكاف"}]}}