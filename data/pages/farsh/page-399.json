{"page":399,"data":{"29:25:8":[{"f":"مَّوَدَّةَ بَيۡنِكُمۡ","r":"اكنفاَىَفَ","n":"بضم التاء وكسر النون"},{"f":"مَّوَدَّةُ بَيۡنِكُمۡ","r":"دحرطَ","n":"بضم التاء وكسر النون"},{"f":"مَّوَدَّةَۢ بَيۡنَكُمۡ","r":"اكصاَفَ","n":"بفتح وتنوين التاء وفتح النون"}],"29:27:8":[{"f":"ٱلنُّبُوَّةَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"النُّبُوٓءَةَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"29:28:5":[{"f":"إِنَّكُمۡ","r":"ادكعاَحَ","n":"بالاستفهام (ء همزة قطع - •تسهيل \n- | إدخال - |• إدخال مع تسهيل)"},{"f":"أَءِنَّكُمۡ","r":"حصفرفَ","n":"بالاستفهام (ء همزة قطع - •تسهيل \n- | إدخال - |• إدخال مع تسهيل)"}]}}