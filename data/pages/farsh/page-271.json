{"page":271,"data":{"16:36:8":[{"f":"أَنِ ٱعۡبُدُواْ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱعۡبُدُواْ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}],"16:37:8":[{"f":"يَهۡدِي","r":"نفرفَ","n":"بضم الياء وفتح الدال وألف بعدها"},{"f":"يُهۡدَىٰ","r":"ادحكاَحَ","n":"بضم الياء وفتح الدال وألف بعدها"}],"16:40:10":[{"f":"فَيَكُونُ","r":"حدناَ ففَاَح","n":"بفتح النون"},{"f":"فَيَكُونَ","r":"كر","n":"بفتح النون"}]}}