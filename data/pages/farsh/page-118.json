{"page":118,"data":{"5:58:6":[{"f":"هُزُوٗا","r":"ادحكنراَحَفَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو \nأو حذفها ونقل حركتها للزاي"}],"5:60:19":[{"f":"وَعَبَدَ ٱلطَّٰغُوتَ","r":"ادحكنراَحَفَ","n":"بضم الباء وكسر التاء"},{"f":"وَعَبُدَ ٱلطَّٰغُوتِ","r":"ف","n":"بضم الباء وكسر التاء"}],"5:62:9":[{"f":"السحْت","r":""},{"f":"السحُت","r":""}]}}