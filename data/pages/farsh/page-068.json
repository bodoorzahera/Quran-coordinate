{"page":68,"data":{"3:146:1":[{"f":"وَكَأَيِّن","r":"اكغ","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآئِن","r":"د","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآىٜن","r":"اَ","n":"بتسهيل الهمزة المكسورة مع مد وقصر"},{"f":"وَكَأَيّنْ","r":"ححَ","n":"الوقوف على الياء"},{"f":"وَكَا۬يِّن","r":"ف","n":"الوقوف بتسهيل الهمزة المفتوحة وبعدها ياء"}],"3:146:3":[{"f":"نَبِيُّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"نَبِيٓءُ","r":"ا","n":"بالهمز فيمد على المتصل"}],"3:146:4":[{"f":"قَٰتَلَ","r":"ذاَ","n":"بضم القاف وكسر التاء"},{"f":"قُتِلَ","r":"احد حَ","n":"بضم القاف وكسر التاء"}]}}