{"page":204,"data":{"9:107:1":[{"f":"وَٱلَّذِينَ","r":"دحنفرحَفَ","n":"بحذف الواو قبلها"},{"f":"ٱلَّذِينَ","r":"اكاَ","n":"بحذف الواو قبلها"}],"9:109:2":[{"f":"أَسَّسَ بُنۡيَٰنَهُ(معا)","r":"دحنفراَحَفَ","n":"بضم الهمزة وكسر السين الأولى ورفع بنيانه"},{"f":"أُسِّسَ بُنۡيَٰنُهُ","r":"اك","n":"بضم الهمزة وكسر السين الأولى ورفع بنيانه"}],"9:109:8":[{"f":"وَرِضۡوَٰنٍ","r":"ادحكعفراَحَفَ","n":"بضم الراء"},{"f":"وَرُضۡوَٰنٍ","r":"ص","n":"بضم الراء"}],"9:109:16":[{"f":"جُرُفٍ","r":"ادحعراَحَ","n":"بسكون الراء"},{"f":"جُرۡفٍ","r":"كصففَ","n":"بسكون الراء"}],"9:110:11":[{"f":"إِلَّآ أَن تَقَطَّعَ","r":"ادحكنفراَفَ","n":"بتخفيف اللام وفتح التاء"},{"f":"إِلَآ أَن تَقَطَّعَ","r":"حَ","n":"بتخفيف اللام وفتح التاء"},{"f":"إِلَّآ أَن تُقَطَّعَ","r":"ادحصرفَ","n":"بتشديد اللام وضم التاء"}],"9:111:15":[{"f":"فَيَقۡتُلُونَ وَيُقۡتَلُونَ","r":"ادحكناَحَ","n":"ضم ياء مع فتح التاء في الأول \nوفتح ياء مع كسر تاء الثاني"},{"f":"فَيُقۡتَلُونَ \nوَيَقۡتِلُونَ","r":"فرفَ","n":"ضم ياء مع فتح التاء في الأول \nوفتح ياء مع كسر تاء الثاني"}],"9:111:23":[{"f":"وَٱلۡقُرۡءَانِ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"وَٱلۡقُرَانِ","r":"دف","n":"بالنقل"}]}}