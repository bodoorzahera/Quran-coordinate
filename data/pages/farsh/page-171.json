{"page":171,"data":{"7:161:16":[{"f":"نَّغۡفِرۡ","r":"دحنفرفَ","n":"بتاء مضمومة وفتح الفاء"},{"f":"تُغۡفَرۡ","r":"اكاَحَ","n":"بتاء مضمومة وفتح الفاء"},{"f":"نَّغۡفِرۡ خَطِيٓـَٰٔتِكُمۡ","r":"ظ"},{"f":"نَّغۡفِرۡ خَطَٰيَىٰكُمۡ","r":"ح"},{"f":"تُغۡفَرۡ خَطِيٓـَٰٔتُكُمۡ","r":"ااَحَن"},{"f":"تُغۡفَرۡ خَطِيٓـَٔتُكُمۡ","r":"ك"}],"7:161:18":[{"f":"خَطِيٓـَٰٔتِكُمۡ","r":"ادكنفراَحَفَ","n":"مثل قضاياكم"},{"f":"خَطَٰيَىٰكُمۡ","r":"ح","n":"مثل قضاياكم"},{"f":"خَطِيٓـَٰٔتُكُمۡ","r":"ااَحَ","n":"بالجمع المؤنث السالم والرفع"},{"f":"خَطِيٓـَٔتُكُمۡ","r":"ك","n":"بالتوحيد والرفع"}],"7:163:1":[{"f":"وَسۡـَٔلۡهُمۡ","r":"كفاناَ ح حَ","n":"بالنقل"},{"f":"وَسَلۡهُمۡ","r":"ردفَ","n":"بالنقل"}]}}