{"page":297,"data":{"18:28:7":[{"f":"بِٱلۡغَدَوٰةِ","r":"ادحنفراَحَفَ","n":"بضم الغين وسكون الدال واو مفتوحة"},{"f":"بِٱلۡغُدۡوَةِ","r":"ك","n":"بضم الغين وسكون الدال واو مفتوحة"}],"18:33:4":[{"f":"أُكُلَهَا","r":"كنفراَحَفَ","n":"بسكون الكاف"},{"f":"أُكۡلَهَا","r":"ادح","n":"بسكون الكاف"}],"18:34:3":[{"f":"ثَمَرٞ","r":"ادكنفراَحَفَ","n":"بضم الثاء وسكون الميم"},{"f":"ثُمۡرٞ","r":"ح","n":"بضم الثاء وسكون الميم"},{"f":"ثُمُرٞ","r":"أردف كفَ","n":"بضم الثاء والميم"}],"18:34:8":[{"f":"أَنَا۠","r":"دحكنفرحَفَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"أَنَآ","r":"ااَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}]}}