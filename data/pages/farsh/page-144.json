{"page":144,"data":{"6:125:15":[{"f":"ضَيِّقًا","r":"احكنفراَحَفَ","n":"بسكون الياء"},{"f":"ضَيۡقًا","r":"د","n":"بسكون الياء"}],"6:125:16":[{"f":"حَرَجٗا","r":"فح فَحَ عكر","n":"بكسر الراء"},{"f":"حَرِجٗا","r":"اصاَ","n":"بكسر الراء"}],"6:125:18":[{"f":"يَصَّعَّدُ","r":"فاح فَاَحَ عكر","n":"بسكون الصاد وتخفيف العين دون ألف"},{"f":"يَصۡعَدُ","r":"د","n":"بسكون الصاد وتخفيف العين دون ألف"},{"f":"يَصَّٰعَدُ","r":"ص","n":"بفتح وتشديد الصاد وتخفيف العين وقبلها ألف"}],"6:126:2":[{"f":"صِرَٰطُ","r":"ادحكنقراَحَفَ","n":"بالسين"},{"f":"صِۜرَٰطُ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطُ","r":"ض","n":"بإشمام الصاد زاياً"}],"6:127:6":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"6:128:2":[{"f":"يَحۡشُرُهُمۡ","r":"عيَ","n":"بالنون"},{"f":"نَحۡشُرُهُمۡ","r":"حفر فاصطَاَدك","n":"بالنون"}]}}