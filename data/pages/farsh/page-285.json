{"page":285,"data":{"17:31:12":[{"f":"خِطۡـٔٗا","r":"الغ","n":"بكسر الخاء وفتح الطاء وألف بعدها تمد على المتصل"},{"f":"خِطَآءٗ","r":"د","n":"بكسر الخاء وفتح الطاء وألف بعدها تمد على المتصل"},{"f":"خَطَـٔٗا","r":"ماَ","n":"بفتح الخاء والطاء دون ألف"},{"f":"خِطَا","r":"ف","n":"يقف بنقل"}],"17:33:17":[{"f":"يُسۡرِف","r":"ادحكناَحَ","n":"بتاء الخطاب"},{"f":"تُسۡرِف","r":"فرفَ","n":"بتاء الخطاب"}],"17:35:6":[{"f":"بِٱلۡقِسۡطَاسِ","r":"عفرفَ","n":"بضم القاف"},{"f":"بِٱلۡقُسۡطَاسِ","r":"ادحكصاَحَ","n":"بضم القاف"}],"17:38:4":[{"f":"سَيِّئُهُۥ","r":"كنفرفَ","n":"بفتح الهمزة وتاء التأنيث مفتوحة منونة"},{"f":"سَيِّئَةٗ","r":"ادحاَحَ","n":"بفتح الهمزة وتاء التأنيث مفتوحة منونة"}]}}