{"page":168,"data":{"7:144:7":[{"f":"بِرِسَٰلَٰتِي","r":"حذ طَ","n":"بحذف الألف قبل التاء (مفرد)"},{"f":"بِرِسَٰلَتِي","r":"اداَيَ","n":"بحذف الألف قبل التاء (مفرد)"}],"7:146:20":[{"f":"ٱلرُّشۡدِ","r":"أكدناَ ح حَ","n":"بفتح الراء والشين"},{"f":"ٱلرَّشَدِ","r":"ففَر","n":"بفتح الراء والشين"}],"7:148:7":[{"f":"حُلِيِّهِمۡ","r":"احاَدك فَن","n":"بكسر الحاء واللام والياء مع تشديدها"},{"f":"حِلِيِّهِمۡ","r":"فر","n":"بكسر الحاء واللام والياء مع تشديدها"},{"f":"حَلۡيِهِمۡ","r":"حَ","n":"بفتح الحاء وسكون اللام وكسر وتخفيف الياء"}],"7:149:12":[{"f":"يَرۡحَمۡنَا رَبُّنَا وَيَغۡفِرۡ","r":"أكدناَ ح حَ","n":"بالخطاب ونصب ربنا"},{"f":"تَرۡحَمۡنَا رَبَّنَا وَتَغۡفِرۡ","r":"ففَر","n":"بالخطاب ونصب ربنا"}]}}