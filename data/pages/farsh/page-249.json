{"page":249,"data":{"13:1:1":[{"f":"الٓمٓر","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"13:1:14":[{"f":"أَلِفۡۜ لَآمۡۜ مِيٓمۡۜ رَاۜ","r":"اَ","n":"بالسكت على حروف التهجي"}],"13:3:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"13:3:16":[{"f":"يُغۡشِي","r":"احد عكاَ","n":"بفتح الغين وتشديد الشين"},{"f":"يُغَشِّي","r":"صف فَرحَ","n":"بفتح الغين وتشديد الشين"}],"13:4:8":[{"f":"وَزَرۡعٞ وَنَخِيلٞ صِنۡوَانٞ وَغَيۡرُ","r":"عد ح حَ","n":"بخفضها"},{"f":"وَزَرۡعٖ وَنَخِيلٖ صِنۡوَانٖ وَغَيۡرِ","r":"أراَد فصفَ","n":"بخفضها"}],"13:4:13":[{"f":"يُسۡقَىٰ","r":"نكحَ","n":"بالتأنيث"},{"f":"تُسۡقَىٰ","r":"احد فراَفَ","n":"بالتأنيث"}],"13:4:16":[{"f":"وَنُفَضِّلُ","r":"ادحكناَحَ","n":"بالياء"},{"f":"وَيُفَضِّلُ","r":"فرفَ","n":"بالياء"}],"13:4:21":[{"f":"ٱلۡأُكُلِ","r":"كغاَ","n":"بسكون الكاف"},{"f":"ٱلۡأُكۡلِ","r":"اد","n":"بسكون الكاف"}]}}