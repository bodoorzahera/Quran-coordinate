{"page":52,"data":{"3:19:2":[{"f":"إِنَّ ٱلدِّينَ","r":"ادحكنفاَحَفَ","n":"بفتح الهمزة"},{"f":"أَنَّ ٱلدِّينَ","r":"ر","n":"بفتح الهمزة"}],"3:21:2":[{"f":"وَيَقۡتُلُونَ ٱلَّذِينَ","r":"ادحكنراَحَفَ","n":"ضم الياء وفتح القاف وألف بعدها وكسر التاء"},{"f":"وَيُقَٰتِلُونَ ٱلَّذِينَ","r":"ف","n":"ضم الياء وفتح القاف وألف بعدها وكسر التاء"}],"3:21:7":[{"f":"ٱلنَّبِيِّ‍ۧنَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓـِٕـۧنَ","r":"ا","n":"بالهمز فيمد على المتصل"}]}}