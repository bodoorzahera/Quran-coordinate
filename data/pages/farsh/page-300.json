{"page":300,"data":{"18:54:5":[{"f":"ٱلۡقُرۡءَانِ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانِ","r":"دف","n":"بالنقل"}],"18:55:19":[{"f":"قُبُلٗا ","r":"نفراَفَ","n":"بكسر القاف وفتح الباء"},{"f":"قِبَلٗا","r":"أدك ح حَ","n":"بكسر القاف وفتح الباء"},{"f":"قُبُلٗا","r":"صاَ"}],"18:56:18":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"18:59:7":[{"f":"لِمَهۡلِكِهِم","r":"ع","n":"بفتح الميم واللام"},{"f":"لِمَهۡلَكِهِم","r":"ص","n":"بفتح الميم واللام"},{"f":"لِمُهۡلَكِهِم","r":"ادحكفراَحَفَ","n":"بضم الميم وفتح اللام"}]}}