{"page":455,"data":{"38:29:5":[{"f":"لِّيَدَّبَّرُوٓاْ","r":"ادحكنفرحَفَ","n":"بالتاء وتخفيف الدال"},{"f":"لِّتَدَبَّرُوٓاْ","r":"اَ","n":"بالتاء وتخفيف الدال"}],"38:33:5":[{"f":"بِٱلسُّوقِ","r":"اهحكنفراَحَفَ","n":"بهمز الواو ساكنة"},{"f":"بِٱلسُّؤۡقِ","r":"ز²","n":"بهمز الواو ساكنة"},{"f":"بِٱلسُّـُٔوقِ","r":"ز²","n":"ضم الهمزة قبل الواو"}],"38:36:3":[{"f":"ٱلرِّيحَ","r":"ادحكنفرحَفَ","n":"بفتح الياء وألف بعدها"},{"f":"ٱلرِّيَٰحَ","r":"اَ","n":"بفتح الياء وألف بعدها"}],"38:41:10":[{"f":"بِنُصۡبٖ ","r":"ادحكنفرحَفَ","n":"بضم النون والصاد"},{"f":"بِنُصُبٖ ","r":"اَ","n":"بضم النون والصاد"},{"f":"بِنَصَبٖ ","r":"حَ","n":"بفتح النون والصاد"},{"f":"بِنُصۡبٖ","r":"احظك"},{"f":"بِنُصُبٖ","r":"اَ"},{"f":"بِنَصَبٖ","r":"حَ"}]}}