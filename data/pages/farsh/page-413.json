{"page":413,"data":{"31:20:15":[{"f":"نِعَمَهُ","r":"احاَ  ع","n":"بسكون العين وتاء تأنيث مفتوحة منونة"},{"f":"نِعۡمَةٗ","r":"صدك ففَرحَ","n":"بسكون العين وتاء تأنيث مفتوحة منونة"}],"31:21:2":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"31:22:6":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"31:23:4":[{"f":"يَحۡزُنكَ","r":"دحكنفراَحَفَ","n":"بضم الياء وكسر الزاي"},{"f":"يُحۡزِنكَ","r":"ا","n":"بضم الياء وكسر الزاي"}],"31:27:8":[{"f":"وَٱلۡبَحۡرُ","r":"ادكنفراَفَ","n":"بالنصب"},{"f":"وَٱلۡبَحۡرَ","r":"ححَ","n":"بالنصب"}]}}