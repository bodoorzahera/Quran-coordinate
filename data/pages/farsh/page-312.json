{"page":312,"data":{"19:97:4":[{"f":"لِتُبَشِّرَ","r":"ادحكنراَحَفَ","n":"بفتح التاء وسكون الباء وضم وتخفيف الشين"},{"f":"لِتَبۡشُرَ","r":"ف","n":"بفتح التاء وسكون الباء وضم وتخفيف الشين"}],"20:1:1":[{"f":"طَه","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"20:2:4":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"دف","n":"بالنقل"}],"20:10:5":[{"f":"لِأَهۡلِهِ ٱمۡكُثُوٓاْ","r":"ادحكنراَحَفَ","n":"بضم هاء الضمير"},{"f":"لِأَهۡلِهُ ٱمۡكُثُوٓاْ","r":"ف","n":"بضم هاء الضمير"}],"20:12:1":[{"f":"إِنِّيٓ أَنَا۠","r":"ذحَ","n":"بفتح الهمزة والياء"},{"f":"أَنِّيَ أَنَا۠","r":"حصاَد","n":"بفتح الهمزة والياء"},{"f":"إِنِّيَ أَنَا۠","r":"ا","n":"بكسر الهمزة وفتح الياء"}],"20:12:9":[{"f":"طُوٗى","r":"ذ","n":"دون تنوين"},{"f":"طُوَىٰ","r":"اداَ ح حَ","n":"دون تنوين"}]}}