{"page":364,"data":{"25:44:2":[{"f":"تَحۡسَبُ","r":"كنفاَ","n":"كسر السين"},{"f":"تَحۡسِبُ","r":"ادحرحَفَ","n":"كسر السين"}],"25:48:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"25:48:4":[{"f":"ٱلرِّيَٰحَ","r":"احكنفراَحَفَ","n":"سكون الياء دون الألف"},{"f":"ٱلرِّيحَ","r":"د","n":"سكون الياء دون الألف"}],"25:48:5":[{"f":"بُشۡرَۢا","r":"ادحنفراَحَفَ","n":"بنون مضمومة وسكون الشين"}],"25:49:4":[{"f":"مَّيۡتٗا","r":"ادحكنفرحَفَ","n":"بكسر وتشديد الياء"},{"f":"مَيِّتٗا","r":"اَ","n":"بكسر وتشديد الياء"}],"25:50:4":[{"f":"لِيَذَّكَّرُواْ","r":"ادحكناَحَ","n":"بسكون الذال وضم وتخفيف الكاف"},{"f":"لِيَذۡكُرُواْ","r":"فرفَ","n":"بسكون الذال وضم وتخفيف الكاف"}]}}