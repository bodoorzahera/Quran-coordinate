{"page":305,"data":{"19:1:1":[{"f":"كٓهيعٓصٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"19:2:5":[{"f":"زَكَرِيَّآ","r":"عفرفَ","n":"بهمزة مفتوحة بعد الألف"},{"f":"زَكَرِيَّآءَ","r":"ادحكصاَحَ","n":"بهمزة مفتوحة بعد الألف"}],"19:6:1":[{"f":"يَرِثُنِي وَيَرِثُ","r":"دفنا فَحَكاَ","n":"بسكون الثاء فيهما"},{"f":"يَرِثۡنِي وَيَرِثۡ","r":"حر","n":"بسكون الثاء فيهما"}],"19:7:1":[{"f":"يَٰزَكَرِيَّآ","r":"عفرفَ","n":"بهمزة مضمومة بعد الألف"},{"f":"يَٰزَكَرِيَّآءُ","r":"ادحكصاَحَ","n":"بهمزة مضمومة بعد الألف"}],"19:7:3":[{"f":"نُبَشِّرُكَ","r":"ادحكنراَحَفَ","n":"بفتح النون وسكون الباء وضم وتخفيف الشين"},{"f":"نَبۡشُرُكَ","r":"ف","n":"بفتح النون وسكون الباء وضم وتخفيف الشين"}],"19:8:14":[{"f":"عِتِيّٗا","r":"عفر","n":"بضم العين"},{"f":"عُتِيّٗا","r":"ادحكصاَحَفَ","n":"بضم العين"}],"19:9:9":[{"f":"خَلَقۡتُكَ","r":"ادحكناَحَفَ","n":"بنون مفتوحة وألف"},{"f":"خَلَقۡنـٰكَ","r":"فر","n":"بنون مفتوحة وألف"}]}}