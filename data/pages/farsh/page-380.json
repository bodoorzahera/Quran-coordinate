{"page":380,"data":{"27:36:5":[{"f":"أَتُمِدُّونَنِ","r":"كنفرحَفَ","n":"بنونين وإثبات الياء"},{"f":"أَتُمِدُّوٓنْنِّۦ۬","r":"فحَ","n":"بإدغام النونين فتمد الواو مشبعاً وإثبات ياء الزوائد"},{"f":"أَتُمِدُّونَنِۦ۬ -أَتُمِدُّونَنِۦ","r":"احاَ / د","n":"بنونين وإثبات الياء"}],"27:44:11":[{"f":"سَاقَيۡهَا","r":"اهحكنفراَحَفَ","n":"بهمزة ساكنة بدل الألف"},{"f":"سَأۡقَيۡهَا","r":"ز","n":"بهمزة ساكنة بدل الألف"}]}}