{"page":564,"data":{"67:27:4":[{"f":"سِيٓـَٔتۡ","r":"دحنفىَفَ","n":"بإشمام كسر السين ضماً"},{"f":"سـ۬يٓـَٔتۡ","r":"اراَك طَ","n":"بإشمام كسر السين ضماً"}],"67:27:8":[{"f":"وَقِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"وَقـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"67:27:13":[{"f":"تَدَّعُونَ","r":"ادحكنفراَفَ","n":"بسكون الدال"},{"f":"تَدۡعُونَ","r":"حَ","n":"بسكون الدال"}],"67:29:8":[{"f":"فَسَتَعۡلَمُونَ","r":"ادحكنفاَحَفَ","n":"بياء الغيب"},{"f":"فَسَيَعۡلَمُونَ","r":"ر","n":"بياء الغيب"}],"68:1:1":[{"f":"نٓ","r":"ادحكنفرحَفَ","n":"السكت على حرف التهجي"}],"68:7:9":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}