{"page":332,"data":{"22:2:15":[{"f":"سُكَٰرَىٰ -بِسُكَٰرَىٰ","r":"ادحكناَحَ","n":"بفتح السين وسكون الكاف دون الألف"},{"f":"سَكۡرَىٰ -بِسَكۡرَىٰ","r":"فرفَ","n":"بفتح السين وسكون الكاف دون الألف"}],"22:5:64":[{"f":"وَرَبَتۡ","r":"ادحكنفرحَفَ","n":"بهمزة مفتوحة قبل التاء"},{"f":"وَرَبَـَٔتۡ","r":"اَ","n":"بهمزة مفتوحة قبل التاء"}]}}