{"page":435,"data":{"35:4:10":[{"f":"تُرۡجَعُ","r":"ادحناَ","n":"بفتح تاء المضارعة وكسر الجيم"},{"f":"تَرۡجِعُ","r":"كفرحَفَ","n":"بفتح تاء المضارعة وكسر الجيم"}],"35:8:17":[{"f":"تَذۡهَبۡ نَفۡسُكَ","r":"ادحكنفرحَفَ","n":"بضم التاء وكسر الهاء ونصب السين"},{"f":"تُذۡهِبۡ نَفۡسَكَ","r":"اَ","n":"بضم التاء وكسر الهاء ونصب السين"}],"35:9:4":[{"f":"ٱلرِّيَٰحَ","r":"احكناَحَ","n":"سكون الياء دون الألف"},{"f":"ٱلرِّيحَ","r":"ففَرد","n":"سكون الياء دون الألف"}],"35:9:10":[{"f":"مَّيِّتٖ","r":"عفا راَفَ","n":"بسكون الياء"},{"f":"مَّيۡتٖ","r":"حصدك حَ","n":"بسكون الياء"}],"35:11:24":[{"f":"يُنقَصُ","r":"ادحكنفرحَفَ","n":"بفتح الياء وضم القاف"},{"f":"يَنقُصُ","r":"حَ","n":"بفتح الياء وضم القاف"}]}}