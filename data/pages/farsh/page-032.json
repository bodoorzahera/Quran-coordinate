{"page":32,"data":{"2:204:15":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}],"2:206:2":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"رطَل","n":"بإشمام كسر القاف ضماً"}],"2:207:10":[{"f":"رَءُوفُۢ","r":"ادعاَك","n":"بحذف الواو "},{"f":"رَؤُفُۢ","r":"صفح فرحَ","n":"بحذف الواو "}],"2:208:6":[{"f":"ٱلسِّلۡمِ","r":"فحفَحَنك","n":"فتح السين"},{"f":"ٱلسَّلۡمِ","r":"اراَد","n":"فتح السين"}],"2:208:10":[{"f":"خُطُوَٰتِ","r":"راحَ عزك","n":"سكون الطاء"},{"f":"خُطۡوَٰتِ","r":"احص هففَ","n":"سكون الطاء"}],"2:210:11":[{"f":"وَٱلۡمَلَٰٓئِكَةُ","r":"ادحكنفرحَفَ","n":"بالخفض"},{"f":"وَٱلۡمَلَٰٓئِكَةِ","r":"اَ","n":"بالخفض"}],"2:210:16":[{"f":"تُرۡجَعُ","r":"احدناَ","n":"بفتح تاء المضارعة وكسر الجيم"},{"f":"تَرۡجِعُ","r":"ففَرحَك","n":"بفتح تاء المضارعة وكسر الجيم"}]}}