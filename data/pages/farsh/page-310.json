{"page":310,"data":{"19:66:3":[{"f":"أَءِذَا","r":"ادحلنفراَحَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِذَا","r":"م","n":"بالإخبار بهمزة واحدة مكسورة"}],"19:66:5":[{"f":"مِتُّ","r":"افعرفَك","n":"بضم الميم"},{"f":"مُتُّ","r":"كداَ صححَ","n":"بضم الميم"}],"19:67:2":[{"f":"يَذۡكُرُ","r":"اكن","n":"بفتح الذال والكاف وتشديدهما"},{"f":"يَذَّكَّرُ","r":"حرف فَحَاَد","n":"بفتح الذال والكاف وتشديدهما"}],"19:68:8":[{"f":"جِثيا","r":"عفر"},{"f":"جُثيا","r":"كدحا فَصاَحَ"}],"19:69:10":[{"f":"عِتيا","r":"عفر"},{"f":"عُتيا","r":"كدحا فَصاَحَ"}],"19:70:8":[{"f":"صِليا","r":"عفر"},{"f":"صُليا","r":"كدحا فَصاَحَ"}],"19:72:2":[{"f":"نُنَجِّي","r":"احد فكفَناَ","n":"بسكون النون وتخفيف الجيم"},{"f":"نُنجِي","r":"رحَ","n":"بسكون النون وتخفيف الجيم"}],"19:72:8":[{"f":"جِثيا","r":"عفر"},{"f":"جُثيا","r":"كدحا فَصاَحَ"}],"19:73:14":[{"f":"مَّقَامٗا","r":"احكنفراَحَفَ","n":"بضم الميم الأولى"},{"f":"مُّقَامٗا","r":"د","n":"بضم الميم الأولى"}],"19:74:9":[{"f":"وَرِءۡيٗا","r":"جد غل","n":"بياء مشددة دون همز"},{"f":"وَرِيّٗا","r":"بماَ","n":"بياء مشددة دون همز"}]}}