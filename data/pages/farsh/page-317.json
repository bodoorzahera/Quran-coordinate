{"page":317,"data":{"20:77:6":[{"f":"أَنۡ أَسۡرِ","r":"كغ","n":"بهمزة وصل وكسر أولى الساكنين"},{"f":"أنِ ٱسۡرِ","r":"اداَ","n":"بهمزة وصل وكسر أولى الساكنين"}],"20:77:15":[{"f":"لَّا تَخَٰفُ","r":"ادحكنراَحَفَ","n":"بالقصر والجزم بسكون الفاء دون ألف"},{"f":"لَّا تَخَفۡ","r":"ف","n":"بالقصر والجزم بسكون الفاء دون ألف"}],"20:80:7":[{"f":"وَوَٰعَدۡنَٰكُمۡ","r":"اندك","n":"حذف الألف قبل العين"},{"f":"وَوَعَدۡنَٰكُمۡ","r":"حاَحَ","n":"حذف الألف قبل العين"}],"20:81:5":[{"f":"رزقناكم","r":"أكدناَ ح حَ"}],"20:81:9":[{"f":"فَيَحِلَّ","r":"ادحكنفاَحَفَ","n":"بضم الحاء"},{"f":"فَيَحُلَّ","r":"ر","n":"بضم الحاء"}],"20:81:13":[{"f":"يَحۡلِلۡ","r":"ادحكنفاَحَفَ","n":"بضم اللام الأولى"},{"f":"يَحۡلُلۡ","r":"ر","n":"بضم اللام الأولى"}],"20:84:5":[{"f":"أَثَرِي","r":"ادحكنفراَىَفَ","n":"بكسر الهمزة وسكون الثاء"},{"f":"إِثۡرِي","r":"طَ","n":"بكسر الهمزة وسكون الثاء"}],"20:87:5":[{"f":"بِمَلۡكِنَا","r":"انا","n":"بضم الميم"},{"f":"بِمُلۡكِنَا","r":"ففَر","n":"بضم الميم"},{"f":"بِمِلۡكِنَا","r":"كد ح حَ","n":"بكسر الميم"}],"20:87:7":[{"f":"حُمِّلۡنَآ ","r":"ادكعاَطَ","n":"بفتح الحاء والميم والتخفيف"},{"f":"حَمَلۡنَآ ","r":"حصفرىَفَ","n":"بفتح الحاء والميم والتخفيف"},{"f":"حُمِّلۡنَآ","r":"ادعاَك طَ"},{"f":"حَمَلۡنَآ","r":"حر فصيَفَ"}]}}