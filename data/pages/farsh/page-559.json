{"page":559,"data":{"65:6:6":[{"f":"وُجۡدِكُمۡ","r":"ادحكنفراَطَفَ","n":"بكسر الواو"},{"f":"وِجۡدِكُمۡ","r":"يَ","n":"بكسر الواو"}],"65:7:24":[{"f":"عُسۡرٖ يُسۡرٗا","r":"ادحكنفرحَفَ","n":"بضم السين"},{"f":"عُسُرٖ يُسُرٗا","r":"اَ","n":"بضم السين"}],"65:8:1":[{"f":"وَكَأَيِّن","r":"احكنفراَحَفَ","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآئِن","r":"د","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآىٜن","r":"اَ","n":"بتسهيل الهمزة المكسورة مع مد وقصر"},{"f":"وَكَأَيّنْ","r":"ححَ","n":"الوقوف على الياء"},{"f":"وَكَا۬يِّن","r":"ف","n":"الوقوف بتسهيل الهمزة المفتوحة وبعدها ياء"}],"65:8:14":[{"f":"نُّكۡرٗا","r":"دحلعفرفَ","n":"بضم الكاف"},{"f":"نُكُرٗا","r":"امصاَحَ","n":"بضم الكاف"}],"65:11:6":[{"f":"مُبَيِّنَٰتٖ","r":"كعفرفَ","n":"بفتح الياء"},{"f":"مُبَيَّنَٰتٖ","r":"ادحصاَحَ","n":"بفتح الياء"}],"65:11:21":[{"f":"يُدۡخِلۡهُ","r":"دحنفرحَفَ","n":"بالنون"},{"f":"نُدۡخِلۡهُ","r":"اكاَ","n":"بالنون"}]}}