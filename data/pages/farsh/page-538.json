{"page":538,"data":{"57:5:7":[{"f":"تُرۡجَعُ","r":"ادحناَ","n":"بفتح تاء المضارعة وكسر الجيم"},{"f":"تَرۡجِعُ","r":"كفرحَفَ","n":"بفتح تاء المضارعة وكسر الجيم"}],"57:8:11":[{"f":"أَخَذَ مِيثَٰقَكُمۡ","r":"ادكنفراَحَفَ","n":"بضم الهمزة وكسر الخاء وضم القاف"},{"f":"أُخِذَ مِيثَٰقُكُمۡ","r":"ح","n":"بضم الهمزة وكسر الخاء وضم القاف"}],"57:9:3":[{"f":"يُنَزِّلُ","r":"اكنفراَفَ","n":"بسكون النون وتخفيف الزاي"},{"f":"يُنزِلُ","r":"دححَ","n":"بسكون النون وتخفيف الزاي"}],"57:9:16":[{"f":"لَرَءُوفٞ","r":"ادكعاَ","n":"بحذف الواو "},{"f":"لَرَؤُفٞ","r":"حصفرحَفَ","n":"بحذف الواو "}],"57:10:30":[{"f":"وَكُلّٗا","r":"ادحنفراَحَفَ","n":"بالرفع"},{"f":"وَكُلّٞ","r":"ك","n":"بالرفع"}],"57:11:8":[{"f":"فَيُضَٰعِفَهُ","r":"ن","n":"بألف وتخفيف العين ورفع الفاء"},{"f":"فَيُضَٰعِفُهُ","r":"احففَ ر","n":"بألف وتخفيف العين ورفع الفاء"},{"f":"فَيُضَعِّفُهُ","r":"داَ","n":"حذف الألف وتشديد العين ورفع الفاء"},{"f":"فَيُضَعِّفَهُ","r":"كحَ","n":"حذف الألف وتشديد العين مع نصب الفاء"}]}}