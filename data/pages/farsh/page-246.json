{"page":246,"data":{"12:87:8":[{"f":"تَاْيۡـَٔسُواْ  -يَاْيۡـَٔسُ","r":"ازحكنفراَحَفَ","n":"إبدال الهمزة ألفا وتقديمها وفتح الياء"},{"f":"تَايَسُواْ  -يَايَسُ","r":"ه","n":"إبدال الهمزة ألفا وتقديمها وفتح الياء"},{"f":"تَاْيَّسُواْ  -يَاْيَّسُ","r":"ف","n":"يقف بنقل وإدغام"}],"12:87:14":[{"f":"استَايَسُواْ  -يَايَسُ","r":"ه²"},{"f":"ايتَاْيَّسُواْ  -يَاْيَّسُ","r":"ف"}],"12:90:2":[{"f":"أَءِنَّكَ","r":"اكغ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِنَّكَ","r":"داَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"12:92:9":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}