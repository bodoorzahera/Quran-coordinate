{"page":558,"data":{"65:1:2":[{"f":"ٱلنَّبِيُّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل \n(بتسهيل وإبدال الهمزة الثانية واواً وصلا)"},{"f":"ٱلنَّبِيٓءُ وِذَا (نطقا)\nٱلنَّبِيٓءُ اٜذَا","r":"ا","n":"بالهمز فيمد على المتصل \n(بتسهيل وإبدال الهمزة الثانية واواً وصلا)"}],"65:1:16":[{"f":"بُيُوتِهِنَّ","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"بِيُوتِهِنَّ","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}],"65:1:23":[{"f":"مُّبَيِّنَةٖ","r":"احكعفراَحَفَ","n":"بفتح الياء"},{"f":"مُّبَيَّنَةٖ","r":"دص","n":"بفتح الياء"}],"65:3:10":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"65:3:14":[{"f":"بَٰلِغُ أَمۡرِهِ","r":"ع","n":"بتنوين الغين وفتح الراء"},{"f":"بَٰلِغٌ أَمۡرَهِ","r":"ادحكصفراَحَفَ","n":"بتنوين الغين وفتح الراء"}],"65:4:1":[{"f":"وَٱلَّٰٓـِٔي","r":"جهحكنفراَفَ","n":"دون ياء وتحقيق الهمز"},{"f":"وَٱلَّٰٓـِٔيْ","r":"بزحَ","n":"دون ياء وتحقيق الهمز"},{"f":"وَٱلَّٰٓـِ۬يْ","r":"جهحاَ","n":"دون ياء وتسهيل الهمزة مع مد وقصر"},{"f":"وَٱلَّـٰٓيۡ","r":"جهحاَ","n":"دون ياء وإبدال الهمزة ياء ساكنة فتمد الألف مشبعاً"},{"f":"وَٱلَّٰـِ۬يْ","r":"جهحاَ","n":"دون ياء وتسهيل بروم"}],"65:4:28":[{"f":"يُسۡرٗا","r":"ادحكنفرحَفَ","n":"بضم السين"},{"f":"يُسُرٗا","r":"اَ","n":"بضم السين"}]}}