{"page":543,"data":{"58:7:30":[{"f":"أَكۡثَرَ","r":"ادحكنفراَفَ","n":"بضم الراء"},{"f":"أَكۡثَرُ","r":"حَ","n":"بضم الراء"}],"58:8:13":[{"f":"وَيَتَنَٰجَوۡنَ","r":"احصاَد يَعرفَك","n":"بسكون النون وتقديمها على التاء وحذف الألف وضم الجيم"},{"f":"وَيَنتَجُونَ","r":"فطَ","n":"بسكون النون وتقديمها على التاء وحذف الألف وضم الجيم"}],"58:9:7":[{"f":"تَتَنَٰجَوۡاْ","r":"ادحكنفراَىَفَ","n":"بسكون النون بين التاءين مع حذف الألف وضم الجيم"},{"f":"تَنتَجُوۡاْ","r":"طَ","n":"بسكون النون بين التاءين مع حذف الألف وضم الجيم"}],"58:10:5":[{"f":"لِيَحۡزُنَ","r":"دحكنفراَحَفَ","n":"بضم الياء وكسر الزاي"},{"f":"لِيُحۡزِنَ","r":"ا","n":"بضم الياء وكسر الزاي"}],"58:11:5":[{"f":"قِيلَ (معا)","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"58:11:9":[{"f":"ٱلۡمَجَٰلِسِ","r":"ن","n":"بالإفراد بسكون الجيم دون ألف"},{"f":"ٱلۡمَجۡلِسِ","r":"ادحكفراَحَفَ","n":"بالإفراد بسكون الجيم دون ألف"}],"58:11:16":[{"f":"ٱنشُزُواْ فَٱنشُزُواْ","r":"اكان ص²","n":"بكسر الشين"},{"f":"ٱنشِزُواْ فَٱنشِزُواْ","r":"فح فَحَ در ص²","n":"بكسر الشين"}]}}