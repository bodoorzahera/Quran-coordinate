{"page":43,"data":{"2:258:6":[{"f":"إِبۡرَٰهِ‍ۧمَ (كله)","r":"ادحنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"لمً","n":"بفتح الهاء وألف بعدها"}],"2:258:21":[{"f":"أَنَا۠","r":"غدك","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"أَنَآ","r":"ا","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}],"2:259:6":[{"f":"وَهُيَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡيَ","r":"بحاَر","n":"بسكون الهاء"}],"2:259:10":[{"f":"قَالَ أَعۡلَمُ","r":"احنفَك اَحَد","n":"بوصل الهمزة وسكون الميم"},{"f":"قَالَ ٱعۡلَمۡ","r":"فر","n":"بوصل الهمزة وسكون الميم"}],"2:259:42":[{"f":"يَتَسَنَّهۡ","r":"احن اَكد","n":"حذف الهاء وصلا"},{"f":"يَتَسَنَّه۠","r":"ففَرحَ","n":"حذف الهاء وصلا"}],"2:259:53":[{"f":"نُنشِزُهَا","r":"ذ","n":"بالراء المهملة"},{"f":"نُنشِرُهَا","r":"اداَ ح حَ","n":"بالراء المهملة"}]}}