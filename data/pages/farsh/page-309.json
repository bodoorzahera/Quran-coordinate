{"page":309,"data":{"19:56:8":[{"f":"نَبِيّٗا -ٱلنَّبِيِّـۧنَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"نَّبِيٓـٔٗا -ٱلنَّبِيٓـِٕـۧنَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"19:58:17":[{"f":"إِبۡرَٰهِ‍ۧمَ","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}],"19:58:29":[{"f":"وَبُكِيّٗا","r":"ادحكناَحَفَ","n":"كسر الباء"},{"f":"وَبِكِيّٗا","r":"فر","n":"كسر الباء"}],"19:60:8":[{"f":"يَدۡخُلُونَ","r":"افعرفَك","n":"بضم الياء وفتح الخاء"},{"f":"يُدۡخَلُونَ","r":"حصاَد حَ","n":"بضم الياء وفتح الخاء"}],"19:63:4":[{"f":"نُورِثُ","r":"ادحكنفراَىَفَ","n":"بفتح الواو وتشديد الراء"},{"f":"نُوَرِّثُ","r":"طَ","n":"بفتح الواو وتشديد الراء"}]}}