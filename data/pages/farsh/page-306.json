{"page":306,"data":{"19:19:6":[{"f":"لِأَهَبَ","r":"ب² اذاَد","n":"بالياء"},{"f":"لِاَهَبَ - لِاَ۬هَبَ","r":"اب² ح حَ","n":"بالياء"}],"19:23:8":[{"f":"مِتُّ","r":"افعرفَ","n":"بضم الميم"},{"f":"مُتُّ","r":"حصاَدك حَ","n":"بضم الميم"}],"19:23:12":[{"f":"نَسۡيٗا","r":"فع","n":"بكسر النون"},{"f":"نِسۡيٗا","r":"احصاَدك حَرفَ","n":"بكسر النون"}],"19:24:3":[{"f":"مِن تَحۡتِهَآ","r":"عفافَ ريَا","n":"بفتح الميم والتاء"},{"f":"مَن تَحۡتَهَآ","r":"حصدك طَ","n":"بفتح الميم والتاء"}],"19:25:5":[{"f":"تُسَٰقِطۡ","r":"ع","n":"بفتح التاء والقاف وتخفيف السين"},{"f":"تَسَٰقَطۡ","r":"ف","n":"بفتح التاء والقاف وتخفيف السين"},{"f":"تَسَّٰقَطۡ","r":"احصاَدك رفَ","n":"بفتح التاء والقاف وتشديد السين"},{"f":"يَسَّٰقَطۡ","r":"حَ","n":"بياء مفتوحة وفتح القاف وتشديد السين"}]}}