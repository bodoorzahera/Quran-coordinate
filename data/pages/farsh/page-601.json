{"page":601,"data":{"104:2:2":[{"f":"جَمَعَ","r":"احطَ ند","n":"بتشديد الميم"},{"f":"جَمَّعَ","r":"فيَ كفَاَر","n":"بتشديد الميم"}],"104:3:1":[{"f":"يَحۡسَبُ","r":"كنفاَ","n":"كسر السين"},{"f":"يَحۡسِبُ","r":"ادحرحَفَ","n":"كسر السين"}],"104:8:3":[{"f":"مُّؤۡصَدَةٞ ","r":"حعحَفَ","n":"بالإبدال"},{"f":"مُّوصَدَةٞ ","r":"ادكصفراَ","n":"بالإبدال"},{"f":"مُّؤۡصَدَةٞ","r":"فعفَ ح حَ"},{"f":"مُّوصَدَةٞ","r":"ارصاَدك"}],"104:9:2":[{"f":"عَمَدٖ","r":"اعاَدك ح حَ","n":"بضم العين والميم"},{"f":"عُمُدٖ","r":"فصرفَ","n":"بضم العين والميم"}]}}