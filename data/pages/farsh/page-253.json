{"page":253,"data":{"13:31:3":[{"f":"قُرۡءَانٗا","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"قُرَانٗا","r":"د","n":"بالنقل"}],"13:31:20":[{"f":"يَاْيۡـَٔسِ","r":"ازحكنفراَحَفَ","n":"إبدال الهمزة ألفا وتقديمها وفتح الياء"},{"f":"يَايَسِ","r":"ه²","n":"إبدال الهمزة ألفا وتقديمها وفتح الياء"},{"f":"يَاْيَّسِ","r":"ف","n":"يقف بنقل وإدغام"}],"13:32:1":[{"f":"وَلَقَدِ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"وَلَقَدُ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}],"13:32:2":[{"f":"ٱسۡتُهۡزِئَ","r":"ادحمنرحَفَ","n":"إبدال الهمزة بياء مفتوحة وصلا"},{"f":"ٱسۡتُهۡزِيَ","r":"اَ","n":"إبدال الهمزة بياء مفتوحة وصلا"}],"13:33:30":[{"f":"وَصُدُّواْ","r":"ثحَ","n":"بفتح الصاد"},{"f":"وَصَدُّواْ","r":"احاَدك","n":"بفتح الصاد"}]}}