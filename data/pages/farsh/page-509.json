{"page":509,"data":{"47:22:2":[{"f":"عَسَيۡتُمۡ","r":"دحكنفراَحَفَ","n":"بكسر السين"},{"f":"عَسِيتُمۡ","r":"ا","n":"بكسر السين"}],"47:22:4":[{"f":"تَوَلَّيۡتُمۡ","r":"ادحكنفراَىَفَ","n":"بضم التاء والواو وكسر اللام"},{"f":"تُوُلِّيتُمۡ","r":"طَ","n":"بضم التاء والواو وكسر اللام"}],"47:22:9":[{"f":"وَتُقَطِّعُوٓاْ","r":"ادحكنفراَفَ","n":"بفتح التاء والطاء وتخفيفها وسكون القاف"},{"f":"وَتَقۡطَعُوٓاْ","r":"حَ","n":"بفتح التاء والطاء وتخفيفها وسكون القاف"}],"47:24:3":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"دف","n":"بالنقل"}],"47:25:15":[{"f":"وَأَمۡلَىٰ","r":"ادكنفراَحَفَ","n":"بضم الهمزة وكسر اللام وفتح الياء"},{"f":"وَأُمۡلِيَ","r":"ح","n":"بضم الهمزة وكسر اللام وفتح الياء"},{"f":"وَأُمۡلِي","r":"حَ","n":"بضم الهمزة وكسر اللام وسكون الياء"}],"47:26:15":[{"f":"إِسۡرَارَهُمۡ","r":"عفرفَ","n":"بفتح الهمزة"},{"f":"أَسۡرَارَهُمۡ","r":"ادحكصاَحَ","n":"بفتح الهمزة"}],"47:28:8":[{"f":"رِضۡوَٰنَهُ","r":"ادحكعفراَحَفَ","n":"بضم الراء"},{"f":"رُضۡوَٰنَهُ","r":"ص","n":"بضم الراء"}]}}