{"page":274,"data":{"16:66:6":[{"f":"نُّسۡقِيكُم","r":"ادحكنفرحَفَ","n":"بتاء مفتوحة"},{"f":"تَّسۡقِيكُم","r":"اَ","n":"بتاء مفتوحة"},{"f":"نَّسۡقِيكُم","r":"اكصحَ","n":"بنون مفتوحة"},{"f":"نُّسۡقِيكُ","r":"حد فرفَع"},{"f":"تَّسۡقِيكُ","r":"اَ"},{"f":"نَّسۡقِيكُ","r":"اصاحَك"}],"16:68:9":[{"f":"بُيُوتٗا","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"بِيُوتٗا","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}],"16:68:13":[{"f":"يَعۡرِشُونَ","r":"فاح فَاَحَ رعد","n":"بضم الراء"},{"f":"يَعۡرُشُونَ","r":"صك","n":"بضم الراء"}],"16:71:22":[{"f":"يَجۡحَدُونَ","r":"ادحكعفراَىَفَ","n":"بتاء الخطاب"},{"f":"تَجۡحَدُونَ","r":"صطَ","n":"بتاء الخطاب"}]}}