{"page":573,"data":{"72:14:1":[{"f":"وَأَنَّا","r":"كعفرفَ","n":"بكسر الهمزة"},{"f":"وَإِنَّا","r":"ادحصاَحَ","n":"بكسر الهمزة"}],"72:16:1":[{"f":"وَأَلَّوِ","r":"دحكنفرحَفَ","n":"الرسم فقط"}],"72:17:8":[{"f":"يَسۡلُكۡهُ","r":"نفرحَفَ","n":"بالنون"},{"f":"نَسۡلُكۡهُ","r":"ادحكاَ","n":"بالنون"}],"72:19:1":[{"f":"وَأَنَّهُ","r":"دحكعفراَحَفَ","n":"بكسر الهمزة"},{"f":"وَإِنَّهُ","r":"اص","n":"بكسر الهمزة"}],"72:19:10":[{"f":"لِبَدٗا","r":"ادحمنفراَحَفَ","n":"بضم اللام"},{"f":"لُبَدٗا","r":"ل","n":"بضم اللام"}],"72:20:1":[{"f":"قَالَ - قَٰلَ","r":"ادحكرحَفَ","n":"بفتح القاف واللام وألف بينهما \n(واختلاف الرسم بإثبات الألف عند البعض)"}],"72:20:2":[{"f":"قُلۡ إِنَّمَآ","r":"نفاَ","n":"بفتح القاف واللام وألف بينهما \n(واختلاف الرسم بإثبات الألف عند البعض)"}],"72:28:1":[{"f":"لِّيَعۡلَمَ","r":"ادحكنفراَىَفَ","n":"بضم الياء"},{"f":"لِّيُعۡلَمَ","r":"طَ","n":"بضم الياء"}]}}