{"page":525,"data":{"52:32:2":[{"f":"تَأۡمُرُهُمۡ","r":"ادكنفراَحَفَ","n":"بسكون الراء (والبدل واضح) "},{"f":"تَأۡمُرۡهُمۡ","r":"ح","n":"بسكون الراء (والبدل واضح) "},{"f":"تَأۡمُر۬هُمۡ","r":"ط","n":"واختلاس ضم الراء"}],"52:37:7":[{"f":"ٱلۡمُصَۜيۡطِرُونَ","r":"ڲ","n":"بالسين"},{"f":"ٱلۡمُصَۜيۡطِرُونَ","r":"زلع","n":"بالسين"},{"f":"ٱلۡمُصَـؗيۡطِرُونَ","r":"ف ق²","n":"بإشمام الصاد زاياً"},{"f":"ٱلۡمُصَيۡطِرُونَ","r":"ق² صر حام حَاَفَ"},{"f":"ٱلۡمُسيۡطِرُونَ","r":"زل"}],"52:45:3":[{"f":"يُلَٰقُواْ","r":"ادحكنفرحَفَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"},{"f":"يَلۡقَوۡاْ","r":"اَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"}],"52:45:7":[{"f":"يُصۡعَقُونَ","r":"كن","n":"بفتح الياء"},{"f":"يَصۡعَقُونَ","r":"ادحفراَحَفَ","n":"بفتح الياء"}]}}