{"page":334,"data":{"22:17:6":[{"f":"وَٱلصَّٰبِـِٔينَ","r":"غدك","n":"بحذف الهمزة (يقف حمزة بحذف وتسهيل)"},{"f":"وَٱلصَّٰبِينَ","r":"ااَ","n":"بحذف الهمزة (يقف حمزة بحذف وتسهيل)"}],"22:19:1":[{"f":"هَٰذَانِ","r":"احكنفراَحَفَ","n":"بتشديد النون مع الألف مشبعاً"},{"f":"هَٰذَآنِّ","r":"د","n":"بتشديد النون مع الألف مشبعاً"}],"22:23:19":[{"f":"وَلُؤۡلُؤٗا","r":"اناَحَ","n":"كسر التنوين"},{"f":"وَلُؤۡلُؤٖاْ","r":"حففَ درك","n":"كسر التنوين"},{"f":"وَلُولُؤٖاْ","r":"ص","n":"إبدال الهمزة الساكنة واو وكسر التنوين"},{"f":"وَلُولُؤٗا","r":"اَ","n":"إبدال الهمزة الساكنة واو وفتح التنوين"},{"f":"وَلُؤۡلُواْ","r":"ل","n":"إبدال الأخيرة واوا مع سكون وروم وتسهيل بروم"},{"f":"وَلُولُواْ","r":"ف","n":"إبدال الهمزتين واوا مع سكون وروم وتسهيل بروم"}]}}