{"page":184,"data":{"8:59:2":[{"f":"يَحۡسَبَنَّ","r":"عفاَك","n":"بالتاء وفتح السين"},{"f":"تَحۡسَبَنَّ ","r":"ص","n":"بالتاء وفتح السين"},{"f":"تَحۡسِبَنَّ ","r":"ادحرحَفَ","n":"بالتاء وكسر ا لسين"},{"f":"تَحۡسَبَنَّ","r":"ص"},{"f":"تَحۡسِبَنَّ","r":"احد حَرفَ"}],"8:59:6":[{"f":"إِنَّهُمۡ","r":"ادحنفراَحَفَ","n":"بفتح الهمزة"},{"f":"أَنَّهُمۡ","r":"ك","n":"بفتح الهمزة"}],"8:60:10":[{"f":"تُرۡهِبُونَ","r":"ادحكنفراَىَفَ","n":"بفتح الراء وتشديد الهاء"},{"f":"تُرَهِّبُونَ","r":"طَ","n":"بفتح الراء وتشديد الهاء"}],"8:61:3":[{"f":"لِلسَّلۡمِ","r":"ادحكعفراَحَفَ","n":"بكسر السين"},{"f":"لِلسِّلۡمِ","r":"ص","n":"بكسر السين"}]}}