{"page":505,"data":{"46:23:6":[{"f":"وَأُبَلِّغُكُم","r":"ادكنفراَحَفَ","n":"بسكون الباء وتخفيف اللام"},{"f":"وَأُبۡلِغُكُم","r":"ح","n":"بسكون الباء وتخفيف اللام"}],"46:25:8":[{"f":"لَا يُرَىٰٓ إِلَّا مَسَٰكِنُهُمۡ","r":"فصفَحَ","n":"بتاء مفتوحة ونصب النون"},{"f":"لَا تَرَىٰٓ إِلَّا مَسَٰكِنَهُمۡ","r":"حد اراَك","n":"بتاء مفتوحة ونصب النون"}]}}