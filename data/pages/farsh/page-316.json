{"page":316,"data":{"20:66:7":[{"f":"يُخَيَّلُ","r":"حظا اَطَل","n":"بتاء التأنيث"},{"f":"تُخَيَّلُ","r":"ميَ","n":"بتاء التأنيث"}],"20:69:5":[{"f":"تَلۡقَفۡ","r":"ع","n":"بفتح اللام وتشديد القاف"},{"f":"تَلَقَّفۡ","r":"حاز صلاَحَ ففَر","n":"بفتح اللام وتشديد القاف"},{"f":"تَّلَقَّفۡ","r":"ه","n":"بفتح اللام وتشديد القاف و تشديد التاء وصلاً"},{"f":"تَلَقَّفُ","r":"م","n":"بفتح اللام وتشديد القاف وضم الفاء"}],"20:69:11":[{"f":"سَٰحِرٖ","r":"ادحكناَحَ","n":"كسر السين وسكون الحاء دون ألف"},{"f":"سِحۡرٖ","r":"فرفَ","n":"كسر السين وسكون الحاء دون ألف"}],"20:71:2":[{"f":"ءامنتم","r":"عز طَ"},{"f":"ءأامنتم","r":"صف ريَفَ"},{"f":"ءاْامنتم","r":"حكاها"}],"20:75:2":[{"f":"يأتهِۦ","r":"ب² ط ذا يَداَ"},{"f":"يأتهِ","r":"ب² طَ"},{"f":"ياتهْ","r":"ي"}]}}