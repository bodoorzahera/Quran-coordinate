{"page":499,"data":{"45:1:1":[{"f":"حمٓ","r":"ادحكنفرحَفَ","n":"بالسكت على حرفيه"}],"45:5:17":[{"f":"ٱلرِّيَٰحِ","r":"ادحكناَحَ","n":"سكون الياء دون الألف"},{"f":"ٱلرِّيحِ","r":"فرفَ","n":"سكون الياء دون الألف"}],"45:6:12":[{"f":"يُؤۡمِنُونَ","r":"ادحعاَىَ","n":"بتاء الخطاب (والبدل واضح)"},{"f":"تُؤۡمِنُونَ","r":"كصفرطَفَ","n":"بتاء الخطاب (والبدل واضح)"}],"45:9:7":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"45:11:10":[{"f":"رِّجۡزٍ أَلِيمٌ","r":"دعحَ","n":"بالخفض"},{"f":"رِّجۡزٍ أَلِيمٍ","r":"احكصفراَفَ","n":"بالخفض"}]}}