{"page":129,"data":{"6:10:1":[{"f":"وَلَقَدِ ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"وَلَقَدُ","r":"ااَردفَك","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"وَلَقَدِ","r":"فن ح حَ"}],"6:10:2":[{"f":"ٱسۡتُهۡزِئَ ","r":"ادحمنرحَفَ","n":"إبدال الهمزة بياء مفتوحة وصلا"},{"f":"ٱسۡتُهۡزِيَ","r":"اَ","n":"إبدال الهمزة بياء مفتوحة وصلا"},{"f":"ٱسۡتُهۡزِئَ","r":"ادحمنرحَفَ"}],"6:16:2":[{"f":"يُصۡرَفۡ","r":"حكا دعاَ","n":"بفتح الياء وكسر الراء"},{"f":"يَصۡرِفۡ","r":"فصرفَ حَ","n":"بفتح الياء وكسر الراء"}]}}