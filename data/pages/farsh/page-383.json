{"page":383,"data":{"27:66:2":[{"f":"بَلِ ٱدَّٰرَكَ","r":"اكنفرفَ","n":"بسكون اللام والدال وفتح الهمزة دون ألف"},{"f":"بَلۡ أَدۡرَكَ","r":"دحاَحَ","n":"بسكون اللام والدال وفتح الهمزة دون ألف"}],"27:67:4":[{"f":"أَءِذَا","r":"دحكنفرحَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِذَا","r":"ااَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"27:67:8":[{"f":"أَئِنَّا","r":"ادحنفاَحَفَ","n":"همزة مكسورة ونونين الأولى مشددة"}],"27:70:7":[{"f":"ضَيۡقٖ","r":"احكنفراَحَفَ","n":"بكسر الضاد"},{"f":"ضِيقٖ","r":"د","n":"بكسر الضاد"}],"27:76:3":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"دف","n":"بالنقل"}]}}