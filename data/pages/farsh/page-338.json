{"page":338,"data":{"22:47:14":[{"f":"تَعُدُّونَ","r":"أكان ح حَ","n":"بالياء"},{"f":"يَعُدُّونَ","r":"ففَرد","n":"بالياء"}],"22:48:1":[{"f":"وَكَأَيِّن","r":"احكنفراَحَفَ","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآئِن","r":"د","n":"بألف وهمزة مكسورة تمد على المتصل دون ياء"},{"f":"وَكَآىٜن","r":"اَ","n":"بتسهيل الهمزة المكسورة مع مد وقصر"},{"f":"وَكَأَيّنْ","r":"ححَ","n":"الوقوف على الياء"},{"f":"وَكَا۬يِّن","r":"ف","n":"الوقوف بتسهيل الهمزة المفتوحة وبعدها ياء"}],"22:48:6":[{"f":"وَهِيَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡيَ","r":"بحراَ","n":"بسكون الهاء"}],"22:51:5":[{"f":"مُعَٰجِزِينَ","r":"اذاَحَ","n":"بتشديد الجيم دون ألف"},{"f":"مُعَجِّزِينَ","r":"حد","n":"بتشديد الجيم دون ألف"}],"22:52:8":[{"f":"نَبِيٍّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"نَبِيٓءٍ","r":"ا","n":"بالهمز فيمد على المتصل"}],"22:52:15":[{"f":"أُمۡنِيَّتِهِ","r":"ادحكنفرحَفَ","n":"بالتخفيف"},{"f":"أُمۡنِيَتِهِ","r":"اَ","n":"بالتخفيف"}],"22:54:20":[{"f":"صِرَٰطٖ ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"},{"f":"صِرَٰطٖ","r":"اهحكنفراَىَفَ"}]}}