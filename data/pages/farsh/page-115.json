{"page":115,"data":{"5:42:4":[{"f":"لِلسُّحۡتِ","r":"اكففَن","n":"ضم الحاء"},{"f":"لِلسُّحُتِ","r":"حد حَاَر","n":"ضم الحاء"}],"5:44:9":[{"f":"ٱلنَّبِيُّونَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓـُٔونَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"5:45:7":[{"f":"وَٱلۡعَيۡنَ وَٱلۡأَنفَ \nوَٱلۡأُذُنَ وَٱلسِّنَّ","r":"ادحكنفاَحَفَ","n":"بالرفع"},{"f":"وَٱلۡعَيۡنُ وَٱلۡأَنفُ \nوَٱلۡأُذُنُ وَٱلسِّنُّ","r":"ر","n":"بالرفع"}],"5:45:11":[{"f":"وَٱلۡأُذُنَ بِٱلۡأُذُنِ","r":"دحكنفراَحَفَ","n":"بإسكان الذال"},{"f":"وَٱلۡأُذۡنَ بِٱلۡأُذۡنِ","r":"ا","n":"بإسكان الذال"}],"5:45:15":[{"f":"وَٱلۡجُرُوحَ","r":"انف حَفَ","n":"بالرفع"},{"f":"وَٱلۡجُرُوحُ","r":"حكا در","n":"بالرفع"}],"5:45:20":[{"f":"فَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}]}}