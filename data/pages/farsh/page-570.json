{"page":570,"data":{"70:42:5":[{"f":"يُلَٰقُواْ","r":"ادحكنفرحَفَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"},{"f":"يَلۡقَوۡاْ","r":"اَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"}],"70:43:8":[{"f":"نُصُبٖ","r":"كع","n":"بفتح النون وسكون الصاد"},{"f":"نَصۡبٖ","r":"فحصد فَاراَحَ","n":"بفتح النون وسكون الصاد"}],"71:3:2":[{"f":"أَنِ ٱعۡبُدُواْ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱعۡبُدُواْ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}]}}