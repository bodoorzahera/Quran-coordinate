{"page":539,"data":{"57:13:7":[{"f":"ٱنظُرُونَا","r":"ادحكنراَحَفَ","n":"بهمزة قطع مفتوحة وكسر الظاء"},{"f":"أَنظِرُونَا","r":"ف","n":"بهمزة قطع مفتوحة وكسر الظاء"}],"57:13:11":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"57:14:13":[{"f":"ٱلۡأَمَانِيُّ ","r":"ادحكنفرحَفَ","n":"بسكون الياء"},{"f":"ٱلۡأَمَانِي","r":"اَ","n":"بسكون الياء"},{"f":"ٱلۡأَمَانِيُّ","r":"ادحكنفرحَفَ"}],"57:15:3":[{"f":"يُؤۡخَذُ","r":"ادحنفرفَ","n":"بتاء التأنيث (والإبدال واضح)"},{"f":"تُؤۡخَذُ","r":"كاَحَ","n":"بتاء التأنيث (والإبدال واضح)"}],"57:16:11":[{"f":"نَزَلَ","r":"اع","n":"بتشديد الزاي"},{"f":"نَزَّلَ","r":"حصاَدك ففَرحَ","n":"بتشديد الزاي"}],"57:16:15":[{"f":"يَكُونُواْ","r":"ادحكنفراَىَفَ","n":"بتاء الخطاب"},{"f":"تَكُونُواْ","r":"طَ","n":"بتاء الخطاب"}],"57:18:2":[{"f":"ٱلۡمُصَّدِّقِينَ وَٱلۡمُصَّدِّقَٰتِ","r":"اراَكع فح فَحَ","n":"بتخفيف الصاد"},{"f":"ٱلۡمُصَدِّقِينَ وَٱلۡمُصَدِّقَٰتِ","r":"صد","n":"بتخفيف الصاد"}],"57:18:8":[{"f":"يُضَٰعَفُ","r":"احث","n":"تشديد العين وحذف الألف"},{"f":"يُضَعِّفُ","r":"كاَدحَ","n":"تشديد العين وحذف الألف"}]}}