{"page":138,"data":{"6:83:8":[{"f":"دَرَجَٰتٖ","r":"ثحَ","n":"دون تنوين"},{"f":"دَرَجَٰتِ","r":"احاَدك","n":"دون تنوين"}],"6:85:1":[{"f":"وَزَكَرِيَّا","r":"فعرفَ","n":"بهمزة مفتوحة بعد الألف"},{"f":"وَزَكَرِيَّآءَ","r":"اكداَ صححَ","n":"بهمزة مفتوحة بعد الألف"}],"6:86:2":[{"f":"وَٱلۡيَسَعَ","r":"أكدناَ ح حَ","n":"بتشديد اللام  وسكون الياء"},{"f":"وَٱلَّيۡسَعَ","r":"ففَر","n":"بتشديد اللام  وسكون الياء"}],"6:87:8":[{"f":"صِرَٰطٖ","r":"ادحكنقراَحَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"}],"6:89:6":[{"f":"وَٱلنُّبُوَّةَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"وَالنُّبُوٓءَةَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"6:90:6":[{"f":"ٱقۡتَدِهۡ","r":"ادحكناَ","n":"بحذف الهاء وصلا"},{"f":"ٱقۡتَدِه۠","r":"فرحَفَ","n":"بحذف الهاء وصلا"},{"f":"ٱقۡتَدِهِ","r":"ل","n":"بكسر الهاء"},{"f":"ٱقۡتَدِهِۦ","r":"م","n":"بكسر الهاء مع صلة"},{"f":"ٱقۡتَدِهۡ   (وصلا)","r":"احدناَ"},{"f":"ٱقۡتَدِ    (وصلا)","r":"ففَرحَ"},{"f":"ٱقۡتَدِهِ   (وصلا)","r":"ل"},{"f":"ٱقۡتَدِهِۦ  (وصلا)","r":"م"},{"f":"ٱقۡتَدِهۡ   (وقفا)","r":"جميع القراء"}]}}