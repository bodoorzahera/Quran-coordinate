{"page":428,"data":{"34:3:11":[{"f":"عَٰلِمِ","r":"حيَ فدن","n":"ألف بعد العين ورفع الميم"},{"f":"عَٰلِمُ","r":"اكاَطَ","n":"ألف بعد العين ورفع الميم"},{"f":"عَلَّٰمِ","r":"فر","n":"بتشديد اللام وألف بعدها وخفض الميم"}],"34:3:14":[{"f":"يَعۡزُبُ","r":"ادحكنفاَحَفَ","n":"بكسر الزاي"},{"f":"يَعۡزِبُ","r":"ر","n":"بكسر الزاي"}],"34:5:5":[{"f":"مُعَٰجِزِينَ","r":"اكنفراَحَفَ","n":"بتشديد الجيم وحذف الألف"},{"f":"مُعَجِّزِينَ","r":"دح","n":"بتشديد الجيم وحذف الألف"}],"34:5:11":[{"f":"أَلِيمٞ","r":"دع حَ","n":"بكسر الميم"},{"f":"أَلِيمٖ","r":"حر افاَصفَك","n":"بكسر الميم"}],"34:6:14":[{"f":"صِرَٰطِ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"صِۜرَٰطِ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطِ","r":"ض","n":"بإشمام الصاد زاياً"}]}}