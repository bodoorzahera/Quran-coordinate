{"page":541,"data":{"57:25:3":[{"f":"رسْلنا","r":"ح"},{"f":"رسُلنا","r":""}],"57:26:4":[{"f":"وَإِبۡرَٰهِيمَ","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"وَإِبۡرَٰهَىٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}],"57:26:8":[{"f":"ٱلنُّبُوَّةَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"النُّبُوٓءَةَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"57:27:5":[{"f":"برسُلنا","r":""},{"f":"برسْلنا","r":"ح"}],"57:27:26":[{"f":"رِضۡوَٰنِ","r":"ادحكعفراَحَفَ","n":"بضم الراء"},{"f":"رُضۡوَٰنِ","r":"ص","n":"بضم الراء"}]}}