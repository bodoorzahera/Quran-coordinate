{"page":365,"data":{"25:59:15":[{"f":"فسئَل","r":"كفاناَ ح حَ"},{"f":"فسَل","r":"ردفَ"},{"f":"فَسۡـَٔلۡ","r":"احكناَحَ","n":"بالنقل"},{"f":"فَسَلۡ","r":"دفرفَ","n":"بالنقل"}],"25:60:2":[{"f":"قِيل","r":""},{"f":"قُيل","r":"رطَل"},{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"25:60:11":[{"f":"تأمرنا","r":"احنفَك اَحَد"},{"f":"ياأمرنا","r":"فر"},{"f":"تَأۡمُرُنَا","r":"ادحكناَحَفَ","n":"بياء الغيب (والإبدال واضح)"},{"f":"يَأۡمُرُنَا","r":"فر","n":"بياء الغيب (والإبدال واضح)"}],"25:61:9":[{"f":"سِرَاجا","r":"أكدناَ ح حَ"},{"f":"سُرُجا","r":"ففَر"},{"f":"سِرَٰجٗا","r":"ادحكناَحَ","n":"بضم السين والراء دون ألف"},{"f":"سُرُجٗا","r":"فرفَ","n":"بضم السين والراء دون ألف"}],"25:62:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"25:62:10":[{"f":"يذَّكَّر","r":"أدركناَ ح حَ"},{"f":"يذْكُر","r":"ف فَ"},{"f":"يَذَّكَّرَ","r":"ادحكنراَحَ","n":"بسكون الذال وضم وتخفيف الكاف"},{"f":"يَذۡكُرَ","r":"ففَ","n":"بسكون الذال وضم وتخفيف الكاف"}],"25:67:7":[{"f":"يَقتُروا","r":"ث"},{"f":"يُقتِروا","r":"اكاَد"},{"f":"يَقتِروا","r":"حد حَ"},{"f":"يَقۡتُرُواْ","r":"اكنفراَفَ","n":"بفتح الياء وكسر التاء"},{"f":"يَقۡتِرُواْ","r":"دححَ","n":"بفتح الياء وكسر التاء"},{"f":"يُقۡتِرُواْ","r":"اكاَ","n":"بضم الياء وكسر التاء"}]}}