{"page":490,"data":{"43:11:10":[{"f":"مَّيۡتٗا","r":"ادحكنفرحَفَ","n":"بكسر وتشديد الياء"},{"f":"مَيِّتٗا","r":"اَ","n":"بكسر وتشديد الياء"}],"43:11:12":[{"f":"تُخۡرَجُونَ","r":"ادحلناَحَ","n":"بفتح التاء وضم الراء (الفعل للفاعل)"},{"f":"تَخۡرُجُونَ","r":"مفرفَ","n":"بفتح التاء وضم الراء (الفعل للفاعل)"}],"43:15:5":[{"f":"جُزۡءًا","r":"ادحكعفراَحَفَ","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزُءًا","r":"ص","n":"بضم الزاي وتحقيق الهمز"},{"f":"جُزًّا","r":"اَ","n":"تشديد الزاي دون همز"},{"f":"جُزَا","r":"ف","n":"الإبدال"}],"43:18:2":[{"f":"يُنَشَّؤُاْ","r":"عفرفَ","n":"بفتح الياء وسكون النون وتخفيف الشين"},{"f":"يَنشَؤُاْ","r":"ادحكصاَحَ","n":"بفتح الياء وسكون النون وتخفيف الشين"}],"43:19:5":[{"f":"عِبَٰدُ","r":"حنفرفَ","n":"بنون ساكنة وفتح الدال دون ألف (ظرف)"}],"43:19:8":[{"f":"أَشَهِدُواْ","r":"دحكنفرحَفَ","n":"بزيادة بهمزة مضمومة مسهلة مع سكون الشين (الإدخال وجه لقالون)"},{"f":"أَ•شۡهِدُواْ","r":"ااَ","n":"بزيادة بهمزة مضمومة مسهلة مع سكون الشين (الإدخال وجه لقالون)"}]}}