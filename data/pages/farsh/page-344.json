{"page":344,"data":{"23:29:4":[{"f":"مُنزَلٗا","r":"ادحكعفراَحَفَ","n":"بفتح الميم وكسر الزاي"},{"f":"مَنزِلٗا","r":"ص","n":"بفتح الميم وكسر الزاي"}],"23:32:6":[{"f":"أَنِ ٱعۡبُدُواْ ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱعۡبُدُواْ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنِ ٱعۡبُدُواْ","r":"حنفحَ"}],"23:32:11":[{"f":"مِّنۡ إِلَٰهٍ غَيۡرُهُ","r":"ادحكنفحَفَ","n":"بكسر الراء والهاء"},{"f":"مِّنۡ إِلَٰهٍ غَيۡرِهِ","r":"راَ","n":"بكسر الراء والهاء"}],"23:35:4":[{"f":"مِتُّمۡ","r":"اعفرفَ","n":"بضم الميم الأولى"},{"f":"مُتُّمۡ ","r":"دحكصاَحَ","n":"بضم الميم الأولى"},{"f":"مُتُّمۡ","r":"دحكصاَحَ"}],"23:36:1":[{"f":"هَيۡهَاتَ (معا)","r":"ادحكنفرحَفَ","n":"بكسر التاء"},{"f":"هَيۡهَاتِ","r":"اَ","n":"بكسر التاء"},{"f":"هَيۡهَاتَ","r":"ازحكنفاَحَفَ","n":"يقف بالهاء"},{"f":"هَيۡهَاةَ (نطق دون الرسم)","r":"هر","n":"يقف بالهاء"}]}}