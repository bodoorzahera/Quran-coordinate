{"page":89,"data":{"4:66:6":[{"f":"أَنِ ٱقۡتُلُوٓاْ","r":"فن ح حَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱقۡتُلُوٓاْ","r":"ااَردفَك","n":"وضمك أولى الساكنين لثالث يضم"}],"4:66:9":[{"f":"أَوِ ٱخۡرُجُواْ","r":"فن","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَوُ ٱخۡرُجُواْ","r":"ااَردفَك ح حَ","n":"وضمك أولى الساكنين لثالث يضم"}],"4:66:15":[{"f":"إِلَّا قَلِيلٌ","r":"ادحنفراَحَفَ","n":"بالنصب"},{"f":"إِلَّا قَلِيلًا","r":"ك","n":"بالنصب"}],"4:68:2":[{"f":"صِرَٰطٗا","r":"ادحكنقراَحَفَ","n":"بالسين"},{"f":"صِۜرَٰطٗا","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٗا","r":"ض","n":"بإشمام الصاد زاياً"}],"4:69:12":[{"f":"ٱلنَّبِيِّ‍ۧنَ","r":"دحكنفراَحَفَ","n":"بالهمز مكان الياء"},{"f":"ٱلنَّبِيٓـِٕـۧنَ","r":"ا","n":"بالهمز مكان الياء"}],"4:73:9":[{"f":"لَّمۡ تَكُنۢ","r":"دع طَ","n":"بالياء (بالتذكير)"},{"f":"لَّمۡ يَكُنۢ","r":"احر صيَف كفَاَ","n":"بالياء (بالتذكير)"}]}}