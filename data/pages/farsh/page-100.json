{"page":100,"data":{"4:135:29":[{"f":"تَلۡوُۥٓاْ","r":"احدناَ حرفَ","n":"بضم اللام وواو ساكنة بعدها"},{"f":"تَلُوۥٓاْ","r":"فك","n":"بضم اللام وواو ساكنة بعدها"}],"4:136:9":[{"f":"نَزَّلَ - أَنزَلَ","r":"ااَحَن","n":"ضم النون وكسر الزاي - ضم الهمزة وكسر الزاي"},{"f":"نُزِّلَ - أُنزِلَ","r":"حدك","n":"ضم النون وكسر الزاي - ضم الهمزة وكسر الزاي"}],"4:140:1":[{"f":"وَقَدۡ نَزَّلَ","r":"نحَ","n":"ضم النون وكسر الزاي"},{"f":"وَقَدۡ نُزِّلَ","r":"احاَد فكفَر","n":"ضم النون وكسر الزاي"}]}}