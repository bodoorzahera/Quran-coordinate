{"page":524,"data":{"52:18:1":[{"f":"فَٰكِهِينَ","r":"ادحكنفرحَفَ","n":"بحذف الألف"},{"f":"فَكِهِينَ","r":"اَ","n":"بحذف الألف"}],"52:21:3":[{"f":"وَٱتَّبَعَتۡهُمۡ","r":"ادكنفراَحَفَ","n":"بفتح الهمزة وسكون التاء والعين وبنون وألف"},{"f":"وَأَتۡبَعۡنَٰهُمۡ","r":"ح","n":"بفتح الهمزة وسكون التاء والعين وبنون وألف"}],"52:21:4":[{"f":"ذُرِّيَّتُهُم","r":"اظاَ","n":"بكسر التاء وألف قبلها (جمع ونصب)"},{"f":"ذُرِّيَّٰتِهُمۡ","r":"ح","n":"بكسر التاء وألف قبلها (جمع ونصب)"},{"f":"ذُرِّيَّٰتُهُمۡ","r":"ك","n":"بضم التاء وألف قبلها (جمع ورفع)"},{"f":"بِهِمۡ ذُرِّيَّتَهُمۡ","r":"ظ","n":"بكسر التاء وألف قبلها (جمع)"},{"f":"بِهِمۡ ذُرِّيَّٰتِهُمۡ","r":"احكاَ حَ","n":"بكسر التاء وألف قبلها (جمع)"}],"52:21:10":[{"f":"أَلَتۡنَٰهُم","r":"احكنفراَحَفَ","n":"بكسر اللام"},{"f":"أَلِتۡنَٰهُم","r":"د","n":"بكسر اللام"}],"52:23:5":[{"f":"لَغۡوٞ -تَأۡثِيمٞ","r":"اكنفراَفَ","n":"بفتح الواو والميم دون تنوين"},{"f":"لَغۡوَ -تَأۡثِيمَ","r":"حد حَ","n":"بفتح الواو والميم دون تنوين"}],"52:28:6":[{"f":"إِنَّهُ","r":"دحكنفحَفَ","n":"بفتح الهمزة"},{"f":"أَنَّهُ","r":"اراَ","n":"بفتح الهمزة"}]}}