{"page":98,"data":{"4:122:18":[{"f":"أَصۡدَقُ","r":"احن يداَك","n":"بإشمام الصاد زاياً"},{"f":"أَصۡـؗدَقُ","r":"ففَرطَ","n":"بإشمام الصاد زاياً"}],"4:123:2":[{"f":"بِأَمَانِيِّكُمۡ - أَمَانِيِّ","r":"ادحكنفرحَفَ","n":"بسكون الياء فيهما"},{"f":"بِأَمَانِيكُمۡ - أَمَانِي","r":"اَ","n":"بسكون الياء فيهما"}],"4:124:9":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاق","n":"بسكون الهاء"}],"4:124:12":[{"f":"يَدۡخُلُونَ","r":"اعف طَرفَك","n":"بضم الياء وفتح الخاء"},{"f":"يُدۡخَلُونَ","r":"حصاَديَ","n":"بضم الياء وفتح الخاء"}],"4:125:12":[{"f":"إِبۡرَٰهِ‍ۧمَ (معا)","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}]}}