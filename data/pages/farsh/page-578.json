{"page":578,"data":{"75:27:1":[{"f":"وَقِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"وَقـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"75:27:3":[{"f":"مَنۡۜ رَاقٖ","r":"ع","n":"بالإدغام"},{"f":"مَن رَّاقٖ","r":"ادحكصفراَحَفَ","n":"بالإدغام"}],"75:36:1":[{"f":"أَيَحۡسَبُ","r":"كنفاَ","n":"كسر السين"},{"f":"أَيَحۡسِبُ","r":"ادحرحَفَ","n":"كسر السين"}],"75:37:6":[{"f":"يُمۡنَىٰ","r":"ع حَ","n":"بالتاء"},{"f":"تُمۡنَىٰ","r":"احصاَدك ففَر","n":"بالتاء"}],"76:4:4":[{"f":"سَلَٰسِلَاْ","r":"دحمعفحَفَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"سَلَٰسِلٗا","r":"الصراَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"سَلَٰسِلَا۠","r":"هحمعىَ","n":"الوقف بالألف"}]}}