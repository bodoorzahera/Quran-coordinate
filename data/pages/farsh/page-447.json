{"page":447,"data":{"37:25:4":[{"f":"لَا تَنَاصَرُونَ","r":"ازحكنفرحَفَ","n":"بتشديد التاء فتمد الألف قبلها مشبعاً"},{"f":"لَآ تَّنَاصَرُونَ","r":"هاَ","n":"بتشديد التاء فتمد الألف قبلها مشبعاً"}],"37:35:4":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"37:40:4":[{"f":"ٱلۡمُخۡلَصِينَ","r":"انفراَفَ","n":"بكسر اللام"},{"f":"ٱلۡمُخۡلِصِينَ","r":"دحكحَ","n":"بكسر اللام"}],"37:47:7":[{"f":"يُنزَفُونَ","r":"ادحكناَحَ","n":"بكسر الزاي"},{"f":"يُنزِفُونَ","r":"فرفَ","n":"بكسر الزاي"}]}}