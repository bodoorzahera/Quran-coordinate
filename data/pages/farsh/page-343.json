{"page":343,"data":{"23:20:5":[{"f":"سَيۡنَآءَ","r":"ذحَ","n":"بكسر السين"},{"f":"سِينَآءَ","r":"احاَد","n":"بكسر السين"}],"23:20:6":[{"f":"تَنۢبُتُ","r":"اذاَيَ","n":"بضم التاء وكسر الباء"},{"f":"تُنۢبِتُ","r":"حد طَ","n":"بضم التاء وكسر الباء"}],"23:21:6":[{"f":"نُّسۡقِيكُم","r":"حف در فع","n":"بفتح النون"},{"f":"نَّسۡقِيكُم","r":"اصحَك","n":"بفتح النون"},{"f":"تَّسۡقِيكُم","r":"اَ","n":"بتاء مفتوحة"}],"23:23:13":[{"f":"مِّنۡ إِلَٰهٍ غَيۡرُهُ","r":"ادحكنفحَفَ","n":"بكسر الراء والهاء"},{"f":"مِّنۡ إِلَٰهٍ غَيۡرِهِ","r":"راَ","n":"بكسر الراء والهاء"}],"23:27:15":[{"f":"مِن كُلّٖ","r":"ع","n":"بدون تنوين"},{"f":"مِن كُلِّ","r":"ادحكصفراَحَفَ","n":"بدون تنوين"}]}}