{"page":185,"data":{"8:65:8":[{"f":"وَإِن يَكُن مِّنكُم مِّاْئَةٞ","r":"غ","n":"بالتاء"},{"f":"وَإِن تَكُن مِّنكُم مِّاْئَةٞ","r":"اكاَد","n":"بالتاء"}],"8:66:8":[{"f":"ضَعۡفٗا","r":"ادحكنفرحَفَ","n":"ضم الضاد"},{"f":"ضُعۡفٗا","r":"أدرك ح حَ","n":"ضم الضاد"},{"f":"ضُعَفَاءَ","r":"اَ","n":"بضم الضاد وفتح العين وألف بعد الفاء وهمزة مفتوحة دون تنوين"}],"8:66:9":[{"f":"فَإِن يَكُن مِّنكُم مِّاْئَةٞ","r":"ث","n":"بالتاء"},{"f":"فَإِن تَكُن مِّنكُم مِّاْئَةٞ","r":"اكداَ ح حَ","n":"بالتاء"}],"8:67:5":[{"f":"يَكُونَ","r":"اذد","n":"بالتاء"},{"f":"تَكُونَ","r":"حاَحَ","n":"بالتاء"}],"8:67:7":[{"f":"أَسۡرَىٰ","r":"ادحكنفرحَفَ","n":"ضم الهمزة وفتح السين وألف بعدها"},{"f":"أُسَٰرَىٰ","r":"اَ","n":"ضم الهمزة وفتح السين وألف بعدها"}]}}