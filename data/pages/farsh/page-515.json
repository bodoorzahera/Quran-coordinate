{"page":515,"data":{"48:29:18":[{"f":"وَرِضۡوَٰنٗا","r":"ادحكعفراَحَفَ","n":"بضم الراء"},{"f":"وَرُضۡوَٰنٗا","r":"ص","n":"بضم الراء"}],"48:29:34":[{"f":"شَطۡـَٔهُ","r":"اغلاَ","n":"بفتح الطاء"},{"f":"شَطَـَٔهُ","r":"مد","n":"بفتح الطاء"}],"48:29:35":[{"f":"فَـَٔازَرَهُ","r":"ادحلنفراَحَفَ","n":"بحذف الألف"},{"f":"فَأَزَرَهُ","r":"م","n":"بحذف الألف"}],"48:29:39":[{"f":"سُوقِهِ","r":"اهحكنفراَحَفَ","n":"بهمز الواو"},{"f":"سُؤۡقِهِ","r":"ز","n":"بهمز الواو"},{"f":"سُـُٔوقِهِ","r":"ز","n":"بهمزة مضمومة قبل الواو"}],"49:1:5":[{"f":"تُقَدِّمُواْ","r":"ادحكنفراَفَ","n":"بفتح التاء والدال"},{"f":"تَقَدَّمُواْ","r":"حَ","n":"بفتح التاء والدال"}],"49:2:9":[{"f":"ٱلنَّبِيِّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓءِ","r":"ا","n":"بالهمز فيمد على المتصل"}],"49:4:6":[{"f":"ٱلۡحُجُرَٰتِ","r":"ادحكنفرحَفَ","n":"بفتح الجيم"},{"f":"ٱلۡحُجَرَٰتِ","r":"اَ","n":"بفتح الجيم"}]}}