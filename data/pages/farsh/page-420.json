{"page":420,"data":{"33:20:1":[{"f":"يَحۡسَبُونَ","r":"كنفاَ","n":"كسر السين"},{"f":"يَحۡسِبُونَ","r":"ادحرحَفَ","n":"كسر السين"}],"33:20:14":[{"f":"يَسۡـَٔلُونَ","r":"ادحكنفراَىَفَ","n":"بفتح وتشديد السين وألف بعدها"},{"f":"يَسَّـٰـَٔلُونَ","r":"طَ","n":"بفتح وتشديد السين وألف بعدها"}],"33:21:7":[{"f":"أُسۡوَةٌ","r":"ن","n":"بكسر الهمزة"},{"f":"إِسۡوَةٌ","r":"ادحكفراَحَفَ","n":"بكسر الهمزة"}]}}