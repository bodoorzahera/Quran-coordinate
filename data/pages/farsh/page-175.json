{"page":175,"data":{"7:188:23":[{"f":"أَنَا۠ إِلَّا","r":"جدحكنفراَحَفَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"أَنَآ إِلَّا","r":"ب","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}],"7:190:6":[{"f":"شُرَكَآءَ","r":"دحكعفرحَفَ","n":"بكسر الشين وسكون الراء وتنوين الكاف"},{"f":"شِرۡكٗا","r":"اصاَ","n":"بكسر الشين وسكون الراء وتنوين الكاف"}],"7:193:6":[{"f":"لَا يَتَّبِعُوكُمۡ","r":"دحكنفراَحَفَ","n":"بسكون التاء وفتح الباء"},{"f":"لَا يَتۡبَعُوكُمۡ","r":"ا","n":"بسكون التاء وفتح الباء"}],"7:195:8":[{"f":"يَبۡطِشُونَ","r":"ادحكنفرحَفَ","n":"بضم الطاء"},{"f":"يَبۡطُشُونَ","r":"اَ","n":"بضم الطاء"}],"7:195:21":[{"f":"قُلِ ٱدۡعُواْ","r":"نفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"قُلُ ٱدۡعُواْ","r":"ادحكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}]}}