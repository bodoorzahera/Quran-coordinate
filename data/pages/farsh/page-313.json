{"page":313,"data":{"20:13:1":[{"f":"وَأَنَا ٱخۡتَرۡتُكَ","r":"ادحكنراَحَفَ","n":"بتشديد النون ونون وألف"},{"f":"وَأَنَّا ٱخۡتَرۡنـٰكَ","r":"ف","n":"بتشديد النون ونون وألف"}],"20:31:1":[{"f":"ٱشۡدُدۡ","r":"ادحنفراَحَفَ","n":"بهمزة قطع مفتوحة"},{"f":"أَشۡدُدۡ","r":"ك","n":"بهمزة قطع مفتوحة"}],"20:32:1":[{"f":"وَأَشۡرِكۡهُ ","r":"ادحنفراَحَفَ","n":"بضم الهمزة"},{"f":"وَأُشۡرِكۡهُ ","r":"ك","n":"بضم الهمزة"},{"f":"وَأَشۡرِكۡهُ","r":"ادحنفراَحَفَ"},{"f":"وَأُشۡرِكۡهُ","r":"ك"}]}}