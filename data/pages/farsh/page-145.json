{"page":145,"data":{"6:132:9":[{"f":"يَعۡمَلُونَ","r":"ادحنفراَحَفَ","n":"بالخطاب"},{"f":"تَعۡمَلُونَ","r":"ك","n":"بالخطاب"}],"6:135:5":[{"f":"مَكَانَتِكُمۡ","r":"ادحكعفراَحَفَ","n":"بمد النون بألف الجمع قبل التاء"},{"f":"مَكَانَـٰتِكُمۡ","r":"ص","n":"بمد النون بألف الجمع قبل التاء"}],"6:135:11":[{"f":"تَكُونُ","r":"أكدناَ ح حَ","n":"بياء التذكير"},{"f":"يَكُونُ","r":"ففَر","n":"بياء التذكير"}],"6:136:12":[{"f":"بِزَعۡمِهِمۡ","r":"ادحكنفاَحَفَ","n":"بضم الزاي"},{"f":"بِزُعۡمِهِمۡ","r":"ر","n":"بضم الزاي"}],"6:136:25":[{"f":"فَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}],"6:137:7":[{"f":"زَيَّنَ -قَتۡلَ \nأَوۡلَٰدِهِمۡ شُرَكَآؤُهُمۡ","r":"ادحنفراَحَفَ","n":"ضم الزاي وكسر الياء ورفع قتل \nونصب أولاد وخفض شركاء"},{"f":"زُيِّنَ -قَتۡلُ \nأَوۡلَٰدَهِمۡ شُرَكَآئِهُمۡ","r":"ك","n":"ضم الزاي وكسر الياء ورفع قتل \nونصب أولاد وخفض شركاء"}]}}