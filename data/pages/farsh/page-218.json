{"page":218,"data":{"10:79:5":[{"f":"سَٰحِرٍ","r":"ادحكناَحَ","n":"بتشديد وفتح الحاء وتقديمها على الألف"},{"f":"سَحَّٰرٍ","r":"فرفَ","n":"بتشديد وفتح الحاء وتقديمها على الألف"}],"10:81:8":[{"f":"بِهِ ٱلسِّحۡرُ","r":"اذدحَ","n":"بهمزة قطع وإبدال همزة الوصل \nأو تسهيلها دون إدخال"},{"f":"بِهِۦٓ ءَآلسِّحۡرُ -\nبِهِۦٓ ءَا۬لسِّحۡرُ","r":"حاَ","n":"بهمزة قطع وإبدال همزة الوصل \nأو تسهيلها دون إدخال"}],"10:87:9":[{"f":"بُيُوتٗا -بُيُوتَكُمۡ","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"بِيُوتٗا -بِيُوتَكُمۡ","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}],"10:88:14":[{"f":"لِيُضِلُّواْ","r":"نفرفَ","n":"بفتح الياء"},{"f":"لِيَضِلُّواْ","r":"ادحكاَحَ","n":"بفتح الياء"}]}}