{"page":450,"data":{"37:106:3":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"37:112:3":[{"f":"نَبِيّٗا","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"نَبِيٓـٔٗا","r":"ا","n":"بالهمز فيمد على المتصل"}],"37:118:2":[{"f":"ٱلصِّرَٰطَ","r":"اهحكنفراَىَفَ","n":"بالسين"},{"f":"ٱلصِّۜرَٰطَ ","r":"زطَ","n":"بالسين"},{"f":"ٱلصـِّؗـرَٰطَ","r":"ض","n":"بإشمام الصاد زاياً"}],"37:123:2":[{"f":"إِلۡيَاسَ","r":"ادحلنفراَحَفَ","n":"بوصل الهمزة ويبدأ بفتحها"},{"f":"ٱلۡيَاسَ","r":"م²","n":"بوصل الهمزة ويبدأ بفتحها"}],"37:126:1":[{"f":"ٱللَّهَ رَبَّكُمۡ وَرَبَّ","r":"عف فَرحَ","n":"برفعهم"},{"f":"ٱللَّهُ رَبُّكُمۡ وَرَبُّ","r":"احصاَدك","n":"برفعهم"}]}}