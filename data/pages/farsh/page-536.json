{"page":536,"data":{"56:55:2":[{"f":"شُرۡبَ","r":"افناَ","n":"بفتح الشين"},{"f":"شَرۡبَ","r":"حر فَكدحَ","n":"بفتح الشين"}],"56:60:2":[{"f":"قَدَّرۡنَا","r":"احكنفراَحَفَ","n":"بتخفيف الدال"},{"f":"قَدَرۡنَا","r":"د","n":"بتخفيف الدال"}],"56:62:3":[{"f":"ٱلنَّشۡأَةَ","r":"اكنفراَحَفَ","n":"بفتح الشين وألف بعدها تمد على المتصل"},{"f":"ٱلنَّشَآءَةَ","r":"دح","n":"بفتح الشين وألف بعدها تمد على المتصل"}],"56:62:6":[{"f":"تَذَكَّرُونَ","r":"عفرفَ","n":"تشديد الذال"},{"f":"تَذَّكَّرُونَ","r":"ادحكصاَحَ","n":"تشديد الذال"}],"56:66:1":[{"f":"إِنَّا","r":"ادحكعفراَحَفَ","n":"بالاستفهام"},{"f":"أَءِنَّا","r":"ص","n":"بالاستفهام"}],"56:75:3":[{"f":"بِمَوَٰقِعِ","r":"ادحكناَحَ","n":"بسكون الواو دون ألف"},{"f":"بِمَوۡقِعِ","r":"فرفَ","n":"بسكون الواو دون ألف"}]}}