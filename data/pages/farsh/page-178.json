{"page":178,"data":{"8:9:11":[{"f":"مُرۡدِفِينَ","r":"دحكنفرفَ","n":"بفتح الدال"},{"f":"مُرۡدَفِينَ","r":"ااَحَ","n":"بفتح الدال"}],"8:11:2":[{"f":"يُغَشِّيكُمُ ٱلنُّعَاسَ","r":"دحكنفرحَفَ","n":"بفتح الياء والشين وتخفيفها وألف بعدها مع سكون الغين ورفع السين"},{"f":"يَغۡشَىٰكُمُ ٱلنُّعَاسُ","r":"دح","n":"بفتح الياء والشين وتخفيفها وألف بعدها مع سكون الغين ورفع السين"},{"f":"يُغۡشِيكُمُ ٱلنُّعَاسَ","r":"ااَ","n":"بضم الياء وسكون الغين وكسر وتخفيف الشين وياء بعدها ونصب السين"}],"8:11:6":[{"f":"وَيُنَزِّلُ","r":"اكنفراَفَ","n":"بتخفيف الزاي مع سكون النون"},{"f":"وَيُنزِلُ","r":"دححَ","n":"بتخفيف الزاي مع سكون النون"}],"8:12:16":[{"f":"ٱلرُّعۡبَ","r":"ادحنففَ","n":"بضم العين"},{"f":"ٱلرُّعُبَ","r":"كراَحَ","n":"بضم العين"}]}}