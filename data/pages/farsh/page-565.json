{"page":565,"data":{"68:22:2":[{"f":"أَنِ ٱغۡدُواْ","r":"حنفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"أَنُ ٱغۡدُواْ","r":"ادكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}],"68:32:4":[{"f":"يُبۡدِلَنَا","r":"كحَظ","n":"بتشديد الدال وفتح الباء"},{"f":"يُبَدِّلَنَا","r":"احاَ","n":"بتشديد الدال وفتح الباء"}],"68:38:4":[{"f":"لَمَا تَخَيَّرُونَ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء وصلا فتمد الألف مشبعاً"},{"f":"لَمَآ تَّخَيَّرُونَ","r":"ه","n":"بتشديد التاء وصلا فتمد الألف مشبعاً"}]}}