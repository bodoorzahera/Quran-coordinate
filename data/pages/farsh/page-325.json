{"page":325,"data":{"21:36:8":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"21:41:1":[{"f":"وَلَقَدِ","r":"فن ح حَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"ولقدُ","r":"ااَردفَك","n":"وضمك أولى الساكنين لثالث يضم"}],"21:41:2":[{"f":"ٱسۡتُهۡزِئَ","r":"ادحمنرحَفَ","n":"ابدال الهمزة بياء مفتوحة وصلا"},{"f":"ٱسۡتُهۡزِيَ","r":"اَ","n":"ابدال الهمزة بياء مفتوحة وصلا"}],"21:41:13":[{"f":"يستهزِءُون","r":""},{"f":"يستهزُون","r":"اَ"}]}}