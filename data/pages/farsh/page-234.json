{"page":234,"data":{"11:111:1":[{"f":"وَإِنَّ كُلّٗا لَّمَّا","r":"عفاَك","n":"بسكون النون وتخفيف الميم"},{"f":"وَإِن كُلّٗا لَّمَا","r":"اد","n":"بسكون النون وتخفيف الميم"},{"f":"وَإِن كُلّٗا لَّمَّا","r":"ص","n":"بسكون النون وتشديد الميم"},{"f":"وَإِنَّ كُلّٗا لَّمَا","r":"حر فَحَ","n":"بتشديد النون وتخفيف الميم"}],"11:114:5":[{"f":"وَزُلَفٗا","r":"ادحكنفرحَفَ","n":"بضم اللام"},{"f":"وَزُلُفٗا","r":"اَ","n":"بضم اللام"}],"11:116:8":[{"f":"بَقِيَّةٖ","r":"ادحكنفربَحَفَ","n":"بكسر الباء وسكون القاف وتخفيف الياء"},{"f":"بِقۡيَةٖ","r":"جَ","n":"بكسر الباء وسكون القاف وتخفيف الياء"}]}}