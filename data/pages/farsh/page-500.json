{"page":500,"data":{"45:14:10":[{"f":"لِيَجۡزِيَ","r":"احد حَن","n":"بنون مفتوحة وكسر الزاي وفتح الياء"},{"f":"لِنَجۡزِيَ","r":"فكفَر","n":"بنون مفتوحة وكسر الزاي وفتح الياء"},{"f":"لِيُجۡزَىٰ","r":"اَ","n":"بياء مضمومة وفتح الزاي وألف بعدها"}],"45:15:11":[{"f":"تُرۡجَعُونَ","r":"ادحكنفراَفَ","n":"بالتسمية للفاعل لا بالتجهيل"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بالتسمية للفاعل لا بالتجهيل"}],"45:16:7":[{"f":"وَٱلنُّبُوَّةَ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"وَالنُّبُوٓءَةَ","r":"ا","n":"بالهمز فيمد على المتصل"}],"45:21:12":[{"f":"سَوَآءٗ","r":"عفرفَ","n":"بالرفع"},{"f":"سَوَآءٞ","r":"ادحكصاَحَ","n":"بالرفع"}]}}