{"page":464,"data":{"39:53:8":[{"f":"تَقۡنَطُواْ ","r":"ادكنفاَ","n":"بكسر النون"},{"f":"تَقۡنِطُواْ ","r":"حرحَفَ","n":"بكسر النون"},{"f":"تَقۡنَطُواْ","r":"فاكدناَ"},{"f":"تَقۡنِطُواْ","r":"حرفَ حَ"}],"39:56:4":[{"f":"يَٰحَسۡرَتَىٰ ","r":"ادحكنفرحَفَ","n":"بإثبات ياء بعد الألف مع فتحها وصلاً"},{"f":"يَٰحَسۡرَتَـٰيَ","r":"اَ","n":"بإثبات ياء بعد الألف مع فتحها وصلاً"},{"f":"يَٰحَسۡرَتَـٰٓيۡ","r":"اَ","n":"بإسكان الياء فتمد الألف مشبعاً"},{"f":"يَٰحَسۡرَتَىٰ","r":"ادحكنفرحَفَ"}]}}