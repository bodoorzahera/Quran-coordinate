{"page":465,"data":{"39:61:1":[{"f":"وَيُنَجِّي","r":"ادحكنفراَطَفَ","n":"بتخفيف الجيم مع سكون النون"},{"f":"وَيُنجِي","r":"ىَ","n":"بتخفيف الجيم مع سكون النون"}],"39:61:5":[{"f":"بِمَفَازَتِهِمۡ","r":"ادحكعاَحَ","n":"بالجمع بألف قبل التاء"},{"f":"بِمَفَازَٰتِهِمۡ","r":"صفرفَ","n":"بالجمع بألف قبل التاء"}],"39:64:4":[{"f":"تَأۡمُرُوٓنِّيٓ","r":"ادحنفراَحَفَ","n":"بنونين مخففين مفتوحة ومكسورة"},{"f":"تَأۡمُرُونَنِيٓ","r":"ك","n":"بنونين مخففين مفتوحة ومكسورة"},{"f":"تَأۡمُرُونِيٓ","r":"ااَ","n":"بنون واحدة مخففة مكسورة"}]}}