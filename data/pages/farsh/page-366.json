{"page":366,"data":{"25:69:1":[{"f":"يضاعَفْ","r":"احر فعفَ"},{"f":"يضاعَفُ","r":"ص"},{"f":"يضعَّفُ","r":"ك"},{"f":"يضعَّفْ","r":"داَحَ"},{"f":"يُضَٰعَفۡ","r":"احكنفرفَ","n":"بحذف الألف وتشديد العين وسكون الفاء"},{"f":"يُضَعَّفۡ","r":"داَحَ","n":"بحذف الألف وتشديد العين وسكون الفاء"},{"f":"يُضَعَّفُ","r":"ك","n":"بحذف الألف وتشديد العين وضم الفاء"},{"f":"يُضَٰعَفُ","r":"ص","n":"بتخفيف العين وألف قبلها وضم الفاء"}],"25:69:6":[{"f":"يخلدْ","r":"رعد فاح فَاَحَ"},{"f":"يخلدُ","r":"صك"},{"f":"وَيَخۡلُدۡ","r":"ادحعفراَحَفَ","n":"بضم الدال"},{"f":"وَيَخۡلُدُ","r":"كص","n":"بضم الدال"}],"25:69:7":[{"f":"فيهِ ى","r":"دع"},{"f":"فيهِ","r":"صحف افَراَحَك"}],"25:74:8":[{"f":"ذرياتنا","r":"ادعاَك حَ"},{"f":"ذريتنا","r":"حر فصفَ"},{"f":"وَذُرِّيَّٰتِنَا","r":"ادكعاَحَ","n":"بالتوحيد"},{"f":"وَذُرِّيَّتِنَا","r":"حصفرفَ","n":"بالتوحيد"}],"25:75:6":[{"f":"يُلَقَّون","r":"ادعاَك ح حَ"},{"f":"يَلْقَون","r":"فصرفَ"},{"f":"وَيُلَقَّوۡنَ","r":"ادحكعاَحَ","n":"بفتح الياء وسكون اللام وتخفيف القاف"},{"f":"وَيَلۡقَوۡنَ","r":"صفرفَ","n":"بفتح الياء وسكون اللام وتخفيف القاف"}]}}