{"page":213,"data":{"10:35:6":[{"f":"لَّا يَهِدِّيٓ","r":"ادحكعفراَحَفَ","n":"بكسر الياء والهاء وتشديد الدال"},{"f":"لَّا يِهِدِّيٓ","r":"ص","n":"بكسر الياء والهاء وتشديد الدال"},{"f":"لَّا يَهَدِّيٓ","r":"جدك","n":"بفتح الياء والهاء وتشديد الدال"},{"f":"لَّا يَهۡدِّيٓ","r":"باَ","n":"بفتح الياء وسكون الهاء وتشديد الدال"},{"f":"لَّا يَه۬دِّيٓ","r":"بح","n":"بفتح الياء واختلاس فتح الهاء وتشديد الدال"},{"f":"لَّا يَهۡدِيٓ","r":"ففَر","n":"بفتح الياء وسكون الهاء وتخفيف الدال"}],"10:37:4":[{"f":"ٱلۡقُرۡءَانُ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانُ","r":"د","n":"بالنقل"}],"10:37:11":[{"f":"تَصۡدِيقَ","r":"احن يداَك","n":"بإشمام الصاد زاياً"},{"f":"تَصۡـؗدِيقَ","r":"ففَرطَ","n":"بإشمام الصاد زاياً"}]}}