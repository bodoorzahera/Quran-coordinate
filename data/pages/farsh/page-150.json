{"page":150,"data":{"6:158:5":[{"f":"تَأۡتِيَهُمُ","r":"أكدناَ ح حَ","n":"بالياء"},{"f":"يَأۡتِيَهُمُ","r":"ففَر","n":"بالياء"}],"6:159:3":[{"f":"فَرَّقُواْ","r":"احنفَك اَحَد","n":"بتخفيف الراء وألف قبلها"},{"f":"فَٰرَقُواْ","r":"فر","n":"بتخفيف الراء وألف قبلها"}],"6:160:6":[{"f":"عَشۡرُ أَمۡثَالِهَا","r":"ادحكنفراَفَ","n":"بتنوين الراء ورفع اللام"},{"f":"عَشۡرٌ أَمۡثَالُهَا","r":"حَ","n":"بتنوين الراء ورفع اللام"}],"6:161:6":[{"f":"صِرَٰطٖ","r":"ادحكنقراَحَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"}],"6:161:9":[{"f":"قِيَمٗا","r":"ذ","n":"بفتح القاف وكسر وتشديد الياء"},{"f":"قَيِّمٗا","r":"اداَ ح حَ","n":"بفتح القاف وكسر وتشديد الياء"}],"6:161:11":[{"f":"إِبۡرَٰهِ‍ۧمَ","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"إِبۡرَٰهَ‍ٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}],"6:162:5":[{"f":"وَمَحۡيَايَ ","r":"دحكنفرحَفَ","n":"بإسكان الياء مع المد المشبع لالتقاء الساكنين"},{"f":"وَمَحۡيَآيۡ","r":"ااَ","n":"بإسكان الياء مع المد المشبع لالتقاء الساكنين"},{"f":"وَمَحۡيَايَ وَمَمَاتِي","r":"غدك"},{"f":"وَمَحۡيَايَ وَمَمَاتِيَ","r":"ج²"},{"f":"وَمَحۡيَآيۡ وَمَمَاتِيَ","r":"ج² ااَ"},{"f":"وَمَحۡيَايَ","r":"دحكنفرحَفَ"}],"6:162:6":[{"f":"وَمَمَاتِي","r":"دحكنفرحَفَ","n":"بفتح الياء"},{"f":"وَمَمَاتِيَ","r":"ااَ","n":"بفتح الياء"}],"6:163:6":[{"f":"وَأَنَا۠","r":"غدك","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"وَأَنَآ","r":"ااَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}]}}