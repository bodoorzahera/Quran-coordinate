{"page":298,"data":{"18:36:11":[{"f":"مِّنۡهَا","r":"غ","n":"بزبادة ميم مفتوحة بعد الهاء على التثنية"},{"f":"مِّنۡهُمَا","r":"اكاَد","n":"بزبادة ميم مفتوحة بعد الهاء على التثنية"}],"18:38:1":[{"f":"لَّٰكِنَّا۠ ","r":"ادحنفرىَفَ","n":"بإثبات الألف مطلقا"},{"f":"لَّٰكِنَّا","r":"كاَطَ","n":"بإثبات الألف مطلقا"},{"f":"لَّٰكِنَّا۠","r":"احظيَ"}],"18:39:15":[{"f":"أَنَا۠","r":"دحكنفرحَفَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"أَنَآ","r":"ااَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}],"18:42:2":[{"f":"بِثَمَرِهِ","r":"ناَيَ","n":"بضم الثاء وسكون الميم"},{"f":"بِثُمۡرِهِ","r":"ح","n":"بضم الثاء وسكون الميم"},{"f":"بِثُمُرِهِ","r":"أردف كفَ طَ","n":"بضم الثاء والميم"}],"18:43:2":[{"f":"تَكُن","r":"ادحكناَحَ","n":"مذكر"},{"f":"يَكُن","r":"فرفَ","n":"مذكر"}],"18:44:2":[{"f":"ٱلۡوَلَٰيَةُ","r":"ادحكناَحَ","n":"بكسر الواو"},{"f":"ٱلۡوِلَٰيَةُ","r":"فرفَ","n":"بكسر الواو"}],"18:44:4":[{"f":"ٱلۡحَقِّ","r":"فكفَ أحدناَ","n":"بالرفع"},{"f":"ٱلۡحَقُّ","r":"حر","n":"بالرفع"}],"18:44:9":[{"f":"عُقۡبٗا","r":"ففَن","n":"بضم القاف"},{"f":"عُقُبٗا","r":"اراَدك ح حَ","n":"بضم القاف"}],"18:45:17":[{"f":"ٱلرِّيَٰحُ","r":"ادحكناَحَ","n":"سكون الياء دون الألف"},{"f":"ٱلرِّيحُ","r":"فرفَ","n":"سكون الياء دون الألف"}]}}