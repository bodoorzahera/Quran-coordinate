{"page":418,"data":{"33:1:2":[{"f":"ٱلنَّبِيُّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"ٱلنَّبِيٓءُ","r":"ا","n":"بالهمز فيمد على المتصل"}],"33:2:11":[{"f":"تَعۡمَلُونَ","r":"ادكنفراَحَفَ","n":"بالياء"},{"f":"يَعۡمَلُونَ","r":"ح","n":"بالياء"}],"33:4:12":[{"f":"ٱلَّٰٓـِٔي","r":"ذ","n":"دون ياء وتحقيق الهمز"},{"f":"ٱلَّٰٓـِٔيْ","r":"بزحَ","n":"دون ياء وتحقيق الهمز"},{"f":"ٱلَّٰٓـِ۬يْ","r":"جحاَه","n":"دون ياء وتسهيل الهمزة مع مد وقصر"},{"f":"ٱلَّـٰٓيۡ","r":"جاَ","n":"دون ياء وإبدال الهمزة ياء ساكنة فتمد الألف مشبعاً"},{"f":"ٱلَّٰـِ۬يْ","r":"جهحاَ","n":"دون ياء وتسهيل بروم"},{"f":"ٱلَّـٰٓيْۡ","r":"حه"}],"33:4:13":[{"f":"تُظَٰهِرُونَ","r":"ن","n":"بفتح التاء والهاء وألف قبلها"},{"f":"تَظَٰهَرُونَ","r":"ففَر","n":"بفتح التاء والهاء وألف قبلها"},{"f":"تَظَّٰهَرُونَ","r":"ك","n":"بفتح التاء والهاء وألف قبلها وتشديد الظاء"},{"f":"تَظَّهَّرُونَ","r":"اداَ ح حَ","n":"بفتح التاء وفتح وتشديد الظاء والهاء دون ألف"}],"33:4:26":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"33:6:1":[{"f":"ٱلنَّبِيُّ أَوۡلَىٰ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل \nوإبدال الهمزة الثانية واو وصلا"},{"f":"ٱلنَّبِيٓءُ أَوۡلَىٰ\n(ٱلنَّبِيٓءُ وَوۡلَىٰ)","r":"ا","n":"بالهمز فيمد على المتصل \nوإبدال الهمزة الثانية واو وصلا"}]}}