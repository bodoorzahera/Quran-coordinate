{"page":37,"data":{"2:231:25":[{"f":"هُزُوٗا","r":"ادحكنراَحَفَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"2:233:23":[{"f":"تُضَآرَّ","r":"اذ","n":"سكون الراء"},{"f":"تُضَآرۡ","r":"اَ","n":"سكون الراء"},{"f":"تُضَآرُّ","r":"حد حَ","n":"رفع الراء مشددة"}],"2:233:55":[{"f":"ءَاتَيۡتُم","r":"احكنفراَحَفَ","n":"حذف الألف"},{"f":"أَتَيۡتُم","r":"د","n":"حذف الألف"}]}}