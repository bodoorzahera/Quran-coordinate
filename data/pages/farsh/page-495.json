{"page":495,"data":{"43:80:2":[{"f":"يَحۡسَبُونَ","r":"كنفاَ","n":"كسر السين"},{"f":"يَحۡسِبُونَ","r":"ادحرحَفَ","n":"كسر السين"}],"43:80:9":[{"f":"وَرُسُلُنَا","r":"ادكنفراَحَفَ","n":"بإسكان السين"},{"f":"وَرُسۡلُنَا","r":"ح","n":"بإسكان السين"}],"43:81:5":[{"f":"وَلَدٞ","r":"ادحكناَحَفَ","n":"بضم الواو وسكون اللام"},{"f":"وُلۡدٞ","r":"فر","n":"بضم الواو وسكون اللام"}],"43:81:6":[{"f":"فَأَنَا۠","r":"دحكنفرحَفَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"فَأَنَآ","r":"ااَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}],"43:83:5":[{"f":"يُلَٰقُواْ","r":"ادحكنفرحَفَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"},{"f":"يَلۡقَوۡاْ","r":"اَ","n":"بفتح الياء والقاف وسكون اللام دون ألف"}],"43:84:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"43:85:13":[{"f":"تُرۡجَعُونَ","r":"حكاناَ","n":"بالياء"},{"f":"يُرۡجَعُونَ","r":"ففَرد","n":"بالياء"},{"f":"يَرۡجِعُونَ","r":"طَ","n":"بياء مفتوحة وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"يَ","n":"بفتح التاء وكسر الجيم"}],"43:88:1":[{"f":"وَقِيلِهِ","r":"فن","n":"بفتح اللام وضم الهاء"},{"f":"وَقِيلَهُ","r":"احاَدك حَرفَ","n":"بفتح اللام وضم الهاء"}],"43:89:6":[{"f":"يَعۡلَمُونَ","r":"دحنفرحَفَ","n":"بتاء الخطاب"},{"f":"تَعۡلَمُونَ","r":"اكاَ","n":"بتاء الخطاب"}]}}