{"page":103,"data":{"4:155:7":[{"f":"وَقَتۡلِهِمُ","r":"ادحكناَ","n":"بكسر الهاء والميم (وسكون الميم وقفا)"},{"f":"وَقَتۡلِهِمِ","r":"حرفَ","n":"بكسر الهاء والميم (وسكون الميم وقفا)"},{"f":"وَقَتۡلِهُمُ","r":"فرحَفَ","n":"بضم الهاء والميم (وسكون الميم وقفا)"}],"4:155:8":[{"f":" ٱلۡأَنۢبِيَآءَ","r":"دحكنفراَحَفَ","n":"بالهمز مكان الياء"},{"f":" ٱلۡأَنۢبِئَآءَ","r":"ا","n":"بالهمز مكان الياء"},{"f":"ٱلۡأَنۢبِيَآءَ","r":"دحكنفراَحَفَ"},{"f":"ٱلۡأَنۢبِئَآءَ","r":"ا"}],"4:162:24":[{"f":"سَنُؤۡتِيهِمۡ","r":"أدركناَ ح حَ","n":"بالياء وكسر الياء"},{"f":"سَيُؤۡتِيهِمۡ","r":"ف فَ","n":"بالياء وكسر الياء"},{"f":"سَنُؤۡتِيهُمۡ","r":"حَ","n":"بالنون وضم الهاء"}]}}