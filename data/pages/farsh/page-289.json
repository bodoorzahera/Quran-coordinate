{"page":289,"data":{"17:68:3":[{"f":"يَخۡسِفَ -يُرۡسِلَ","r":"اذاَحَ","n":"بالنون"},{"f":"نَخۡسِفَ -نُرۡسِلَ","r":"حد","n":"بالنون"}],"17:69:4":[{"f":"يُعِيدَكُمۡ -فَيُرۡسِلَ","r":"اكنفراَحَفَ","n":"بالنون"},{"f":"نُعِيدَكُمۡ -فَنُرۡسِلَ","r":"دح","n":"بالنون"}],"17:69:12":[{"f":"ٱلرِّيحِ","r":"ادحكنفرحَفَ","n":"بفتح الياء وألف بعدها"},{"f":"ٱلرِّيَٰحِ","r":"اَ","n":"بفتح الياء وألف بعدها"}],"17:69:13":[{"f":"فَيُغۡرِقَكُم","r":"اكنفراَحَفَ","n":"بالنون"},{"f":"فَنُغۡرِقَكُم","r":"دح","n":"بالنون"},{"f":"فَتُغۡرِقَكُم","r":"اَطَ","n":"بالتاء"},{"f":"فَتُغَرِّقَكُم","r":"بَ","n":"بفتح الغين وتشديد الراء مع التأنيث"}],"17:72:6":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}