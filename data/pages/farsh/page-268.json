{"page":268,"data":{"16:7:9":[{"f":"بِشِقِّ","r":"ادحكنفرحَفَ","n":"بفتح الشين"},{"f":"بِشَقِّ","r":"اَ","n":"بفتح الشين"}],"16:7:13":[{"f":"لَرَءُوفٞ","r":"ادكعاَ","n":"بحذف الواو "},{"f":"لَرَؤُفٞ","r":"حصفرحَفَ","n":"بحذف الواو "}],"16:9:3":[{"f":"قَصۡدُ","r":"ادحكناَىَ","n":"بإشمام الصاد زاياً"},{"f":"قَصۡـؗدُ","r":"فرطَفَ","n":"بإشمام الصاد زاياً"}],"16:11:1":[{"f":"يُنۢبِتُ","r":"ادحكعفراَحَفَ","n":"بالنون"},{"f":"نُنۢبِتُ","r":"ص","n":"بالنون"}],"16:12:5":[{"f":"وَٱلشَّمۡسَ وَٱلۡقَمَرَ","r":"ادحنفراَحَفَ","n":"بالرفع"},{"f":"وَٱلشَّمۡسُ وَٱلۡقَمَرُ","r":"ك","n":"بالرفع"},{"f":"وَٱلشَّمۡسَ وَٱلۡقَمَرَ وَٱلنُّجُومُ مُسَخَّرَٰتُۢ","r":"ع"},{"f":"وَٱلشَّمۡسَ وَٱلۡقَمَرَ وَٱلنُّجُومَ مُسَخَّرَٰتِۭ","r":"ففَادح صرحَاَ"},{"f":"وَٱلشَّمۡسُ وَٱلۡقَمَرُ وَٱلنُّجُومُ مُسَخَّرَٰتُۢ","r":"ك"}],"16:12:7":[{"f":"وَٱلنُّجُومُ مُسَخَّرَٰتُۢ","r":"كع","n":"بالنصب (وكسر التاء الساكنة)"},{"f":"وَٱلنُّجُومَ مُسَخَّرَٰتِۭ","r":"ادحصفراَحَفَ","n":"بالنصب (وكسر التاء الساكنة)"}],"16:14:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}