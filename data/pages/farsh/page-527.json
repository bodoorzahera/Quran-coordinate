{"page":527,"data":{"53:32:3":[{"f":"كَبَٰٓئِرَ","r":"ادحكناَحَ","n":"بكسر الباء وياء بعدها دون همز ولا ألف"},{"f":"كَبِيِرَ","r":"فرفَ","n":"بكسر الباء وياء بعدها دون همز ولا ألف"}],"53:32:24":[{"f":"أُمَّهَٰتِكُمۡ","r":"ادحكنفاَحَفَ","n":"بكسر الهمزة"},{"f":"إِمَّهَٰتِكُمۡ","r":"ر","n":"بكسر الهمزة"},{"f":"إِمِّهَٰتِكُمۡ","r":"ف","n":"بكسر الهمزة والميم وصلا "}],"53:33:1":[{"f":"أَفَرَءَيۡتَ","r":"ادحكنفاَحَفَ","n":"بحذف الهمزة الثانية"},{"f":"أَفَرَيۡتَ","r":"ر","n":"بحذف الهمزة الثانية"},{"f":"أَفَرَٰ۬يۡتَ","r":"افاَ","n":"بالتسهيل"},{"f":"أَفَرَٰٓيۡتَ","r":"ج","n":"بالإبدال تمد مشبعا"}],"53:37:1":[{"f":"وَإِبۡرَٰهِيمَ","r":"ادحمنفراَحَفَ","n":"بفتح الهاء وألف بعدها"},{"f":"وَإِبۡرَٰهَىٰمَ","r":"ل","n":"بفتح الهاء وألف بعدها"}]}}