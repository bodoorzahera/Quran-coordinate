{"page":208,"data":{"10:1:1":[{"f":"الٓر","r":"ادحكنفرحَفَ","n":"بالسكت على حروف التهجي"}],"10:2:25":[{"f":"لَسَٰحِرٞ","r":"دنفرفَ","n":"بكسر السين وسكون الحاء دون ألف"},{"f":"لَسِحۡرٞ","r":"احكاَحَ","n":"بكسر السين وسكون الحاء دون ألف"}],"10:3:29":[{"f":"تَذَكَّرُونَ","r":"عفرفَ","n":"تشديد الذال"},{"f":"تَذَّكَّرُونَ","r":"ادحكصاَحَ","n":"تشديد الذال"}],"10:4:7":[{"f":"إِنَّهُ","r":"ادحكنفرحَفَ","n":"بفتح الهمزة"},{"f":"أَنَّهُ","r":"اَ","n":"بفتح الهمزة"}],"10:5:5":[{"f":"ضِيَآءٗ","r":"اهحكنفراَحَفَ","n":"بالهمز (ويقف حمزة بتسهيل)"},{"f":"ضِئَآءٗ","r":"ز","n":"بالهمز (ويقف حمزة بتسهيل)"}],"10:5:20":[{"f":"يُفَصِّلُ","r":"دحعحَ","n":"بالنون"},{"f":"نُفَصِّلُ","r":"اكصفراَفَ","n":"بالنون"}]}}