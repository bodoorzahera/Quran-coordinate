{"page":304,"data":{"18:98:11":[{"f":"دَكَّآءَ","r":"نفرفَ","n":"بتنوين الكاف دون همز"},{"f":"دَكّٗا","r":"ادكاَ ح حَ","n":"بتنوين الكاف دون همز"}],"18:104:8":[{"f":"يَحۡسَبُونَ","r":"كنفاَ","n":"كسر السين"},{"f":"يَحۡسِبُونَ","r":"ادحرحَفَ","n":"كسر السين"}],"18:106:9":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}],"18:109:12":[{"f":"تَنفَدَ","r":"ادحكناَحَ","n":"بياء التذكير"},{"f":"يَنفَدَ","r":"فرفَ","n":"بياء التذكير"}]}}