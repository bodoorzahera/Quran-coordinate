{"page":102,"data":{"4:152:12":[{"f":"يُؤۡتِيهِمۡ","r":"ع","n":"بالنون وكسر الهاء"},{"f":"نُؤۡتِيهِمۡ","r":"ادحكصفراَفَ","n":"بالنون وكسر الهاء"},{"f":"نُؤۡتِيهُمۡ","r":"حَ","n":"بالنون وضم الهاء"}],"4:153:5":[{"f":"تُنَزِّلَ","r":"اذاَ","n":"سكون النون وتخفيف الزاي"},{"f":"تُنزِلَ","r":"حد حَ","n":"سكون النون وتخفيف الزاي"}],"4:153:17":[{"f":"وَأَرِنَا","r":"اذاَ","n":"إسكان الراء مفخمة"},{"f":"وَأَرۡنَا","r":"يد حَ","n":"إسكان الراء مفخمة"},{"f":"وَأَرٜنَا","r":"ط","n":"باختلاس كسر الراء"}],"4:154:13":[{"f":"تَعۡدُواْ","r":"غدك","n":"فتح العين وتشديد الدال"},{"f":"تَعَدُّواْ","r":"ج","n":"فتح العين وتشديد الدال"},{"f":"تَعۡدُّواْ","r":"ب² اَ","n":"سكون العين وتشديد الدال"},{"f":"تَع۬دُّواْ","r":"ب²","n":" اختلاس فتح العين وتشديد الدال"}]}}