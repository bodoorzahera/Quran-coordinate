{"page":526,"data":{"53:7:1":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"53:11:2":[{"f":"كَذَبَ","r":"ادحمنفرحَفَ","n":"بتشديد الذال"},{"f":"كَذَّبَ","r":"لاَ","n":"بتشديد الذال"}],"53:12:1":[{"f":"أَفَتُمَٰرُونَهُ","r":"ادحكناَ","n":"بفتح التاء وسكون الميم بدون ألف"},{"f":"أَفَتَمۡرُونَهُ","r":"فرحَفَ","n":"بفتح التاء وسكون الميم بدون ألف"}],"53:19:1":[{"f":"أَفَرَءَيۡتُمُ","r":"ادحكنفاَحَفَ","n":"بحذف الهمزة الثانية"},{"f":"أَفَرَيۡتُمُ","r":"ر","n":"بحذف الهمزة الثانية"},{"f":"أَفَرَٰ۬يۡتُم","r":"افاَ","n":"بالتسهيل"}],"53:19:2":[{"f":"ٱللَّٰتَ","r":"ادحكنفراَىَفَ","n":"بتشديد التاء مع المد المشبع"},{"f":"ٱللَّٰٓتَّ","r":"طَ","n":"بتشديد التاء مع المد المشبع"}],"53:20:1":[{"f":"وَمَنَوٰةَ","r":"احكنفراَحَفَ","n":"بهمزة مفتوحة بعد الألف فتمد على المتصل"},{"f":"وَمَنَوٰٓءَةَ","r":"د","n":"بهمزة مفتوحة بعد الألف فتمد على المتصل"}],"53:22:4":[{"f":"ضِيزَىٰٓ","r":"احكنفراَحَفَ","n":"بهمزة ساكنة مكان الياء"},{"f":"ضِئۡزَىٰٓ","r":"د","n":"بهمزة ساكنة مكان الياء"}]}}