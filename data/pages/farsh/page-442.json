{"page":442,"data":{"36:29:4":[{"f":"صَيۡحَةٗ وَٰحِدَةٗ","r":"ادحكنفرحَفَ","n":"بالرفع"},{"f":"صَيۡحَةٞ وَٰحِدَةٞ","r":"اَ","n":"بالرفع"}],"36:32:3":[{"f":"لَّمَّا","r":"فك جَن","n":"بتخفيف الميم"},{"f":"لَّمَا","r":"اربَح فَحَد","n":"بتخفيف الميم"}],"36:33:4":[{"f":"ٱلۡمَيۡتَةُ","r":"غدك","n":"بكسر وتشديد الياء"},{"f":"ٱلۡمَيِّتَةُ","r":"ااَ","n":"بكسر وتشديد الياء"}],"36:34:10":[{"f":"ٱلۡعُيُونِ","r":"احلعاَحَفَ","n":"كسر العين"},{"f":"ٱلۡعِيُونِ","r":"دمصفر","n":"كسر العين"}],"36:35:3":[{"f":"ثَمَرِهِ","r":"ادحكناَحَ","n":"بضم الثاء والميم"},{"f":"ثُمُرِهِ","r":"فرفَ","n":"بضم الثاء والميم"}],"36:35:5":[{"f":"عَمِلَتۡهُ","r":"ادحكعاَحَ","n":"بحذف الهاء"},{"f":"عَمِلَتۡهْ","r":"صفرفَ","n":"بحذف الهاء"},{"f":"عَمِلَتۡ","r":"صفرفَ"}],"36:39:1":[{"f":"وَٱلۡقَمَرَ","r":"ذاَ طَ","n":"بالرفع"},{"f":"وَٱلۡقَمَرُ","r":"احاَد","n":"بالرفع"}]}}