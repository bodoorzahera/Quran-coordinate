{"page":491,"data":{"43:24:1":[{"f":"قَٰلَ","r":"حع","n":"بضم القاف وسكون اللام دون ألف"},{"f":"قُلَ","r":"ادكصفراَحَفَ","n":"بضم القاف وسكون اللام دون ألف"}],"43:24:3":[{"f":"جِئۡتُكُم","r":"ادطكنراَحَفَ","n":"إبدال الهمزة"},{"f":"جِيتُكُم","r":"ىف","n":"إبدال الهمزة"},{"f":"جِينـٰكُم","r":"اَ","n":"بنون مفتوحة وألف مكان التاء وإبدال الهمزة"}],"43:31:5":[{"f":"ٱلۡقُرۡءَانُ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانُ","r":"دف","n":"بالنقل"}],"43:33:11":[{"f":"لِبُيُوتِهِمۡ","r":"جحعاَحَ","n":"كسر الباء الموحدة"},{"f":"لِبِيُوتِهِمۡ","r":"بدكصفرفَ","n":"كسر الباء الموحدة"}],"43:33:12":[{"f":"سُقُفٗا","r":"اكنفرحَفَ","n":"بفتح السين وسكون القاف"},{"f":"سَقۡفٗا","r":"دحاَ","n":"بفتح السين وسكون القاف"}]}}