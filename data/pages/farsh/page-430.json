{"page":430,"data":{"34:15:3":[{"f":"لِسَبَإٖ","r":"اذاَحَ","n":"بفتح الهمزة دون تنوين"},{"f":"لِسَبَأَ","r":"حه","n":"بفتح الهمزة دون تنوين"},{"f":"لِسَبَأۡ","r":"ز","n":"بسكون الهمزة"},{"f":"لِسَبَا - لِسَبَاٜ","r":"لف","n":"يقف بإبدال أو تسهيل بروم"}],"34:15:5":[{"f":"مَسۡكَنِهِمۡ","r":"فع","n":"بكسر الكاف"},{"f":"مَسۡكِنِهِمۡ","r":"رفَ","n":"بكسر الكاف"},{"f":"مَسَٰكِنِهِمۡ","r":"اكداَ صححَ","n":"بفتح السين وكسر الكاف وألف بينهما"}],"34:16:10":[{"f":"أُكُلٍ","r":"ذاَ","n":"بسكون الكاف مع التنوين"},{"f":"أُكۡلٍ","r":"اد","n":"بسكون الكاف مع التنوين"},{"f":"أُكُلِ","r":"ح حَ","n":"بضم الكاف بدون التنوين"}],"34:17:6":[{"f":"نُجَٰزِيٓ إِلَّا ٱلۡكَفُورَ","r":"فعفَ حَر","n":"بياء وفتح الزاي وألف بعدها ورفع الكفور"},{"f":"يُجَٰزَىٰٓ إِلَّا ٱلۡكَفُورُ","r":"احصاَدك","n":"بياء وفتح الزاي وألف بعدها ورفع الكفور"}],"34:19:2":[{"f":"رَبَّنَا","r":"ادحكنفراَفَ","n":"بضم الباء"},{"f":"رَبُّنَا","r":"حَ","n":"بضم الباء"}],"34:19:3":[{"f":"بَٰعِدۡ","r":"اثاَم","n":"بكسر وتشديد العين دون ألف"},{"f":"بَعِّدۡ","r":"حد ل","n":"بكسر وتشديد العين دون ألف"},{"f":"بَٰعَدَ","r":"حَ","n":"بفتح وتخفيف العين وألف قبلها وفتح الدال"}],"34:20:2":[{"f":"صَدَّقَ","r":"نفرفَ","n":"بتخفيف الدال"},{"f":"صَدَقَ","r":"ادحكاَحَ","n":"بتخفيف الدال"}],"34:22:2":[{"f":"قُلِ ٱدۡعُواْ","r":"نفحَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"قُلُ ٱدۡعُواْ","r":"ادحكراَفَ","n":"وضمك أولى الساكنين لثالث يضم"}]}}