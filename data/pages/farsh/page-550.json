{"page":550,"data":{"60:6:5":[{"f":"أُسۡوَةٌ","r":"ن","n":"بكسر الهمزة"},{"f":"إِسۡوَةٌ","r":"ادحكفراَحَفَ","n":"بكسر الهمزة"}],"60:9:16":[{"f":"أَن تَوَلَّوۡهُمۡ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء وصلاً"},{"f":"أَن تَّوَلَّوۡهُمۡ","r":"ه","n":"بتشديد التاء وصلاً"}],"60:10:39":[{"f":"تُمۡسِكُواْ","r":"ادكنفراَفَ","n":"بتشديد السين مع فتح الميم"},{"f":"تُمَسِّكُواْ","r":"ححَ","n":"بتشديد السين مع فتح الميم"}],"60:10:42":[{"f":"وَسۡـَٔلُواْ","r":"احكناَحَ","n":"بالنقل بحذف الهمزة ونقل حركة الفتح للسين"},{"f":"وَسَلُواْ","r":"دفرفَ","n":"بالنقل بحذف الهمزة ونقل حركة الفتح للسين"}]}}