{"page":161,"data":{"7:85:12":[{"f":"مِّنۡ إِلَٰهٍ غَيۡرُهُ","r":"احد فحَنفَك","n":"بكسر الراء والهاء"},{"f":"مِّنۡ إِلَٰهٍ غَيۡرِهِ","r":"راَ","n":"بكسر الراء والهاء"}],"7:86:4":[{"f":"صِرَٰطٖ","r":"ادحكنقراَحَفَ","n":"بالسين"},{"f":"صِۜرَٰطٖ","r":"زطَ","n":"بالسين"},{"f":"صـِؗرَٰطٖ","r":"ض","n":"بإشمام الصاد زاياً"}],"7:87:17":[{"f":"وَهُوَ","r":"جد فحَنفَك","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحاَر","n":"بسكون الهاء"}]}}