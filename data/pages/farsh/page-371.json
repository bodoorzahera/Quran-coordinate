{"page":371,"data":{"26:92:1":[{"f":"وَقِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"وَقـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}],"26:104:3":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"26:111:4":[{"f":"وَٱتَّبَعَكَ","r":"ادحكنفراَفَ","n":"بفتح الهمزة وسكون التاء وضم العين وألف قبلها"},{"f":"وَأَتۡبَٰعُكَ","r":"حَ","n":"بفتح الهمزة وسكون التاء وضم العين وألف قبلها"}]}}