{"page":583,"data":{"78:35:5":[{"f":"وَلَا كِذَّٰبٗا","r":"ادحكنفاَحَفَ","n":"بتخفيف الذال"},{"f":"وَلَا كِذَٰبٗا","r":"ر","n":"بتخفيف الذال"}],"78:37:2":[{"f":"رَّبِّ ٱلسَّمَٰوَٰتِ","r":"ذحَ","n":"بضم الباء"},{"f":"رَّبُّ ٱلسَّمَٰوَٰتِ","r":"اكداَ","n":"بضم الباء"}],"78:37:6":[{"f":"ٱلرَّحۡمَٰنِ","r":"كحَن","n":"بضم النون"},{"f":"ٱلرَّحۡمَٰنُ","r":"احد فراَفَ","n":"بضم النون"}],"79:10:2":[{"f":"أَءِنَّا","r":"ادحكنفرحَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِنَّا","r":"اَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"79:11:1":[{"f":"أَءِذَا","r":"دحنفاَفَ","n":"بالإخبار بهمزة واحدة مكسورة"},{"f":"إِذَا","r":"اكرحَ","n":"بالإخبار بهمزة واحدة مكسورة"}],"79:11:4":[{"f":"نَّخِرَةٗ","r":"حيَ اعاَدك","n":"بالمد بألف بعد النون"},{"f":"نَّٰخِرَةٗ","r":"صف فَطَر","n":"بالمد بألف بعد النون"}]}}