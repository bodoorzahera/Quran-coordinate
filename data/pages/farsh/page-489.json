{"page":489,"data":{"43:1:1":[{"f":"حمٓ","r":"ادحكنفرحَفَ","n":"بالكست على حرفيه"}],"43:3:3":[{"f":"قُرۡءَٰنًا","r":"احكنفراَحَفَ","n":"بالنقل"},{"f":"قُرَانًا","r":"د","n":"بالنقل"}],"43:4:2":[{"f":"فِيٓ أُمِّ","r":"ادحكناَحَفَ","n":"بكسر الهمزة وصلاً (والضم ابتداءا)"},{"f":"فِيٓ إِمِّ","r":"فر","n":"بكسر الهمزة وصلاً (والضم ابتداءا)"}],"43:5:6":[{"f":"أَن كُنتُمۡ","r":"دحكنحَ","n":"بكسر الهمزة"},{"f":"إِن كُنتُمۡ","r":"افراَفَ","n":"بكسر الهمزة"}],"43:7:4":[{"f":"نَّبِيٍّ","r":"دحكنفراَحَفَ","n":"بالهمز فيمد على المتصل"},{"f":"نَبِيٓءٍ","r":"ا","n":"بالهمز فيمد على المتصل"}],"43:10:5":[{"f":"مَهۡدٗا","r":"نفرفَ","n":"بكسر الميم وفتح الهاء وبعدها ألف"},{"f":"مِهَٰدٗا","r":"ادحكاَحَ","n":"بكسر الميم وفتح الهاء وبعدها ألف"}]}}