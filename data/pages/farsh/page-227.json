{"page":227,"data":{"11:46:8":[{"f":"عَمَلٌ غَيۡرُ","r":"احد فنفَاَك","n":"بكسر الميم وفتح اللام دون تنوين ونصب الراء"},{"f":"عَمِلَ غَيۡرَ","r":"رحَ","n":"بكسر الميم وفتح اللام دون تنوين ونصب الراء"}],"11:46:12":[{"f":"تَسۡـَٔلۡنِ","r":"ادكنفراَفَ","n":"إثبات الياء"},{"f":"تَسۡـَٔلۡنِۦ -تَسۡـَٔلۡنِۦ۬","r":"ححَ","n":"إثبات الياء"},{"f":"تَسۡـَٔلَنِّ","r":"اكاَ","n":"بفتح اللام وكسر وتشديد النون (الكسر للوصل)"},{"f":"تَسۡـَٔلَنِّۦ","r":"جاَ","n":"بفتح اللام وكسر وتشديد النون وإثبات الياء"},{"f":"تَسۡـَٔلَنَّ","r":"د","n":"بفتح اللام وفتح وتشديد النون"}],"11:50:12":[{"f":"مِّنۡ إِلَٰهٍ غَيۡرُهُ","r":"ادحكنفحَفَ","n":"بكسر الراء والهاء"},{"f":"مِّنۡ إِلَٰهٍ غَيۡرِهِ","r":"راَ","n":"بكسر الراء والهاء"}]}}