{"page":76,"data":{"3:195:25":[{"f":"وَقَٰتَلُواْ وَقُتِلُواْ","r":"ااَن ح حَ","n":"للفاعل ثم المفعول مع تشديد التاء للمفعول"},{"f":"وَقَٰتَلُواْ وَقُتِّلُواْ","r":"دك","n":"للفاعل ثم المفعول مع تشديد التاء للمفعول"},{"f":"وَقُتِلُواْ وَقَٰتَلُواْ ","r":"فرفَ","n":"تقديم المفعول قبل الفاعل"},{"f":"وَقُتِلُواْ وَقَٰتَلُواْ","r":"ففَر"}],"3:196:2":[{"f":"يَغُرَّنَّكَ","r":"ادحكنفراَىَفَ","n":"بسكون النون"},{"f":"يَغُرَّنكَ","r":"طَ","n":"بسكون النون"}],"3:198:1":[{"f":"لَٰكِنِ","r":"ادحكنفرحَفَ","n":"بفتح وتشديد النون"},{"f":"لَٰكِنَّ","r":"اَ","n":"بفتح وتشديد النون"}]}}