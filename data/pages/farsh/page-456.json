{"page":456,"data":{"38:45:2":[{"f":"عِبَٰدَنَآ","r":"احكنفراَحَفَ","n":"بفتح العين وسكون الباء دون ألف"},{"f":"عَبۡدَنَآ","r":"د","n":"بفتح العين وسكون الباء دون ألف"}],"38:46:3":[{"f":"بِخَالِصَةٖ","r":"دمغ","n":"دون تنوين"},{"f":"بِخَالِصَةِ","r":"الاَ","n":"دون تنوين"}],"38:48:3":[{"f":"وَٱلۡيَسَعَ","r":"ادحكناَحَ","n":"بفتح وتشديد اللام وسكون الياء"},{"f":"وَٱلَّيۡسَعَ","r":"فرفَ","n":"بفتح وتشديد اللام وسكون الياء"}],"38:53:3":[{"f":"تُوعَدُونَ","r":"اكنفراَحَفَ","n":"بياء الغيب"},{"f":"يُوعَدُونَ","r":"دح","n":"بياء الغيب"}],"38:57:4":[{"f":"وَغَسَّاقٞ","r":"عفرفَ","n":"بتخفيف السين"},{"f":"وَغَسَاقٞ","r":"ادحكصاَحَ","n":"بتخفيف السين"}],"38:58:1":[{"f":"وَءَاخَرُ","r":"ادكنفراَفَ","n":"بضم الهمزة وقصره"},{"f":"وَأُخَرُ","r":"ححَ","n":"بضم الهمزة وقصره"}]}}