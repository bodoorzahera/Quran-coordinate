{"page":421,"data":{"33:26:11":[{"f":"قُلُوبِهِمُ","r":"ادكنفراَفَ","n":"بكسر الهاء واليم"},{"f":"قُلُوبِهِمِ","r":"ححَ","n":"بكسر الهاء واليم"},{"f":"قُلُوبِهُمُ","r":"فرفَ","n":"بضم الهاء والميم"}],"33:26:12":[{"f":"ٱلرُّعۡبَ","r":"ادحنففَ","n":"بضم العين"},{"f":"ٱلرُّعُبَ","r":"كراَحَ","n":"بضم العين"}],"33:30:7":[{"f":"مُّبَيِّنَةٖ","r":"احكعفراَحَفَ","n":"بفتح الياء"},{"f":"مُّبَيَّنَةٖ","r":"دص","n":"بفتح الياء"}],"33:30:8":[{"f":"يُضَٰعَفۡ -ٱلۡعَذَابُ","r":"اثر","n":"بنون وكسر و تشديد العين دون ألف ونصب العذاب"},{"f":"نُضَعِّفۡ -ٱلۡعَذَابَ","r":"دك","n":"بنون وكسر و تشديد العين دون ألف ونصب العذاب"},{"f":"يُضَعَّفۡ -ٱلۡعَذَابُ","r":"حاَحَ","n":"بالياء وفتح وتشديد العين دون ألف مع رفع العذاب"}]}}