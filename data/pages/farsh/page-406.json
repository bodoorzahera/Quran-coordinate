{"page":406,"data":{"30:19:4":[{"f":"ٱلۡمَيِّتِ (معا)","r":"اعفراَحَفَ","n":"بسكون الياء"},{"f":"ٱلۡمَيۡتِ","r":"دحكص","n":"بسكون الياء"}],"30:19:14":[{"f":"تُخۡرَجُونَ","r":"ادحلناَحَ","n":"بفتح التاء وضم الراء \n(ما ذكره الشاطبي من خلاف لا يؤخذ به)"},{"f":"تَخۡرُجُونَ","r":"مفرفَ","n":"بفتح التاء وضم الراء \n(ما ذكره الشاطبي من خلاف لا يؤخذ به)"}],"30:22:13":[{"f":"لِّلۡعَٰلِمِينَ","r":"ع","n":"بفتح اللام قبل الميم"},{"f":"لِّلۡعَٰلَمِينَ","r":"ادحكصفراَحَفَ","n":"بفتح اللام قبل الميم"}],"30:24:7":[{"f":"وَيُنَزِّلُ","r":"اكنفراَفَ","n":"بسكون النون وتخفيف الزاي"},{"f":"وَيُنزِلُ","r":"دححَ","n":"بسكون النون وتخفيف الزاي"}]}}