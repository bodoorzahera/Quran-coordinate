{"page":106,"data":{"4:176:19":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"5:2:23":[{"f":"وَرِضۡوَٰنًا","r":"ادحكعفراَحَفَ","n":"بضم الراء"},{"f":"وَرُضۡوَٰنًا","r":"ص","n":"بضم الراء"}],"5:2:29":[{"f":"شَنَ‍َٔانُ","r":"احد عف ففَرحَ","n":"بسكون النون"},{"f":"شَنۡ‍َٔانُ","r":"صاَك","n":"بسكون النون"}],"5:2:32":[{"f":"أَن صَدُّوكُمۡ","r":"اذاَحَ","n":"بكسر الهمزة"},{"f":"إِن صَدُّوكُمۡ","r":"حد","n":"بكسر الهمزة"}],"5:2:43":[{"f":"وَلَا تَعَاوَنُواْ","r":"ازحكنفراَحَفَ","n":"بتشديد التاء مع مد الألف قبلها مشبعاً"},{"f":"وَلَآ تَّعَاوَنُواْ","r":"ه","n":"بتشديد التاء مع مد الألف قبلها مشبعاً"}]}}