{"page":322,"data":{"21:4:1":[{"f":"قَالَ","r":"عفرفَ","n":"بضم القاف وسكون اللام دون الألف"},{"f":"قُلۡ","r":"ادحكصاَحَ","n":"بضم القاف وسكون اللام دون الألف"}],"21:4:8":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"21:7:6":[{"f":"نُّوحِيٓ إِلَيۡهِمۡ","r":"ع","n":"بياء وفتح الحاء وألف بعدها"},{"f":"يُّوحَيٰ إِلَيۡهِمۡ","r":"ادحكصفراَحَفَ","n":"بياء وفتح الحاء وألف بعدها"}],"21:7:8":[{"f":"فَسۡـَٔلُوٓاْ ","r":"احكناَحَ","n":"بالنقل"},{"f":"فَسَلُوٓاْ ","r":"دفرفَ","n":"بالنقل"},{"f":"فَسۡـَٔلُوٓاْ","r":"احكناَحَ"},{"f":"فَسَلُوٓاْ","r":"دفرفَ"}]}}