{"page":378,"data":{"27:16:16":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"27:18:14":[{"f":"يَحۡطِمَنَّكُمۡ","r":"ادحكنفراَىَفَ","n":"بسكون النون"},{"f":"يَحۡطِمَنكُمۡ","r":"طَ","n":"بسكون النون"}],"27:21:7":[{"f":"لَيَأۡتِيَنِّي","r":"احكنفراَحَفَ","n":"بنون مفتوحة مشددة وأخرى مكسورة مخففة"},{"f":"لَيَأۡتِيَنَّنِي","r":"د","n":"بنون مفتوحة مشددة وأخرى مكسورة مخففة"}],"27:22:1":[{"f":"فَمَكَثَ","r":"نىَ","n":"بضم الكاف"},{"f":"فَمَكُثَ","r":"احاَدك ففَرطَ","n":"بضم الكاف"}],"27:22:12":[{"f":"سَبَإِۭ","r":"اهحكنفراَحَفَ","n":"بسكون الهمزة"},{"f":"سَبَأَ","r":"حه","n":"بفتح الهمز دون تنوين"},{"f":"سَبَأۡ","r":"ز","n":"بسكون الهمزة"},{"f":"سَبَا - سَبَاٜ","r":"لف","n":"يقف بإبدال أو تسهيل بروم"}]}}