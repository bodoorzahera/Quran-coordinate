{"page":363,"data":{"25:38:2":[{"f":"وَثَمُودَاْ","r":"عف حَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"وَثَمُودٗا","r":"حاصر فَدكاَ","n":"بالتنوين ويبدل ألف وقفا"}],"25:41:6":[{"f":"هُزُوٗا","r":"عففَ","n":"ضم الزاي مع الهمز"},{"f":"هُزُؤٗا","r":"ادحكصراَحَ","n":"ضم الزاي مع الهمز"},{"f":"هُزۡؤٗا","r":"ففَ","n":"إسكان الزاي مع الهمز"},{"f":"هُزۡوَا\nهُزَوْا","r":"ف","n":"إسكان الزاي وإبدال الهمز واو\nأو حذفها ونقل حركتها للزاي"}]}}