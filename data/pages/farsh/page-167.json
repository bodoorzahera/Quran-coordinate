{"page":167,"data":{"7:138:8":[{"f":"يَعۡكُفُونَ","r":"أكدناَ ح حَ","n":"بكسر الكاف"},{"f":"يَعۡكِفُونَ","r":"ففَر","n":"بكسر الكاف"}],"7:140:6":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"7:141:2":[{"f":"أَنجَيۡنَٰكُم","r":"ادحنفراَحَفَ","n":"من غير ياء ولا نون"},{"f":"أَنجَٰكُم","r":"ك","n":"من غير ياء ولا نون"}],"7:141:9":[{"f":"يُقَتِّلُونَ","r":"دحكنفراَحَفَ","n":"بفتح الياء وسكون القاف وضم وتخفيف التاء"},{"f":"يَقۡتُلُونَ","r":"ا","n":"بفتح الياء وسكون القاف وضم وتخفيف التاء"}],"7:142:1":[{"f":"وَوَٰعَدۡنَا","r":"اذد","n":"بحذف الألف الأولى"},{"f":"وَوَعَدۡنَا","r":"حاَحَ","n":"بحذف الألف الأولى"}],"7:143:9":[{"f":"أَرِنِيٓ","r":"اذاَ","n":"بسكون الراء"},{"f":"أَرۡنِيٓ","r":"يد حَ","n":"بسكون الراء"},{"f":"أَرٜنِيٓ","r":"ط","n":"اختلاس كسر الراء"}],"7:143:15":[{"f":"وَلَٰكِنِ ٱنظُرۡ","r":"فن ح حَ","n":"وضمك أولى الساكنين لثالث يضم"},{"f":"وَلَٰكِنُ ٱنظُرۡ","r":"ااَردفَك","n":"وضمك أولى الساكنين لثالث يضم"}],"7:143:29":[{"f":"دَكّٗا","r":"أكدناَ ح حَ","n":"بهمزة مفتوحة بعد الألف دون تنوين"},{"f":"دَكَّاءَ","r":"ففَر","n":"بهمزة مفتوحة بعد الألف دون تنوين"}],"7:143:39":[{"f":"وَأَنَا۠","r":"غدك","n":"بإثبات الألف مطلقا"},{"f":"وَأَنَآ","r":"ااَ","n":"بإثبات الألف مطلقا"}]}}