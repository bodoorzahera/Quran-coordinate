{"page":302,"data":{"18:76:12":[{"f":"لَّدُنِّي","r":"عكف حد فَرحَ","n":"بتخفيف النون"},{"f":"لَّدُنِي","r":"ااَ","n":"بتخفيف النون"},{"f":"لَّد۬نِي","r":"ص²","n":"تخفيف النون مع اختلاس ضم الدال"},{"f":"لَّدۡنِي","r":"ص²","n":"تخفيف النون مع إسكانها الدال مع الإشمام"}],"18:77:22":[{"f":"لَتَّخَذۡتَ","r":"اذاَ","n":"بتخفيف التاء وكسر الخاء \n(إدغام الذال والتاء من الأصول)"},{"f":"لَتَخِذۡتَ","r":"حد حَ","n":"بتخفيف التاء وكسر الخاء \n(إدغام الذال والتاء من الأصول)"}],"18:81:3":[{"f":"يُبۡدِلَهُمَا","r":"كحَظ","n":"بفتح الباء وتشديد الدال"},{"f":"يُبَدِّلَهُمَا","r":"احاَ","n":"بفتح الباء وتشديد الدال"}],"18:81:9":[{"f":"رُحۡمٗا","r":"احظ","n":"بضم الحاء"},{"f":"رُحُمٗا","r":"كاَحَ","n":"بضم الحاء"}]}}