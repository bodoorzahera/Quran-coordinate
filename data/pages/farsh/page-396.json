{"page":396,"data":{"28:85:5":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"دف","n":"بالنقل"}],"28:88:19":[{"f":"تُرۡجَعُونَ","r":"ادحكنفراَفَ","n":"بفتح التاء وكسر الجيم"},{"f":"تَرۡجِعُونَ","r":"حَ","n":"بفتح التاء وكسر الجيم"}],"29:1:1":[{"f":"الٓمٓ","r":"ادحكنفرحَفَ","n":"السكت على حروفه"}],"29:2:9":[{"f":"أَلِفۡۜ لَآمۜ مِّيٓمۡۜ","r":"اَ","n":"السكت على حروفه"}],"29:5:10":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}]}}