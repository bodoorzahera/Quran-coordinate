{"page":372,"data":{"26:114:2":[{"f":"أَنَا۠ إِلَّا","r":"جدحكنفراَحَفَ","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"},{"f":"أَنَآ إِلَّا","r":"ب","n":"إثبات الألف مطلقا فتمد على المنفصل وصلا"}],"26:122:3":[{"f":"لَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"لَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"26:134:2":[{"f":"وَعُيُونٍ","r":"احلعاَحَفَ","n":"كسر العين"},{"f":"وَعِيُونٍ","r":"دمصفر","n":"كسر العين"}]}}