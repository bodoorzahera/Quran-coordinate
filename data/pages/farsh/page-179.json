{"page":179,"data":{"8:17:3":[{"f":"وَلَٰكِنَّ ٱللَّهَ (معا)","r":"ادحناَحَ","n":"بتخفيف وكسر النون ورفع الهاء"},{"f":"وَلَٰكِنِ ٱللَّهُ","r":"كفرفَ","n":"بتخفيف وكسر النون ورفع الهاء"}],"8:18:4":[{"f":"مُوهِنُ كَيۡدِ","r":"كنفرحَفَ","n":"بتنوين النون وفتح الدال"},{"f":"مُوهِنٞ كَيۡدَ","r":"كصفرحَفَ","n":"بتنوين النون وفتح الدال"},{"f":"مُوَهِّنٞ كَيۡدَ","r":"ادحاَ","n":"بفتح الواو وتشديد الهاء وتنوين النون وفتح الدال"}],"8:19:6":[{"f":"وَأَنَّ ٱللَّهَ","r":"اكعاَ","n":"بكسر الهمزة"},{"f":"وَإِنَّ ٱللَّهَ","r":"دحصفرحَفَ","n":"بكسر الهمزة"}],"8:19:8":[{"f":"فَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"فَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"8:20:7":[{"f":"وَلَا تَوَلَّوۡاْ","r":"ازحكنفراَحَفَ","n":"شدد التاء وصلا فتمد الألف قبلها مشبعا"},{"f":"وَلَآ تَّوَلَّوۡاْ","r":"ه","n":"شدد التاء وصلا فتمد الألف قبلها مشبعا"}]}}