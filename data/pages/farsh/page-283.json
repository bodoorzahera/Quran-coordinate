{"page":283,"data":{"17:9:3":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"د","n":"بالنقل"}],"17:9:8":[{"f":"وَيُبَشِّرُ","r":"ادحكناَحَفَ","n":"فتح الياء وسكون الباء وضم وتخفيف الشين"},{"f":"وَيَبۡشُرُ","r":"فر","n":"فتح الياء وسكون الباء وضم وتخفيف الشين"}],"17:13:7":[{"f":"وَنُخۡرِجُ","r":"احظك","n":"بياء مضمومة وفتح الراء"},{"f":"وَيُخۡرَجُ","r":"اَ","n":"بياء مضمومة وفتح الراء"},{"f":"وَيَخۡرُجُ","r":"حَ","n":"بياء مفتوحة وضم الراء"}],"17:13:12":[{"f":"يَلۡقَىٰهُ","r":"اعد","n":"بضم الياء وفتح اللام وتشديد القاف"},{"f":"يُلَقَّىٰهُ","r":"كا","n":"بضم الياء وفتح اللام وتشديد القاف"}],"17:16:6":[{"f":"أَمَرۡنَا","r":"ادحكنفراَفَ","n":"بالألف بعد الهمزة"},{"f":"ءَامَرۡنَا","r":"حَ","n":"بالألف بعد الهمزة"}]}}