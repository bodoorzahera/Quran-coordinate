{"page":579,"data":{"76:15:7":[{"f":"كَانَتۡ قَوَارِيرَا۠","r":"حكعفحَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"كَانَتۡ قَوَارِيرٗا","r":"ادصراَفَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"كَانَتۡ قَوَارِيرَاْ","r":"فطَ","n":"دون تنوين والوقف بالراء"}],"76:15:8":[{"f":"قَوَارِيرَاْ مِن","r":"دحكعفحَفَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"قَوَارِيرٗا مِن","r":"اصراَ","n":"بالتنوين ويبدل ألف وقفا"},{"f":"قَوَارِيرَا۠ مِن","r":"ل","n":"دون تنوين والوقف بالألف"}],"76:21:1":[{"f":"عَٰلِيَهُمۡ","r":"درك فن ح حَ","n":"بسكون الياء مع كسر الهاء"},{"f":"عَٰلِيهِمۡ","r":"افاَ","n":"بسكون الياء مع كسر الهاء"}],"76:21:4":[{"f":"خُضۡرٞ","r":"احكعاَحَ","n":"بالخفض"},{"f":"خُضۡرٖ","r":"دصفرفَ","n":"بالخفض"}],"76:21:5":[{"f":"وَإِسۡتَبۡرَقٞ","r":"ادن","n":"بالخفض"},{"f":"وَإِسۡتَبۡرَقٖ","r":"حكفراَحَفَ","n":"بالخفض"},{"f":"خُضۡرٞ وَإِسۡتَبۡرَقٞ","r":"اع"},{"f":"خُضۡرٖ وَإِسۡتَبۡرَقٖ","r":"ففَر"},{"f":"خُضۡرٖ وَإِسۡتَبۡرَقٞ","r":"صد"},{"f":"خُضۡرٞ وَإِسۡتَبۡرَقٖ","r":"حكاَ حَ"}],"76:23:5":[{"f":"ٱلۡقُرۡءَانَ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانَ","r":"دف","n":"بالنقل"}]}}