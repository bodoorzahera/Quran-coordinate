{"page":410,"data":{"30:52:3":[{"f":"تُسۡمِعُ ٱلصُّمَّ","r":"احكنفراَحَفَ","n":"بياء مفتوحة وفتح الميم ثم رفع الصم"},{"f":"يَسۡمَعُ ٱلصُّمُّ","r":"د","n":"بياء مفتوحة وفتح الميم ثم رفع الصم"}],"30:53:3":[{"f":"بِهَٰدِ ٱلۡعُمۡيِ","r":"ادحكنفاَفَ","n":"الوقوف بالياء بعد الدال"},{"f":"بِهَٰدِۦ۠ ٱلۡعُمۡيِ","r":"رحَ","n":"الوقوف بالياء بعد الدال"}],"30:53:4":[{"f":"تَهۡدِۦ۠ ٱلۡعُمۡيَ","r":"ف","n":"بتاء مضارعة مفتوحة وسكون الهاء \nوالوقوف بياء ثم نصب العمي"}],"30:54:5":[{"f":"ضَعۡفٖ (معا)-ضَعۡفٗا","r":"ڲ","n":"بضم الضاد"},{"f":"ضُعۡفٖ -ضُعۡفٗا","r":"ڲ","n":"بضم الضاد"}],"30:54:22":[{"f":"وَهُوَ","r":"جدكنفحَفَ","n":"بسكون الهاء"},{"f":"وَهۡوَ","r":"بحراَ","n":"بسكون الهاء"}],"30:57:3":[{"f":"يَنفَعُ","r":"نفرفَ","n":"بالتاء"},{"f":"تَنفَعُ","r":"ادحكاَحَ","n":"بالتاء"}],"30:58:6":[{"f":"ٱلۡقُرۡءَانِ","r":"احكنراَحَفَ","n":"بالنقل"},{"f":"ٱلۡقُرَانِ","r":"دف","n":"بالنقل"}],"30:60:7":[{"f":"يَسۡتَخِفَّنَّكَ","r":"ادحكنفراَىَفَ","n":"بسكون النون"},{"f":"يَسۡتَخِفَّنكَ","r":"طَ","n":"بسكون النون"}]}}