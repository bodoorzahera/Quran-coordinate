{"page":214,"data":{"10:44:7":[{"f":"وَلَٰكِنَّ ٱلنَّاسَ","r":"ادحكناَحَ","n":"بسكون النون فتكسر على الوصل ورفع الناس"},{"f":"وَلَٰكِنِ ٱلنَّاسُ","r":"فرفَ","n":"بسكون النون فتكسر على الوصل ورفع الناس"}],"10:45:2":[{"f":"يَحۡشُرُهُمۡ","r":"ع","n":"بالنون"},{"f":"نَحۡشُرُهُمۡ","r":"ادحكصفراَحَفَ","n":"بالنون"}],"10:52:2":[{"f":"قِيلَ","r":"ادحمنفاَىَفَ","n":"بإشمام كسر القاف ضماً"},{"f":"قـ۬يلَ","r":"لرطَ","n":"بإشمام كسر القاف ضماً"}]}}